<div class="collection-page">
  <div class="collection-main">
    <div class="collection-grid-rhode bundle-grid">
      
      <!-- GLASS SKIN BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/products/elaris-7-korean-glass-skin-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'main.jpg' | file_img_url: '600x' }}" class="card-img" alt="Korean Glass Skin Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">KOREAN GLASS SKIN BUNDLE</h3>
          <p class="card-price">
            <span class="original-price">RS. 13,354</span> RS. 6,677
          </p>
          <div class="card-shop-btn">SHOP THE SET</div>
        </div>
      </div>

      <!-- BRIGHTENING BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/products/elaris-7-korean-brightening-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'Artboard_4-100_jpg.jpg' | file_img_url: '600x' }}" class="card-img" alt="Korean Brightening Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">KOREAN BRIGHTENING BUNDLE</h3>
          <p class="card-price">
            <span class="original-price">RS. 10,784</span> RS. 5,392
          </p>
          <div class="card-shop-btn">SHOP THE SET</div>
        </div>
      </div>

      <!-- HAIR CARE BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/products/elaris-7-korean-hair-care-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'hair_care_main.jpg' | file_img_url: '600x' }}" class="card-img" alt="Hair Care Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">HAIR CARE BUNDLE</h3>
          <p class="card-price">
            <span class="original-price">RS. 8,430</span> RS. 4,215
          </p>
          <div class="card-shop-btn">SHOP THE SET</div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.collection-grid-rhode.bundle-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  padding: 40px 15px;
  max-width: 1400px;
  margin: 0 auto;
}
@media (max-width: 768px) {
  .collection-grid-rhode.bundle-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 20px 15px;
  }
}

.card-rhode {
  cursor: pointer;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  border: 1px solid #f0f0f0;
}
.card-image-wrapper {
  position: relative;
  aspect-ratio: 1/1.2;
  overflow: hidden;
  background: #fff;
}
.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.card-rhode:hover .card-img {
  transform: scale(1.05);
}

.card-info { 
  padding: 20px 10px; 
  text-align: center;
}
.card-name { 
  font-size: 0.75rem; 
  font-weight: 800; 
  color: #333; 
  margin-bottom: 8px; 
  letter-spacing: 0.05em;
}
.card-price {
  font-size: 0.75rem;
  font-weight: 700;
  color: #333;
  margin-bottom: 15px;
}
.original-price {
  text-decoration: line-through;
  color: #999;
  margin-right: 8px;
  font-weight: 400;
  font-size: 0.65rem;
}
.card-shop-btn {
  border: 1px solid #333;
  border-radius: 50px;
  padding: 6px 20px;
  font-size: 0.65rem;
  font-weight: 700;
  color: #333;
  text-transform: uppercase;
  display: inline-block;
  transition: all 0.3s ease;
}
.card-rhode:hover .card-shop-btn {
  background: #333;
  color: #fff;
}
</style>

{% schema %}
{
  "name": "Sets Grid",
  "settings": []
}
{% endschema %}
