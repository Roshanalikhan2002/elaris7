<div class="collection-page">
  <div class="collection-main">
    <div class="collection-grid-rhode bundle-grid">
      
      <!-- GLASS SKIN BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/collections/elaris-7-korean-glass-skin-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'main.jpg' | file_img_url: '600x' }}" class="card-img" alt="Korean Glass Skin Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">KOREAN GLASS SKIN BUNDLE</h3>
          <div class="card-buy-btn">BUY - RS. 4,800</div>
        </div>
      </div>

      <!-- HAIR CARE BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/collections/elaris-7-korean-hair-care-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'hair_care_main.jpg' | file_img_url: '600x' }}" class="card-img" alt="Hair Care Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">HAIR CARE BUNDLE</h3>
          <div class="card-buy-btn">BUY - RS. 7,515</div>
        </div>
      </div>

      <!-- BRIGHTENING BUNDLE -->
      <div class="card card-rhode bundle-card" onclick="window.location.href='/collections/elaris-7-korean-brightening-bundle'">
        <div class="card-image-wrapper">
          <img src="{{ 'Artboard_4-100_jpg.jpg' | file_img_url: '600x' }}" class="card-img" alt="Korean Brightening Bundle">
        </div>
        <div class="card-info">
          <h3 class="card-name">KOREAN BRIGHTENING BUNDLE</h3>
          <div class="card-buy-btn">BUY - RS. 5,392</div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.collection-grid-rhode.bundle-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  padding: 40px 20px;
  max-width: 1200px;
  margin: 0 auto;
}
@media (max-width: 768px) {
  .collection-grid-rhode.bundle-grid {
    grid-template-columns: 1fr;
    gap: 15px;
  }
}

.card-rhode {
  cursor: pointer;
  background: #f4f4f2;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}
.card-image-wrapper {
  position: relative;
  aspect-ratio: 1/1.4;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #f4f4f2;
}
.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
}
.card-rhode:hover .card-img {
  transform: scale(1.05);
}

.card-info { 
  padding: 15px 10px 20px; 
  text-align: center;
}
.card-name { 
  font-size: 0.65rem; 
  font-weight: 800; 
  color: #333; 
  margin-bottom: 12px; 
  letter-spacing: 0.05em;
  line-height: 1.4;
}
.card-buy-btn {
  border: 1px solid #333;
  border-radius: 50px;
  padding: 8px 15px;
  font-size: 0.65rem;
  font-weight: 800;
  color: #333;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: inline-block;
}
.card-rhode:hover .card-buy-btn {
  background: #333;
  color: #fff;
}
</style>

{% schema %}
{
  "name": "Sets Grid",
  "settings": []
}
{% endschema %}
