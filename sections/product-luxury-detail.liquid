{%- assign is_renewal_cleanser = false -%}
{%- if product.handle contains 'cleanser' or product.handle == 'centella-skin-toner-copy' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or product.handle == 'renewal-cleanser' -%}
  {%- assign is_renewal_cleanser = true -%}
{%- endif -%}

{%- assign is_centella_serum = product.handle == 'centella-serum' or product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}

{%- assign display_title = product.title -%}
{%- if is_renewal_cleanser -%}
  {%- assign display_title = "Renewal Cleanser" -%}
{%- elsif is_centella_serum -%}
  {%- assign display_title = "Centella Serum" -%}
{%- endif -%}

<style>
  .product-page { padding: 20px; max-width: 1400px; margin: 0 auto; background: #fff; }
  .product-grid { display: grid; grid-template-columns: 100px 1fr 1fr; gap: 40px; }
  .gallery-thumbnails { display: flex; flex-direction: column; gap: 15px; }
  .thumb-item { width: 80px; height: 100px; cursor: pointer; border: 1px solid #eee; overflow: hidden; }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-item.active { border: 2px solid #333; }
  
  .gallery-main-viewport { width: 100%; overflow: hidden; border-radius: 12px; aspect-ratio: 4/5; }
  .gallery-slider { display: flex; transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); height: 100%; }
  .gallery-slide { flex: 0 0 100%; height: 100%; }
  .gallery-slide img { width: 100%; height: 100%; object-fit: cover !important; }
  
  .product-details { padding: 0 20px; }
  .product-title { font-size: 3rem; margin: 0; color: #333; text-transform: lowercase; font-weight: 800; }
  
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: 1fr; }
    .gallery-thumbnails { order: 2; flex-direction: row; justify-content: center; }
  }
</style>

<main class="product-page">
  <div class="product-grid">
    <div class="gallery-thumbnails">
      {%- if is_renewal_cleanser -%}
        <div class="thumb-item active" onmouseover="scrollGallery(0, this)"><img src="{{ 'gel cleanser-100.jpg' | asset_url }}" alt="Cleanser Main"></div>
        <div class="thumb-item" onmouseover="scrollGallery(1, this)"><img src="{{ 'cleanser-meet-1.jpg' | asset_url }}" alt="Cleanser Model 1"></div>
        <div class="thumb-item" onmouseover="scrollGallery(2, this)"><img src="{{ 'cleanser-meet-2.jpg' | asset_url }}" alt="Cleanser Model 2"></div>
        <div class="thumb-item" onmouseover="scrollGallery(3, this)"><img src="{{ 'cleanser-meet-3.jpg' | asset_url }}" alt="Cleanser Model 3"></div>
      {%- else -%}
        {%- for image in product.images -%}
          <div class="thumb-item {% if forloop.first %}active{% endif %}" onmouseover="scrollGallery({{ forloop.index0 }}, this)"><img src="{{ image | img_url: '200x200', crop: 'center' }}" alt="{{ image.alt }}"></div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="gallery-main-viewport">
      <div class="gallery-slider" id="productSlider">
        {%- if is_renewal_cleanser -%}
          <div class="gallery-slide"><img src="{{ 'gel cleanser-100.jpg' | asset_url }}" class="force-pink" alt="Main Pink Cleanser"></div>
          <div class="gallery-slide"><img src="{{ 'cleanser-meet-1.jpg' | asset_url }}" alt="Model Shot 1"></div>
          <div class="gallery-slide"><img src="{{ 'cleanser-meet-2.jpg' | asset_url }}" alt="Model Shot 2"></div>
          <div class="gallery-slide"><img src="{{ 'cleanser-meet-3.jpg' | asset_url }}" alt="Model Shot 3"></div>
        {%- else -%}
          {%- for image in product.images -%}
            <div class="gallery-slide"><img src="{{ image | img_url: 'master' }}" alt="{{ image.alt }}"></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="product-details">
      <div class="product-details-inner">
        <div class="product-header">
          <h1 class="product-title">{{ display_title }}</h1>
          {%- if is_renewal_cleanser or is_centella_serum -%}
            <div class="product-award"><div class="award-seal">BEST OF BEAUTY</div></div>
          {%- endif -%}
        </div>

        <div class="product-meta" style="margin-top: 15px; display: flex; align-items: center; gap: 15px;">
          <span class="product-subtitle" style="font-weight: 700; color: #8c8b84; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em;">{{ section.settings.subtitle | default: "Premium Formula" }}</span>
          <div class="product-reviews" style="font-size: 0.9rem; color: #5b5a53;">
            <span class="stars">★★★★★</span>
            <span class="review-count">({{ section.settings.review_count | default: "1.2k" }})</span>
          </div>
        </div>

        <div class="product-description" style="margin-top: 25px;">
           <p style="font-size: 1.1rem; line-height: 1.6; color: #555;">{{ product.description }}</p>
        </div>

        <hr style="border: none; border-top: 1px solid rgba(0,0,0,0.06); margin: 30px 0;">

        {%- form 'product', product, id: "product-main-form" -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div class="product-actions">
            <button type="submit" name="add" class="buy-button" style="width: 100%; background: #002d5f; color: #fff; border: none; padding: 20px; border-radius: 50px; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: transform 0.2s, background 0.2s;">
              ADD TO BAG — {{ product.price | money }}
            </button>
          </div>
        {%- endform -%}

        <hr style="border: none; border-top: 1px solid rgba(0,0,0,0.06); margin: 30px 0;">

        <div class="product-accordions">
          <details style="margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
            <summary style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 700; color: #333; list-style: none;">
              <span>BENEFITS</span>
              <span>+</span>
            </summary>
            <div style="padding-top: 15px; color: #666; line-height: 1.6;">
              <p>Experience deep hydration and visible radiance with our advanced formula.</p>
            </div>
          </details>
          <details style="margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
            <summary style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 700; color: #333; list-style: none;">
              <span>HOW TO USE</span>
              <span>+</span>
            </summary>
            <div style="padding-top: 15px; color: #666; line-height: 1.6;">
              <p>Apply to clean skin in the AM and PM for best results.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  function scrollGallery(index, thumb) {
    const slider = document.getElementById('productSlider');
    if (slider) slider.style.transform = `translateX(-${index * 100}%)`;
    document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
    if (thumb) thumb.classList.add('active');
  }
</script>
