</main>

<script>
  // ── Gift selection UI ──
  function selectGift(el) {
    document.querySelectorAll('.gift-item').forEach(item => item.classList.remove('selected'));
    el.classList.add('selected');
    const radio = el.querySelector('.gift-radio');
    if (radio) radio.checked = true;
  }

  // ── BOGO Add to Cart ──
  async function bogoAddToCart(buyNow = false) {
    const mainVariantId  = {{ product.selected_or_first_available_variant.id }};
    const mainProductTitle = {{ product.title | json }};

    // Find selected free gift variant ID from the checked radio
    const selectedRadio = document.querySelector('input[name="free_gift"]:checked');
    const giftVariantId  = selectedRadio ? parseInt(selectedRadio.value) : null;
    const giftLabel      = selectedRadio
      ? selectedRadio.closest('.gift-item')?.querySelector('.gift-name')?.textContent?.trim()
      : null;

    // Build items array — always start with main product
    const items = [
      { id: mainVariantId, quantity: 1 }
    ];

    // Add free gift if one is selected
    if (giftVariantId) {
      items.push({
        id: giftVariantId,
        quantity: 1,
        properties: {
          '_free_gift': 'true',
          '_free_gift_for': mainProductTitle
        }
      });
    }

    // Disable buttons while adding
    const addBtn  = document.getElementById('bogo-add-to-cart');
    const buyBtn  = document.getElementById('bogo-buy-now');
    if (addBtn) { addBtn.disabled = true; addBtn.textContent = 'Adding...'; }
    if (buyBtn) { buyBtn.disabled = true; }

    try {
      const res = await fetch('/cart/add.js', {
        method : 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body   : JSON.stringify({ items })
      });

      if (!res.ok) throw new Error('Cart add failed');

      if (buyNow) {
        window.location.href = '/checkout';
      } else {
        window.location.href = '/cart';
      }
    } catch (err) {
      console.error('BOGO cart error:', err);
      alert('Could not add to cart. Please try again.');
    } finally {
      if (addBtn) { addBtn.disabled = false; addBtn.textContent = 'ADD TO CART'; }
      if (buyBtn) { buyBtn.disabled = false; }
    }
  }
</script>


