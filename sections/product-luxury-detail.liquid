<style>
  .product-page { padding: 40px 20px; max-width: 1400px; margin: 0 auto; background: #fff; }
  .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  
  .gallery-side { position: sticky; top: 40px; }
  .gallery-main-viewport { width: 100%; border-radius: 14px; overflow: hidden; background: #fff; border: 1px solid #f0f0f0; }
  .gallery-main-viewport img { width: 100%; height: auto; display: block; object-fit: contain; }
  
  /* Details Column */
  .product-details { padding: 0; }
  .product-title { font-size: 3rem; font-weight: 900; color: #1a1a1a; margin-bottom: 30px; text-transform: uppercase; line-height: 1; }
  .product-description { font-size: 1.15rem; line-height: 1.6; color: #444; margin-bottom: 45px; letter-spacing: -0.01em; max-width: 90%; }
  
  /* BOGO Section */
  .bogo-container { border: 2px solid #002d5f; border-radius: 12px; padding: 24px; background: #fff; margin-bottom: 30px; }
  .bogo-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; cursor: pointer; }
  .bogo-title { display: flex; align-items: center; gap: 12px; font-size: 1.25rem; font-weight: 700; color: #002d5f; }
  .bogo-radio-main { width: 22px; height: 22px; accent-color: #002d5f; cursor: pointer; }
  .bogo-price { font-weight: 700; font-size: 1.25rem; color: #000; }
  
  .bogo-instruction { display: flex; align-items: center; gap: 8px; font-size: 0.95rem; font-weight: 700; color: #444; margin-bottom: 15px; }
  
  .gift-list { display: flex; flex-direction: column; gap: 12px; }
  .gift-item { border: 1px solid #e0e0e0; border-radius: 10px; padding: 14px; display: flex; align-items: center; gap: 15px; cursor: pointer; transition: all 0.2s ease; }
  .gift-item:hover { border-color: #b0b0b0; background: #fcfcfc; }
  .gift-item.selected { border-width: 2px; border-color: #002d5f; background: #f4f7ff; }
  .gift-radio { width: 18px; height: 18px; accent-color: #002d5f; }
  .gift-thumb { width: 55px; height: 55px; border-radius: 6px; overflow: hidden; background: #f9f9f9; border: 1px solid #eee; }
  .gift-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .gift-info { flex: 1; }
  .gift-name { font-weight: 700; font-size: 1rem; color: #1a1a1a; margin-bottom: 2px; }
  .gift-price { font-size: 0.9rem; color: #666; font-weight: 500; }
  .gift-badge { font-weight: 800; color: #002d5f; margin-left: 8px; font-size: 0.85rem; }
  
  .add-to-cart-btn { width: 100%; background: #002d5f; color: #fff; border: none; padding: 22px; border-radius: 50px; font-weight: 700; font-size: 1.3rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: transform 0.2s, opacity 0.2s; margin-top: 10px; }
  .add-to-cart-btn:hover { opacity: 1; transform: translateY(-2px); background: #001a3d; }
  
  /* Modern Accordions matching reference image 2 */
  .modern-accordions { margin-top: 50px; border-top: 1px solid #eee; }
  .acc-item { border-bottom: 1px solid #eee; }
  .acc-summary { display: flex; justify-content: space-between; align-items: center; padding: 25px 0; cursor: pointer; font-weight: 700; font-size: 1.2rem; color: #1a1a1a; list-style: none; }
  .acc-summary::-webkit-details-marker { display: none; }
  .acc-icon { color: #002d5f; font-size: 1.5rem; transition: transform 0.3s ease; }
  details[open] .acc-icon { transform: rotate(45deg); }
  .acc-content { padding-bottom: 25px; color: #555; line-height: 1.7; font-size: 1.05rem; }

  @media (max-width: 900px) {
    .product-grid { grid-template-columns: 1fr; gap: 30px; }
    .product-title { font-size: 2.2rem; }
  }
</style>

<main class="product-page">
  <div class="product-grid">
    <div class="gallery-side">
      <div class="gallery-main-viewport">
        {%- assign asset_image_name = '' -%}
        {%- case product.handle -%}
          {%- when 'night-cream' -%}{%- assign asset_image_name = 'night-cream.jpg' -%}
          {%- when 'tranexamic-serum' -%}{%- assign asset_image_name = 'tranexamic-serum.jpg' -%}
          {%- when 'anti-frizz-keratin-serum' -%}{%- assign asset_image_name = 'keratin-serum.jpg' -%}
          {%- when 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}{%- assign asset_image_name = 'glow-serum-100.jpg' -%}
          {%- when 'glutathione-cream' -%}{%- assign asset_image_name = 'glutathione-cream-100.jpg' -%}
          {%- when 'hair-mist' -%}{%- assign asset_image_name = 'hair-mist.jpg' -%}
          {%- when 'e7-korean-glass-skin-centella-night-cream-copy' -%}{%- assign asset_image_name = 'facewash-100.jpg' -%}
          {%- when 'e7-korean-glass-skin-centella-face-wash-copy' -%}{%- assign asset_image_name = 'sunscreen-100.jpg' -%}
          {%- when 'centella-skin-toner-copy' or 'renewal-cleanser' -%}{%- assign asset_image_name = 'gel cleanser-100.jpg' -%}
          {%- when 'e7-korean-glass-skin-moisturizer' -%}{%- assign asset_image_name = 'moisturizer-100.jpg' -%}
          {%- when 'centella-skin-toner' or 'renewal-toner' -%}{%- assign asset_image_name = 'toner1.jpeg' -%}
        {%- endcase -%}

        {%- if asset_image_name != blank -%}
          <img src="{{ asset_image_name | asset_url }}" alt="{{ product.title }}">
        {%- elsif product.featured_image != blank -%}
          <img src="{{ product.featured_image | img_url: '1200x' }}" alt="{{ product.title }}">
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=1000" alt="Fallback Product Image">
        {%- endif -%}
      </div>
    </div>

    <div class="product-details">
      {%- assign handle_down = product.handle | downcase | strip -%}
      {%- assign title_up = product.title | upcase -%}
      {%- assign is_centella_serum = false -%}
      {%- assign is_glutathione_cream = false -%}
      {%- assign is_hair_mist = false -%}
      {%- if handle_down contains 'centella-serum' or handle_down contains 'spf50-copy' or title_up contains 'CENTELLA' and title_up contains 'SERUM' or title_up contains 'GLOW SERUM' -%}
        {%- assign is_centella_serum = true -%}
      {%- elsif handle_down contains 'glutathione' or title_up contains 'GLUTATHIONE' -%}
        {%- assign is_glutathione_cream = true -%}
      {%- elsif handle_down contains 'hair-mist' or title_up contains 'HAIR MIST' -%}
        {%- assign is_hair_mist = true -%}
      {%- endif -%}
      {%- assign is_night_cream = false -%}
      {%- assign is_face_wash = false -%}
      {%- if title_up contains 'FACE WASH' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or handle_down contains 'face-wash' or product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
        {%- assign is_face_wash = true -%}
      {%- elsif handle_down == 'night-cream' or title_up contains 'NIGHT CREAM' -%}
        {%- assign is_night_cream = true -%}
      {%- endif -%}

      {%- if is_night_cream -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Your Overnight Glow Secret</div>
      {%- elsif is_face_wash -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Fresh Skin Begins Here</div>
      {%- elsif product.handle == 'tranexamic-serum' -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Fade Spots. Reveal Clarity.</div>
      {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Smooth Hair. Zero Frizz.</div>
      {%- elsif is_centella_serum -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Targeted Glow. Visible Clarity.</div>
      {%- elsif is_glutathione_cream -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Brighten & Repair</div>
      {%- elsif is_hair_mist -%}
        <div class="catchy-title" style="font-size: 1.2rem; font-weight: 700; color: #a09d94; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Refresh & Revive</div>
      {%- endif -%}
      <h1 class="product-title" style="margin-bottom: 5px;">{% if product.handle == 'tranexamic-serum' %}Elaris7 Tranexamic Brightening Serum{% else %}{{ product.title }}{% endif %}</h1>
      {%- if is_night_cream -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Night Renewal</div>
      {%- elsif is_face_wash -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Gentle Cleansing + pH Balance</div>
      {%- elsif product.handle == 'tranexamic-serum' -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Even & Illuminate</div>
      {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Smooth Control</div>
      {%- elsif is_centella_serum -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Radiance Reset</div>
      {%- elsif is_glutathione_cream -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Even & Radiant</div>
      {%- elsif is_hair_mist -%}
        <div style="font-size: 1.5rem; font-weight: 600; color: #444; margin-bottom: 25px; font-style: italic;">Scented Shine</div>
      {%- endif -%}
      
      <div class="product-description" style="margin-top: 20px; margin-bottom: 40px;">
        <p style="font-size: 1.15rem; line-height: 1.6; color: #444;">
          {%- if section.settings.description != blank -%}
            {{ section.settings.description }}
          {%- elsif is_night_cream -%}
            An intensive overnight formula designed to rejuvenate your skin while you sleep. Infused with Centella Asiatica, brightening complexes, and repair-focused botanicals, this night cream hydrates deeply, improves skin texture, and helps reveal a smoother, luminous, and refreshed complexion by morning.
          {%- elsif is_face_wash -%}
            A gentle, glow-reviving cleanser infused with Centella Asiatica, brightening actives, and hydrating botanicals to cleanse, soothe, and refresh your skin for a soft, balanced, and radiant look every day.
          {%- elsif product.handle == 'tranexamic-serum' -%}
             A targeted brightening serum designed to reduce the appearance of dark spots and uneven tone. It helps improve clarity, boost radiance, and support a smoother, more even-looking complexion with consistent use.
          {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
             A smoothing hair serum designed to control frizz, protect against heat, and restore softness without weighing hair down. It seals moisture, enhances shine, and leaves hair silky, manageable, and smooth with every use.
          {%- elsif is_centella_serum -%}
             A concentrated, glow-correcting serum infused with Centella Asiatica and advanced brightening actives to visibly even tone, fade dark spots, and restore a smooth, glass-like complexion over time.
          {%- elsif is_glutathione_cream -%}
             A nourishing brightening cream designed to improve uneven tone, reduce dullness, and support skin repair. It helps fade the look of dark spots, restore radiance, and leave skin smoother and healthier with consistent use.
          {%- elsif is_hair_mist -%}
             A refreshing hair mist designed to instantly revive your hair with a soft floral scent. It helps add a natural shine, refresh between washes, and keep your hair feeling clean and beautifully scented all day.
          {%- else -%}
            {{ product.description }}
          {%- endif -%}
        </p>
      </div>

      <div class="bogo-container">
        <div class="bogo-header" style="margin-bottom: 25px;">
          <div class="bogo-title">
            <input type="radio" name="offer_type" value="bogo" checked class="bogo-radio-main">
            <span style="font-size: 1.3rem;">Buy 1 Get 1 FREE Offer</span>
          </div>
          <div class="bogo-price" style="font-size: 1.3rem;">{{ product.price | money }}</div>
        </div>
        
        <div class="bogo-content">
          <div class="bogo-instruction">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"></path></svg>
            Choose your free item
          </div>
          
          <div class="gift-list">
             {%- comment -%} Dynamically fetching ALL products from the store for the gift selection {%- endcomment -%}
             {%- assign count = 0 -%}
             {%- for gift_prod in collections.all.products -%}
               {%- if gift_prod.available and gift_prod.handle != product.handle -%}
                 {%- assign count = count | plus: 1 -%}
                 <label class="gift-item {% if count == 1 %}selected{% endif %}" onclick="selectGift(this)">
                   <div class="gift-radio-wrap"><input type="radio" name="free_gift" value="{{ gift_prod.first_available_variant.id }}" {% if count == 1 %}checked{% endif %} class="gift-radio"></div>
                   <div class="gift-thumb">
                     {%- if gift_prod.featured_image -%}
                       <img src="{{ gift_prod.featured_image | img_url: '100x100' }}" alt="{{ gift_prod.title }}">
                     {%- else -%}
                       <div style="width:100%; height:100%; background:#eee; display:flex; align-items:center; justify-content:center; font-size:10px; color:#999;">No Image</div>
                     {%- endif -%}
                   </div>
                   <div class="gift-info">
                     <div class="gift-name">{{ gift_prod.title }}</div>
                     <div class="gift-price"><span style="text-decoration: line-through; opacity: 0.6;">{{ gift_prod.price | money }}</span><span class="gift-badge">FREE</span></div>
                   </div>
                 </label>
               {%- endif -%}
             {%- endfor -%}
          </div>
        </div>
      </div>

      <div class="action-buttons" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px;">
        <button type="button" class="add-to-cart-btn" id="bogo-add-to-cart" style="margin-top: 0; width: 100%;" onclick="bogoAddToCart()">ADD TO CART</button>
        <button type="button" class="buy-now-btn" id="bogo-buy-now" style="width: 100%; background: #fff; color: #002d5f; border: 2px solid #002d5f; padding: 22px; border-radius: 50px; font-weight: 700; font-size: 1.3rem; cursor: pointer; transition: all 0.2s;" onclick="bogoAddToCart(true)">BUY NOW</button>
      </div>

      <div class="modern-accordions">
        <details class="acc-item">
          <summary class="acc-summary">Benefits <span class="acc-icon">+</span></summary>
          <div class="acc-content">
            <ul style="padding-left: 20px;">
              {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
                <li>Boosts skin radiance for a naturally luminous glow</li>
                <li>Provides 72-hour hydration with a moisture-locking formula</li>
                <li>Supports collagen to improve skin firmness and elasticity</li>
                <li>Helps fade dark spots, acne scars, and discoloration</li>
                <li>Repairs and strengthens the skin barrier overnight</li>
                <li>Delivers a soft, smooth, poreless finish by morning</li>
                <li>Reduces the appearance of fine lines and wrinkles</li>
                <li>Promotes a more even-toned, youthful-looking complexion over time</li>
              {%- elsif product.handle == 'tranexamic-serum' -%}
                <li>Helps reduce the appearance of dark spots and discoloration</li>
                <li>Supports a brighter, more even skin tone</li>
                <li>Improves dullness and uneven texture</li>
                <li>Enhances overall skin clarity and radiance</li>
                <li>Hydrates while supporting the skin barrier</li>
                <li>Helps smooth and refine the skin surface</li>
                <li>Promotes a healthier, more luminous glow</li>
              {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
                <li>Instantly controls frizz for a smoother look</li>
                <li>Helps reduce hair breakage and split ends</li>
                <li>Protects hair from heat styling damage</li>
                <li>Locks in moisture for long-lasting smoothness</li>
                <li>Enhances shine and softness without heaviness</li>
                <li>Keeps hair manageable and easy to style</li>
              {%- elsif is_centella_serum -%}
                <li>Helps brighten skin and improve overall tone clarity</li>
                <li>Fades the appearance of dark spots and post-acne marks</li>
                <li>Supports firmness while enhancing skin elasticity</li>
                <li>Delivers deep hydration for a plump, radiant finish</li>
                <li>Helps calm sensitivity and strengthen the skin barrier</li>
                <li>Refines pores and smooths uneven texture</li>
              {%- elsif is_glutathione_cream -%}
                <li>Helps visibly brighten dull and uneven skin tone</li>
                <li>Supports reduction of dark spots and pigmentation</li>
                <li>Helps improve post-acne marks and discoloration</li>
                <li>Provides deep hydration and skin barrier support</li>
                <li>Leaves skin soft, smooth and radiant</li>
                <li>Helps restore skin clarity and evenness over time</li>
                <li>Promotes a naturally healthy, luminous glow</li>
              {%- elsif is_hair_mist -%}
                <li>Instantly refreshes hair with a soft floral scent</li>
                <li>Adds a natural, healthy shine without grease</li>
                <li>Helps revive hair between washes</li>
                <li>Keeps hair smelling beautiful all day</li>
                <li>Lightweight formula that doesn't weigh hair down</li>
                <li>Suitable for all hair types</li>
              {%- elsif product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
                <li>Gently removes dirt, oil, and daily buildup</li>
                <li>Helps improve dull and uneven skin tone</li>
                <li>Supports a clearer, brighter-looking complexion</li>
                <li>Maintains hydration while cleansing the skin</li>
                <li>Leaves skin feeling soft and comfortable</li>
                <li>Helps refresh and revive tired-looking skin</li>
                <li>Prepares skin for better absorption of skincare</li>
              {%- endif -%}
            </ul>
          </div>
        </details>

        <details class="acc-item">
          <summary class="acc-summary">Application <span class="acc-icon">+</span></summary>
          <div class="acc-content">
            {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
