{%- style -%}
  /* Luxury Product Page Specific Styles */
  .product-page {
    padding: 16px;
    background-color: #ffffff;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 12px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: start; /* Required for sticky columns in CSS Grid */
  }
  .product-gallery {
    position: sticky;
    top: 20px;
    height: calc(100vh - 40px);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  @media (max-width: 850px) {
    .product-gallery {
      position: relative;
      top: 0;
      height: auto;
      aspect-ratio: 1/1;
      margin-bottom: 12px;
    }
  }
  .product-gallery-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .main-product-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: 14px;
  }
  .product-details {
    background-color: #f3f0ec;
    border-radius: 14px;
    padding: 60px 40px;
  }
  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8px;
  }
  .product-title {
    font-size: 3.5rem;
    font-weight: 900;
    margin: 0;
    color: #5b5a53;
    line-height: 1;
    letter-spacing: -0.04em;
    text-transform: lowercase;
  }
  .product-award {
    background-color: #e02b20;
    color: white;
    padding: 8px;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 800;
    text-align: center;
    line-height: 1.1;
  }
  .product-meta {
    margin-bottom: 30px;
  }
  .product-subtitle {
    font-size: 0.9rem;
    font-weight: 700;
    color: #5b5a53;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 12px;
  }
  .product-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
  }
  .stars { color: #5b5a53; }
  .review-count { color: #7a7873; }
  
  .product-description {
    font-size: 1rem;
    line-height: 1.5;
    color: #5b5a53;
    margin-bottom: 40px;
  }
  .divider {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin: 30px 0;
  }
  .size-selector {
    display: flex;
    gap: 12px;
    margin-top: 12px;
  }
  .size-btn {
    flex: 1;
    background: transparent;
    border: 1px solid #5b5a53;
    border-radius: 40px;
    padding: 12px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
  }
  .size-btn.active {
    background: #ffffff;
    border-width: 2px;
  }
  .size-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 2px; }
  .size-desc { font-size: 0.75rem; color: #7a7873; }
  
  .buy-button {
    width: 100%;
    background: #5b5a53;
    color: white;
    border: none;
    border-radius: 40px;
    padding: 18px;
    font-size: 0.9rem;
    font-weight: 700;
    margin-top: 30px;
    cursor: pointer;
  }
  
  .accordions {
    margin-top: 40px;
  }
  .accordion-item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
    padding: 18px 0;
    display: flex;
    justify-content: space-between;
    cursor: pointer;
    font-weight: 700;
    font-size: 0.85rem;
    color: #5b5a53;
  }

  .bogo-offer-container {
    margin: 24px 0 32px 0;
  }
  .bogo-main-offer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid #004d2e;
    background-color: #f6faf7;
    border-radius: 8px;
    padding: 16px;
    cursor: pointer;
    margin-bottom: 24px;
  }
  .bogo-radio-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .bogo-main-offer input[type="radio"],
  .gift-option input[type="radio"] {
    display: none;
  }
  .custom-radio {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #004d2e;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bogo-main-offer input[type="radio"]:checked + .custom-radio::after {
    content: '';
    width: 10px;
    height: 10px;
    background: #004d2e;
    border-radius: 50%;
  }
  .offer-title {
    font-weight: 700;
    color: #004d2e;
    font-size: 1.2rem;
  }
  .offer-price {
    font-weight: 700;
    color: #111;
    font-size: 1.1rem;
  }

  .bogo-gift-selector {
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fff;
    padding: 0;
    overflow: hidden;
  }
  .gift-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px;
    font-weight: 700;
    color: #333;
    border-bottom: 1px solid #e5e5e5;
  }
  .gift-options-list {
    display: flex;
    flex-direction: column;
    max-height: 400px;
    overflow-y: auto;
  }
  .gift-option {
    display: flex;
    align-items: center;
    padding: 16px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    transition: background 0.2s;
  }
  .gift-option:hover {
    background: #fafafa;
  }
  .gift-option:last-child {
    border-bottom: none;
  }
  .gift-radio-custom {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid #ccc;
    margin-right: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gift-option input[type="radio"]:checked + .gift-radio-custom {
    border-color: #0066cc;
  }
  .gift-option input[type="radio"]:checked + .gift-radio-custom::after {
    content: '';
    width: 8px;
    height: 8px;
    background: #0066cc;
    border-radius: 50%;
  }
  .gift-img, .gift-img-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    border: 1px solid #eee;
    object-fit: cover;
    margin-right: 12px;
  }
  .gift-img-placeholder {
    background: #f5f5f5;
  }
  .gift-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gift-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #111;
  }
  .gift-price {
    font-size: 0.75rem;
  }
  .old-price {
    color: #888;
    text-decoration: line-through;
  }
  .free-text {
    font-weight: 600;
    color: #333;
    margin-left: 4px;
  }

  @media (max-width: 850px) {
    .product-grid { grid-template-columns: 1fr; }
    .product-title { font-size: 2.5rem; }
    .product-details { padding: 40px 20px; }
  }
{%- endstyle -%}

<main class="product-page">
  <div class="product-grid">
    <div class="product-gallery">
      <div class="product-gallery-inner">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '1200x' }}" class="main-product-img" alt="{{ product.title }}">
        {% else %}
          <img src="{{ 'night-cream.jpg' | asset_url }}" class="main-product-img" alt="Night Cream" style="object-fit: contain; background: #f2f0ed;">
        {% endif %}
      </div>
    </div>

    <div class="product-details">
      <div class="product-header">
        <h1 class="product-title">{{ product.title | default: "night cream" }}</h1>
        <div class="product-award">BEST OF BEAUTY</div>
      </div>

      <div class="product-meta">
        <span class="product-subtitle">ADVANCED GLOW REGEN NIGHT CREAM</span>
        <div class="product-reviews">
          <span class="stars">★★★★★</span>
          <span class="review-count">(1,895)</span>
        </div>
      </div>

      <div class="product-description">
        {{ product.description | default: "An advanced overnight renewal cream formulated with Centella Asiatica and Peptides. Our ultra-rich formula works while you sleep to deeply nourish and restore radiance overnight." }}
      </div>

      <hr class="divider">

      <div class="bogo-offer-container">
        <!-- Main Offer Box -->
        <label class="bogo-main-offer">
          <div class="bogo-radio-wrapper">
            <input type="radio" name="main_offer" checked>
            <span class="custom-radio"></span>
            <span class="offer-title">Buy 1 Get 1 FREE Offer</span>
          </div>
          <span class="offer-price">Rs.1,690</span>
        </label>

        <!-- Gift Selector Box -->
        <div class="bogo-gift-selector">
          <div class="gift-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
            <span class="gift-title">Choose your item</span>
          </div>
          
          <div class="gift-options-list">
            
            <label class="gift-option">
              <input type="radio" name="free_gift" value="cleanser" checked>
              <div class="gift-radio-custom"></div>
              <img src="https://images.unsplash.com/photo-1629198688000-71f23e745b6e?q=80&w=100" class="gift-img" alt="Cleanser">
              <div class="gift-details">
                <div class="gift-name">Oil to Foam Cleanser</div>
                <div class="gift-price"><span class="old-price">Rs.2,850.00</span> <span class="free-text">FREE</span></div>
              </div>
            </label>

            <label class="gift-option">
              <input type="radio" name="free_gift" value="toner">
              <div class="gift-radio-custom"></div>
              <div class="gift-img-placeholder"></div>
              <div class="gift-details">
                <div class="gift-name">Skin Refining Toner</div>
                <div class="gift-price"><span class="old-price">Rs.2,670.00</span> <span class="free-text">FREE</span></div>
              </div>
            </label>

            <label class="gift-option">
              <input type="radio" name="free_gift" value="moisturizer">
              <div class="gift-radio-custom"></div>
              <div class="gift-img-placeholder"></div>
              <div class="gift-details">
                <div class="gift-name">Centella Moisturizer</div>
                <div class="gift-price"><span class="old-price">Rs.2,499.00</span> <span class="free-text">FREE</span></div>
              </div>
            </label>
            
            <label class="gift-option">
              <input type="radio" name="free_gift" value="serum">
              <div class="gift-radio-custom"></div>
              <div class="gift-img-placeholder"></div>
              <div class="gift-details">
                <div class="gift-name">Centella Serum</div>
                <div class="gift-price"><span class="old-price">Rs.2,540.00</span> <span class="free-text">FREE</span></div>
              </div>
            </label>
            
            <label class="gift-option" style="opacity: 0.5;">
              <input type="radio" name="free_gift" value="sunscreen" disabled>
              <div class="gift-radio-custom"></div>
              <div class="gift-img-placeholder"></div>
              <div class="gift-details">
                <div class="gift-name">Centella Sunscreen SPF60+</div>
                <div class="gift-price"><span class="old-price">Rs.2,630.00</span> <span class="free-text">FREE</span></div>
              </div>
            </label>

          </div>
        </div>
      </div>

      <button class="buy-button">BUY {{ product.title | upcase | default: "NIGHT CREAM" }} - Rs. 1,500</button>
      
      <div class="afterpay" style="margin-top: 15px; font-size: 0.8rem; color: #7a7873; text-align: center;">
        or interest-free payments with <strong>Afterpay</strong> ⓘ
      </div>

      <hr class="divider">

      <div class="accordions">
        <div class="accordion-item"><span>BENEFITS</span><span>+</span></div>
        <div class="accordion-item"><span>APPLICATION</span><span>+</span></div>
        <div class="accordion-item"><span>KEY INGREDIENTS</span><span>+</span></div>
      </div>
    </div>
  </div>
</main>

{% schema %}
{
  "name": "Luxury Product Detail",
  "settings": [],
  "presets": [
    {
      "name": "Luxury Product Detail"
    }
  ]
}
{% endschema %}
