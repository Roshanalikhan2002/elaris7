    <script>
      function toggleAccordion(btn) {
        const wrap = btn.parentElement;
        const panel = wrap.querySelector('.accordion-content-panel');
        const isOpen = wrap.classList.contains('active');
        
        // Close others
        document.querySelectorAll('.accordion-item-wrap').forEach(item => {
          item.classList.remove('active');
          item.querySelector('.accordion-content-panel').style.gridTemplateRows = '0fr';
        });

        if (!isOpen) {
          wrap.classList.add('active');
          panel.style.gridTemplateRows = '1fr';
        }
      }
    </script>
