<style>
  .product-page { padding: 40px 20px; max-width: 1400px; margin: 0 auto; background: #fff; }
  .product-grid { display: grid; grid-template-columns: 80px 1fr 1fr; gap: 40px; }
  
  /* Thumbnails on the far left */
  .gallery-thumbnails { display: flex; flex-direction: column; gap: 12px; }
  .thumb-item { width: 60px; height: 60px; cursor: pointer; border-radius: 8px; overflow: hidden; border: 2px solid transparent; background: #f9f9f9; }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-item.active { border-color: #000; }
  
  .gallery-main-viewport { width: 100%; border-radius: 20px; overflow: hidden; background: #f9f9f9; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
  .gallery-slider { display: flex; width: 100%; height: 100%; transition: transform 0.4s ease; }
  .gallery-slide { flex: 0 0 100%; display: flex; align-items: center; justify-content: center; }
  .gallery-slide img { max-width: 90%; max-height: 90%; object-fit: contain; }
  
  /* Details Column */
  .product-details { background: #f3f3f3; border-radius: 20px; padding: 40px; position: sticky; top: 40px; height: fit-content; }
  .product-title { font-size: 2.8rem; font-weight: 900; line-height: 1; color: #333; margin-bottom: 20px; text-transform: uppercase; }
  .product-description { font-size: 1rem; line-height: 1.5; color: #444; margin-bottom: 30px; }
  
  /* Variant Selector */
  .variant-selector { margin-bottom: 30px; }
  .selector-group { display: flex; gap: 12px; margin-bottom: 20px; }
  .selection-btn { border: 1px solid #ccc; padding: 12px 24px; border-radius: 30px; background: #fff; cursor: pointer; font-weight: 600; font-size: 0.9rem; }
  .selection-btn.active { background: #000; color: #fff; border-color: #000; }
  
  .shape-swatches { display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 30px; }
  .shape-item { display: flex; flex-direction: column; align-items: center; gap: 8px; cursor: pointer; }
  .shape-icon { width: 45px; height: 45px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; border: 2px solid transparent; }
  .shape-icon.active { border-color: #000; }
  .shape-label { font-size: 0.75rem; font-weight: 700; text-transform: lowercase; color: #666; }
  
  .buy-button { width: 100%; background: #ffb800; color: #002d5f; border: none; padding: 22px; border-radius: 30px; font-weight: 900; font-size: 1.2rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 12px rgba(255,184,0,0.3); }
  
  /* Accordions */
  .product-accordions { margin-top: 30px; border-top: 1px solid #ddd; }
  .accordion-item { border-bottom: 1px solid #ddd; padding: 15px 0; }
  .accordion-summary { display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 800; font-size: 1rem; color: #555; text-transform: uppercase; }
  .accordion-summary span:last-child { font-size: 1.2rem; color: #999; }
  
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: 1fr; }
    .gallery-thumbnails { order: 2; flex-direction: row; justify-content: center; }
  }
</style>

<main class="product-page">
  <div class="product-grid">
    <div class="gallery-thumbnails">
      {%- for image in product.images -%}
        <div class="thumb-item {% if forloop.first %}active{% endif %}" onmouseover="scrollGallery({{ forloop.index0 }}, this)"><img src="{{ image | img_url: '200x200', crop: 'center' }}" alt="{{ image.alt }}"></div>
      {%- endfor -%}
    </div>

    <div class="gallery-main-viewport">
      <div class="gallery-slider" id="productSlider">
        {%- for image in product.images -%}
          <div class="gallery-slide"><img src="{{ image | img_url: 'master' }}" alt="{{ image.alt }}"></div>
        {%- endfor -%}
      </div>
    </div>

    <div class="product-details">
      <h1 class="product-title">{{ product.title }}</h1>
      <div class="product-description">
        <p>{{ product.description }}</p>
      </div>

      <div class="variant-selector">
        <div class="selector-group">
          <button class="selection-btn active">solo</button>
          <button class="selection-btn">all five shapes <span style="background: #eee; border-radius: 4px; padding: 2px 6px; font-size: 0.7rem;">SAVE 10%</span></button>
        </div>
        
        <div class="shape-swatches">
           {%- comment -%} Sample swatches to match reference image {%- endcomment -%}
           <div class="shape-item">
             <div class="shape-icon active" style="background: #ffb800;"><svg width="24" height="24" viewBox="0 0 24 24" fill="#fff"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
             <span class="shape-label">daisy</span>
           </div>
           <div class="shape-item">
             <div class="shape-icon" style="background: #ccc;"></div>
             <span class="shape-label">bubble</span>
           </div>
           <div class="shape-item">
             <div class="shape-icon" style="background: #00a86b;"></div>
             <span class="shape-label">shroom</span>
           </div>
           <div class="shape-item">
             <div class="shape-icon" style="background: #a2c2e1;"></div>
             <span class="shape-label">curve</span>
           </div>
           <div class="shape-item">
             <div class="shape-icon" style="background: #f4c2c2;"></div>
             <span class="shape-label">jelly bean</span>
           </div>
        </div>
      </div>

      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="buy-button">JOIN THE WAITLIST — {{ product.price | money }}</button>
      {%- endform -%}

      <div class="product-accordions">
        <div class="accordion-item"><div class="accordion-summary"><span>BENEFITS</span><span>+</span></div></div>
        <div class="accordion-item"><div class="accordion-summary"><span>APPLICATION</span><span>+</span></div></div>
        <div class="accordion-item"><div class="accordion-summary"><span>KEY INGREDIENTS</span><span>+</span></div></div>
      </div>
    </div>
  </div>
</main>

<script>
  function scrollGallery(index, thumb) {
    const slider = document.getElementById('productSlider');
    if (slider) slider.style.transform = `translateX(-${index * 100}%)`;
    document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
    if (thumb) thumb.classList.add('active');
  }
</script>

<script>
  function scrollGallery(index, thumb) {
    const slider = document.getElementById('productSlider');
    if (slider) slider.style.transform = `translateX(-${index * 100}%)`;
    document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
    if (thumb) thumb.classList.add('active');
  }
</script>
