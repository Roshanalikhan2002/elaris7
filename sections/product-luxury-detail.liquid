          <img src="{{ 'night-cream-jar.jpg' | asset_url }}" alt="Thumb 2">
        </div>
        <div class="thumb-item" onmouseover="updateGallery(2, this)">
          <img src="{{ 'night-cream-ba.jpg' | asset_url }}" alt="Thumb 3">
        </div>
        <div class="thumb-item" onmouseover="updateGallery(3, this)">
