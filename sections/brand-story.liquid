<section id="story" class="section" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="split-section">
      <div class="split-content">
        <h2>{{ section.settings.title }}</h2>
        <p>{{ section.settings.story_text }}</p>
        {% if section.settings.btn_link != blank %}
          <a href="{{ section.settings.btn_link }}" class="btn btn-secondary mt-4">{{ section.settings.btn_text }}</a>
        {% endif %}
      </div>
      <div class="split-image">
        {% if section.settings.story_image != blank %}
          {{ section.settings.story_image | image_url: width: 800 | image_tag: alt: section.settings.title }}
        {% else %}
          <div style="background:#ddd; width:100%; height:500px; display:flex; align-items:center; justify-content:center; border-radius:8px;">Brand Story Image</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f8f6f2"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Sunnah Beauty meets Korean Skincare"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "Story Content",
      "default": "At Elaris7, we combine the purity of ancient Sunnah beauty rituals with the innovation of modern Korean skincare science."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Image"
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}


