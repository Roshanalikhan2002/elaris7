{%- style -%}
  .benefits-focus-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 16px 60px 16px;
  }
  
  .bf-left {
    background-color: #f3f0ec;
    border-radius: 14px;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  
  .bf-subtitle {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #8c8a82;
    margin-bottom: 40px;
  }
  
  .bf-title-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .bf-line {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    color: #9c9a96;
    letter-spacing: -0.04em;
  }
  
  .bf-line-highlight {
    color: #002d5f; /* Deep blue requested by user */
  }

  .bf-right {
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    min-height: 500px;
  }
  
  .bf-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  @media (max-width: 900px) {
    .benefits-focus-section {
      grid-template-columns: 1fr;
      margin: 0;
      gap: 0;
    }
    .bf-left {
      padding: 60px 20px;
      border-radius: 0;
    }
    .bf-line {
      font-size: 2.5rem;
    }
    .bf-right {
      min-height: 400px;
      border-radius: 0;
      order: -1;
    }
  }
{%- endstyle -%}

<section class="benefits-focus-section">
  <div class="bf-left">
    {%- assign bf_subtitle = section.settings.subtitle | default: 'SPREAD IT ON FOR:' -%}
    {%- assign handle_down = product.handle | downcase -%}
    {%- assign title_up = product.title | upcase -%}
    {%- assign is_sunscreen = false -%}
    {%- if product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' or product.handle == 'sunscreen' or title_up contains 'SUNSCREEN' -%}
      {%- assign is_sunscreen = true -%}
    {%- endif -%}

    {%- assign is_night_cream = false -%}
    {%- assign is_face_wash = false -%}
    {%- if (title_up contains 'FACE WASH' or title_up contains 'CLEANSER' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy') and is_sunscreen == false -%}
      {%- assign is_face_wash = true -%}
    {%- elsif handle_down == 'night-cream' or title_up contains 'NIGHT CREAM' -%}
      {%- assign is_night_cream = true -%}
    {%- endif -%}

    {%- if is_night_cream or is_face_wash -%}
      {%- assign bf_subtitle = 'WASH IT ON TO:' -%}
    {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
      {%- assign bf_subtitle = 'MIST IT ON TO:' -%}
    {%- endif -%}
    <div class="bf-subtitle">{{ bf_subtitle }}</div>
    <div class="bf-title-group">
    {%- assign handle_down = product.handle | downcase -%}
    {%- assign title_up = product.title | upcase -%}
    {%- assign is_centella_serum = false -%}
    {%- assign is_glutathione_cream = false -%}
    {%- if handle_down == 'centella-serum' or handle_down == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or title_up contains 'CENTELLA SERUM' or title_up contains 'GLOW SERUM' -%}
      {%- assign is_centella_serum = true -%}
    {%- elsif handle_down == 'glutathione-cream' or title_up contains 'GLUTATHIONE' -%}
      {%- assign is_glutathione_cream = true -%}
    {%- endif -%}

    {%- if is_night_cream -%}
      <div class="bf-line">deep repair</div>
      <div class="bf-line">overnight hydration</div>
      <div class="bf-line bf-line-highlight">revitalized, luminous skin</div>
      <div class="bf-line">baby-soft skin</div>
    {%- elsif is_face_wash -%}
      <div class="bf-line">fresh, balanced skin</div>
      <div class="bf-line">gentle daily cleansing</div>
      <div class="bf-line bf-line-highlight">natural, radiant glow</div>
    {%- elsif is_centella_serum -%}
      <div class="bf-line">evened-out tone</div>
      <div class="bf-line">bright, radiant skin</div>
      <div class="bf-line bf-line-highlight">smooth, glass-like finish</div>
    {%- elsif is_glutathione_cream -%}
      <div class="bf-line">visible brightening</div>
      <div class="bf-line">intense repair</div>
      <div class="bf-line bf-line-highlight">even, radiant tone</div>
        {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
          <div class="bf-line">hair refresh</div>
          <div class="bf-line">soft floral scent</div>
          <div class="bf-line bf-line-highlight">natural shine</div>
        {%- elsif product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
          <div class="bf-line">daily cleansing</div>
          <div class="bf-line">brighter skin</div>
          <div class="bf-line bf-line-highlight">fresh, clean feel</div>
        {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' -%}
          <div class="bf-line">all-day hydration</div>
          <div class="bf-line">natural radiance</div>
          <div class="bf-line bf-line-highlight">soft, glass-like skin</div>
        {%- elsif product.handle == 'centella-skin-toner' -%}
          <div class="bf-line">refined, balanced skin</div>
          <div class="bf-line">smoother texture</div>
          <div class="bf-line bf-line-highlight">clear, radiant glow</div>
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
           <div class="bf-line">daily defense</div>
           <div class="bf-line">weightless feel</div>
           <div class="bf-line bf-line-highlight">complete protection</div>
        {%- else -%}
          {%- for block in section.blocks -%}
             <div class="bf-line {% if block.settings.highlight %}bf-line-highlight{% endif %}" {{ block.shopify_attributes }}>
               {{ block.settings.text | downcase }}
             </div>
          {%- endfor -%}
          {%- if section.blocks.size == 0 -%}
              <div class="bf-line">deep repair</div>
              <div class="bf-line">overnight hydration</div>
              <div class="bf-line bf-line-highlight">revitalized, luminous skin</div>
          {%- endif -%}
        {%- endif -%}
    </div>
  </div>
  
  <div class="bf-right">
    {%- if product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' or product.handle == 'sunscreen' or is_sunscreen -%}
      <img class="bf-image" src="{{ 'sunscreen-lifestyle-1.jpg' | asset_url }}" alt="Sunscreen Protection">
    {%- elsif is_night_cream -%}
    {%- elsif is_face_wash -%}
      <img class="bf-image" src="{{ 'faq-100-13.jpg' | asset_url }}" alt="Face Wash Shot">
    {%- elsif is_centella_serum -%}
      <img class="bf-image" src="{{ 'glow-meet-4.jpg' | asset_url }}" alt="Centella Serum Shot">
    {%- elsif is_glutathione_cream -%}
      <img class="bf-image" src="{{ 'toner-deep-hydration.jpg' | asset_url }}" alt="Refined, balanced skin">
    {%- elsif product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
      <img class="bf-image" src="{{ 'cleanser-meet-3.jpg' | asset_url }}" alt="Gel Cleanser Shot">
    {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' -%}
      <img class="bf-image" src="{{ 'moisturizer-deep-hydration.jpg' | asset_url }}" alt="Moisturizer Shot">
    {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
      <img class="bf-image" src="{{ 'hair-mist-meet-1.jpg' | asset_url }}" alt="Hair Mist Shot">
    {%- elsif product.handle == 'anti-frizz-keratin-serum' -%}
      <img class="bf-image" src="{{ 'keratin-meet-1.jpg' | asset_url }}" alt="Keratin Shot">
    {%- elsif product.handle == 'glutathione-cream' -%}
      <img class="bf-image" src="{{ 'glutathione-meet-1.jpg' | asset_url }}" alt="Glutathione Shot">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'bf-image', alt: 'Benefits Visual' }}
    {%- else -%}
      <img class="bf-image" src="https://images.unsplash.com/photo-1549439602-43ebca2327af?q=80&w=1000" alt="Jewelry and Cosmetics setup">
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Benefits Focus Split",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "SPREAD IT ON FOR:"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    }
  ],
  "blocks": [
    {
      "type": "benefit_line",
      "name": "Benefit Line",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "deep hydration"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight Color (Green)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Focus Split"
    }
  ]
}
{% endschema %}
