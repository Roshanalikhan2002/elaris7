{% schema %}
{
  "name": "Rhode Footer",
  "settings": [
    {
      "type": "text",
      "id": "branding_text",
      "label": "Giant Branding Text",
      "default": "elaris7"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Footer Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rhode Footer"
    }
  ]
}
{% endschema %}
