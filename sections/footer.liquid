<footer class="site-footer-rhode">
  <!-- 1. Massive Logo Header -->
  <div class="footer-logo-massive">
    <h1 class="logo-text-giant">elaris7</h1>
  </div>

  <div class="footer-main-grid">
    <!-- 2. Newsletter & Intro -->
    <div class="footer-column newsletter-column">
      <p class="newsletter-intro">Join us on the rhode to an effortless glow.</p>
      <p class="newsletter-sub">Glaze your inbox with tips, tricks & exclusive content from Elaris7.</p>
      
      <form class="footer-newsletter-form">
        <input type="email" placeholder="Email Address" required>
        <button type="submit">SUBSCRIBE</button>
      </form>
      
      <p class="newsletter-disclaimer">By signing up, you agree to our Privacy Policy*.</p>
    </div>

    <!-- 3. Navigate -->
    <div class="footer-column">
      <h4>NAVIGATE</h4>
      <ul>
        <li><a href="/collections/all">Shop</a></li>
        <li><a href="/pages/our-story">Our Story</a></li>
        <li><a href="/pages/futures">Rhode Futures</a></li>
        <li><a href="/pages/impact">Impact</a></li>
        <li><a href="/pages/vlog">VLOG</a></li>
        <li><a href="/pages/find-us">Where to Find Us</a></li>
      </ul>
    </div>

