{%- style -%}
  .study-results-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 16px 60px 16px;
  }
  
  .sr-left {
    background-color: #f3f0ec;
    border-radius: 14px;
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .sr-stat-block {
    margin-bottom: 45px;
  }
  
  .sr-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #002d5f; /* Deep blue requested by user */
    margin: 0 0 8px 0;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  
  .sr-desc {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #6a6863;
    letter-spacing: 0.05em;
    margin: 0;
  }
  
  .sr-footnote {
    font-size: 0.75rem;
    color: #5b5a53;
    margin-top: 10px;
  }

  .sr-right {
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    min-height: 500px;
  }
  
  .sr-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  @media (max-width: 900px) {
    .study-results-section {
      grid-template-columns: 1fr;
      margin: 0;
      gap: 0;
    }
    .sr-left {
      padding: 50px 24px;
      border-radius: 0;
    }
    .sr-number {
      font-size: 2.2rem;
    }
    .sr-right {
      min-height: 400px;
      order: -1; /* Push image to top on mobile */
      border-radius: 0;
    }
  }
{%- endstyle -%}

{%- comment -%}
  CENTRALIZED STUDY RESULTS MAPPING
{%- endcomment -%}

{%- assign handle_down = product.handle | downcase -%}
{%- assign title_up = product.title | upcase -%}
{%- assign is_serum = false -%}
{%- assign is_glutathione_cream = false -%}
{%- if handle_down contains 'centella-serum' or handle_down contains 'spf50-copy' or title_up contains 'CENTELLA' and title_up contains 'SERUM' or title_up contains 'GLOW SERUM' -%}
  {%- assign is_serum = true -%}
{%- elsif handle_down contains 'glutathione' or title_up contains 'GLUTATHIONE' -%}
  {%- assign is_glutathione_cream = true -%}
{%- endif -%}

{%- assign is_sunscreen = false -%}
{%- if product.handle == 'sunscreen' or product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
  {%- assign is_sunscreen = true -%}
{%- endif -%}

{%- assign is_night_cream = false -%}
{%- assign is_face_wash = false -%}
{%- if title_up contains 'FACE WASH' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or handle_down contains 'face-wash' or handle_down contains 'cleanser' -%}
  {%- assign is_face_wash = true -%}
{%- elsif handle_down == 'night-cream' or title_up contains 'NIGHT CREAM' -%}
  {%- assign is_night_cream = true -%}
{%- endif -%}

{%- assign is_cleanser = false -%}
{%- if is_face_wash or product.handle == 'renewal-cleanser' -%}
  {%- assign is_cleanser = true -%}
{%- endif -%}

<section class="study-results-section">
  <div class="sr-left">
    {%- assign has_custom_stats = false -%}
    {%- capture sr_stats -%}
      {%- if is_night_cream -%}
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">said their skin felt deeply hydrated and nourished</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">95%</h3><p class="sr-desc">said it absorbed well without heaviness</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">94%</h3><p class="sr-desc">noticed smoother, softer, and refined skin by morning</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">reported a visible reduction in fine lines and dark spots</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif is_face_wash -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN FELT CLEAN + REFRESHED AFTER EVERY WASH</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID IT DID NOT DRY OUT THEIR SKIN</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR SKIN LOOKED CLEARER + MORE BALANCED</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">said their hair felt smoother + more manageable</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">said it reduced frizz effectively</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">said their hair looked shinier + healthier</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">said they noticed less breakage</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'tranexamic-serum' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">said their skin looked more even</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">said their skin appeared brighter</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">said dark spots looked less visible</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">said they noticed improved skin clarity</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif is_serum -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN LOOKED BRIGHTER + MORE EVEN</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID DARK SPOTS APPEARED VISIBLY REDUCED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR SKIN FELT SMOOTHER + MORE REFINED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">SAID THEY NOTICED A HEALTHY, GLASS-LIKE GLOW</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif is_sunscreen -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN FELT PROTECTED + COMFORTABLE</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID IT BLENDS EASILY WITHOUT ANY WHITE CAST</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR SKIN FELT HYDRATED THROUGHOUT THE DAY</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">SAID THEY NOTICED A HEALTHY, PROTECTED GLOW</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'keratin-serum' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR HAIR FELT SMOOTHER + MORE MANAGEABLE</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID IT REDUCED FRIZZ EFFECTIVELY</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR HAIR LOOKED SHINIER + HEALTHIER</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif is_glutathione_cream -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN LOOKED MORE RADIANT</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID THEIR SKIN FELT MORE HYDRATED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR SKIN APPEARED MORE EVEN</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">SAID THEY NOTICED IMPROVED SKIN CLARITY</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR HAIR FELT FRESHER INSTANTLY</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID THE FRAGRANCE LASTED THROUGHOUT THE DAY</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR HAIR LOOKED MORE SHINY + REVIVED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">SAID THEY USED IT DAILY FOR QUICK REFRESH</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN FELT CLEANER + MORE BALANCED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID THEIR SKIN LOOKED CLEARER + MORE REFINED</p></div>
        {%- assign has_custom_stats = true -%}
      {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' or product.handle == 'hydra-burst-moisturizer' -%}
        <div class="sr-stat-block"><h3 class="sr-number">99%</h3><p class="sr-desc">SAID THEIR SKIN FELT MORE HYDRATED + REFRESHED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">98%</h3><p class="sr-desc">SAID IT ABSORBS QUICKLY WITHOUT ANY HEAVINESS</p></div>
        {%- assign has_custom_stats = true -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- if has_custom_stats -%}
      {{ sr_stats }}
    {%- elsif section.blocks.size > 0 -%}
      {% for block in section.blocks %}
        <div class="sr-stat-block" {{ block.shopify_attributes }}>
          <h3 class="sr-number">{{ block.settings.number }}</h3>
          <p class="sr-desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    {%- else -%}
        <div class="sr-stat-block"><h3 class="sr-number">97%</h3><p class="sr-desc">SAID THEIR SKIN FELT DEEPLY HYDRATED AND NOURISHED</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">95%</h3><p class="sr-desc">SAID IT ABSORBED WELL WITHOUT HEAVINESS</p></div>
        <div class="sr-stat-block"><h3 class="sr-number">3 out of 4</h3><p class="sr-desc">REPORTED A VISIBLE REDUCTION IN FINE LINES</p></div>
    {%- endif -%}
    
    <div class="sr-footnote">
      {%- if is_night_cream -%}
        Based on a 2-week consumer perception study with consistent nightly use.
      {%- elsif is_serum or is_sunscreen or is_cleanser or product.handle contains 'serum' or product.handle contains 'mist' or product.handle contains 'toner' or product.handle contains 'moisturizer' or product.handle contains 'cream' -%}
        Based on a 2-week consumer perception study with consistent daily use.
      {%- else -%}
        {{ section.settings.footnote | default: '*Based on a 32-subject consumer perception study after 2 weeks of use.' }}
      {%- endif -%}
    </div>
  </div>
  
  <div class="sr-right">
    {%- if is_night_cream -%}
      <img class="sr-image" src="{{ 'night-cream-ba.jpg' | asset_url }}" alt="Night Cream Result">
    {%- elsif is_face_wash -%}
      <img class="sr-image" src="{{ 'before-after-100-10.jpg' | asset_url }}" alt="Face Wash Result">
    {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
      <img class="sr-image" src="{{ 'keratin-ba.jpg' | asset_url }}" alt="Keratin Serum Result">
    {%- elsif product.handle == 'tranexamic-serum' -%}
      <img class="sr-image" src="{{ 'tranexamic-meet-3.jpg' | asset_url }}" alt="Tranexamic Serum Result">
    {%- elsif is_serum -%}
      {%- assign result_img = images['before-after.jpg'] -%}
      {%- if result_img != blank -%}
        <img class="sr-image" src="{{ result_img | img_url: '1200x' }}" alt="Centella Serum Results">
      {%- else -%}
        <img class="sr-image" src="{{ 'before-after.jpg' | asset_url }}" alt="Centella Serum Results">
      {%- endif -%}
    {%- elsif is_sunscreen -%}
      <img class="sr-image" src="{{ 'sunscreen-lifestyle-4.jpg' | asset_url }}" alt="Sunscreen Result">
    {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
       <img class="sr-image" src="{{ 'facewash-gallery-2.jpg' | asset_url }}" alt="Face Wash Result">
    {%- elsif is_cleanser -%}
       <img class="sr-image" src="{{ 'before-after-100-10.jpg' | asset_url }}" alt="Cleanser Result">
    {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
      <img class="sr-image" src="{{ 'toner-before-after.jpg' | asset_url }}" alt="Toner Results">
    {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' or product.handle == 'hydra-burst-moisturizer' -%}
      <img class="sr-image" src="{{ 'moisturizer-before-after.jpg' | asset_url }}" alt="Moisturizer Results">
    {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'keratin-serum' -%}
      <img class="sr-image" src="{{ 'keratin-ba.jpg' | asset_url }}" alt="Before After Comparison">
    {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
      <img class="sr-image" src="{{ 'hair-mist.jpg' | asset_url }}" alt="Hair Mist Results">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'sr-image', alt: 'Study Results Visual' }}
    {%- else -%}
      <img class="sr-image" src="https://images.unsplash.com/photo-1549439602-43ebca2327af?q=80&w=1000" alt="Cosmetic application close up">
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Consumer Study Results",
  "settings": [
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote Text",
      "default": "*Based on a 32-subject consumer perception study after 2 weeks of use."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    }
  ],
  "blocks": [
    {
      "type": "stat_block",
      "name": "Statistic",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number/Percentage",
          "default": "100%"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "SAID IT GAVE CHEEKS A NATURAL GLOW"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Consumer Study Results"
    }
  ]
}
{% endschema %}
