<section class="card social-section">
  <div class="social-header">
    <h2 class="logo-text" style="font-size: 2.5rem;">{{ section.settings.title }}</h2>
    <a href="{{ section.settings.link }}" class="btn-pill-outline">{{ section.settings.btn_text }}</a>
  </div>
  <div class="social-scroll">
    {% for block in section.blocks %}
      <div class="social-thumb" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 600 | image_tag: alt: 'Social' }}
        {% else %}
          <div style="background:#eee; height:300px;"></div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Rhode Social Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "elaris7 + you"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "FIND US ON SOCIAL"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rhode Social Gallery",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}


