<section class="card" style="padding: 100px 40px; text-align: center; background-color: {{ section.settings.bg_color }};">
  <h3 class="card-label mb-sm">{{ section.settings.eyebrow }}</h3>
  <h2 style="font-size: 3rem; font-weight: 800; letter-spacing: -0.04em; max-width: 800px; margin: 0 auto 30px;">"{{ section.settings.quote }}"</h2>
  <p style="font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #999;">— {{ section.settings.author }}</p>
</section>

{% schema %}
{
  "name": "Rhode Honors Block",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf9f6"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "REAL RESULTS"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "My acne cleared up in just two weeks. Finally a halal-conscious Korean skincare routine."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "AYESHA A."
    }
  ],
  "presets": [
    {
      "name": "Rhode Honors Block",
      "category": "Text"
    }
  ]
}
{% endschema %}
