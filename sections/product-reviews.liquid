<div class="product-reviews-wrapper">
  <div class="pr-header">
    <div class="pr-rating-info">
      <div class="pr-rating-score">4.7 <span class="pr-stars">★★★★★</span></div>
      <div class="pr-rating-label">AVERAGE RATING</div>
      <div class="pr-rating-count">Based on 6,947 reviews</div>
    </div>
    <div class="pr-actions">
      <button class="pr-btn-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        FILTERS
      </button>
      <button class="pr-btn-pill">MOST RECENT</button>
    </div>
  </div>

    <!-- Review 1: Fatima -->
    <div class="pr-item">
      <div class="pr-item-sidebar">
        <div class="pr-meta-group">
          <div class="pr-reviewer-name">Fatima</div>
          <div class="pr-verified">
            Verified Buyer 
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#333">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
        </div>
        <div class="pr-meta-group">
          <div class="pr-meta-title">Reviewing</div>
          <a href="#" class="pr-meta-link">Centella Night Cream</a>
        </div>
        <div class="pr-meta-group">
          <div class="pr-meta-title">Skin Type</div>
          <div class="pr-meta-value">Dry / Sensitive</div>
        </div>
      </div>
      <div class="pr-item-content">
        <div class="pr-item-top">
          <span class="pr-stars">★★★★★</span>
          <span class="pr-date">2 days ago</span>
        </div>
        <h3 class="pr-review-title">Stronger Skin Barrier</h3>
        <p class="pr-review-text">“I’ve been using it for 2 weeks, and my skin barrier feels so much stronger and healthier. My skin looks brighter, more even-toned, and I’m genuinely loving the glow. ”</p>
      </div>
    </div>

    <!-- Review 2: Ayesha -->
    <div class="pr-item">
      <div class="pr-item-sidebar">
        <div class="pr-meta-group">
          <div class="pr-reviewer-name">Ayesha</div>
          <div class="pr-verified">Verified Buyer</div>
        </div>
        <div class="pr-meta-group">
          <div class="pr-meta-title">Reviewing</div>
          <a href="#" class="pr-meta-link">Centella Night Cream</a>
        </div>
      </div>
      <div class="pr-item-content">
        <div class="pr-item-top">
          <span class="pr-stars">★★★★★</span>
          <span class="pr-date">1 week ago</span>
        </div>
        <h3 class="pr-review-title">Love the texture!</h3>
        <p class="pr-review-text">“I’m honestly in love with the texture — it’s lightweight, smooth, and absorbs instantly without any greasiness. My skin feels soft, hydrated, and has a natural glow every morning.”</p>
      </div>
    </div>

    <!-- Review 3: Fiza -->
    <div class="pr-item">
      <div class="pr-item-sidebar">
        <div class="pr-meta-group">
          <div class="pr-reviewer-name">Fiza</div>
          <div class="pr-verified">Verified Buyer</div>
        </div>
      </div>
      <div class="pr-item-content">
        <div class="pr-item-top">
          <span class="pr-stars">★★★★★</span>
          <span class="pr-date">2 weeks ago</span>
        </div>
        <h3 class="pr-review-title">10/10 Experience</h3>
        <p class="pr-review-text">“Received my order and I’m super impressed with both the product and packaging. Everything feels premium — definitely a 10/10 experience for me!”</p>
      </div>
    </div>

    <!-- Review 4: Razish -->
    <div class="pr-item">
      <div class="pr-item-sidebar">
        <div class="pr-reviewer-name">Razish</div>
        <div class="pr-verified">Verified Buyer</div>
      </div>
      <div class="pr-item-content">
        <div class="pr-item-top">
          <span class="pr-stars">★★★★★</span>
          <span class="pr-date">3 weeks ago</span>
        </div>
        <h3 class="pr-review-title">Visible improvement</h3>
        <p class="pr-review-text">“After consistent use, my skin feels deeply hydrated and looks much more refreshed. I’ve noticed a visible improvement in texture and overall glow.”</p>
      </div>
    </div>

    <!-- Review 5: Anonymous (Gentle) -->
    <div class="pr-item">
      <div class="pr-item-sidebar">
        <div class="pr-verified">Verified Buyer</div>
      </div>
      <div class="pr-item-content">
        <div class="pr-item-top">
          <span class="pr-stars">★★★★★</span>
          <span class="pr-date">1 month ago</span>
        </div>
        <h3 class="pr-review-title">Gentle yet effective</h3>
        <p class="pr-review-text">“The night cream feels very gentle yet effective — my skin looks brighter and healthier with regular use. Waking up to soft, smoother skin is the best!”</p>
      </div>
    </div>
  </div>
</div>

<style>
.product-reviews-wrapper {
  background-color: #f3f0ec;
  padding: 60px;
  margin: 0;
  color: #555;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.pr-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  margin-bottom: 40px;
}

.pr-rating-score {
  font-size: 1.1rem;
  font-weight: 700;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.pr-stars {
  color: #777;
  letter-spacing: 2px;
  font-size: 0.95rem;
}

.pr-rating-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: #555;
  margin-bottom: 2px;
}

.pr-rating-count {
  font-size: 0.8rem;
  color: #777;
}

.pr-actions {
  display: flex;
  gap: 12px;
}

.pr-btn-pill {
  background: transparent;
  border: 1px solid #d5d1c8;
  border-radius: 50px;
  padding: 8px 16px;
  font-size: 0.75rem;
  font-weight: 700;
  color: #555;
  cursor: pointer;
  display: flex;
  align-items: center;
  letter-spacing: 0.05em;
  transition: all 0.2s ease;
}

.pr-btn-pill:hover {
  background: #fff;
  border-color: #bbb;
}

.pr-list {
  display: flex;
  flex-direction: column;
}

.pr-item {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 40px;
  padding-bottom: 40px;
  margin-bottom: 40px;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.pr-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.pr-item-sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.pr-meta-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.pr-reviewer-name {
  font-size: 0.85rem;
  font-weight: 700;
  color: #333;
}

.pr-verified {
  font-size: 0.8rem;
  color: #555;
  display: flex;
  align-items: center;
  gap: 4px;
}

.pr-meta-title {
  font-size: 0.85rem;
  font-weight: 700;
  color: #555;
}

.pr-meta-value {
  font-size: 0.8rem;
  color: #777;
  line-height: 1.4;
}

.pr-meta-link {
  font-size: 0.8rem;
  color: #777;
  text-decoration: underline;
}

.pr-item-content {
  display: flex;
  flex-direction: column;
}

.pr-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.pr-date {
  font-size: 0.8rem;
  color: #888;
}

.pr-review-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #333;
  margin: 0 0 12px 0;
}

.pr-review-text {
  font-size: 0.9rem;
  color: #555;
  line-height: 1.6;
  margin: 0 0 32px 0;
}

.pr-attribute-slider {
  max-width: 450px;
  margin-bottom: 40px;
}

.pr-slider-label {
  font-size: 0.85rem;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
}

.pr-slider-track {
  height: 2px;
  background: #d5d1c8;
  position: relative;
  border-radius: 2px;
  margin-bottom: 12px;
}

.pr-slider-point {
  position: absolute;
  width: 1px;
  height: 10px;
  background: #a8a49c;
  top: -4px;
}

.point-1 { left: 0; }
.point-2 { left: 50%; }
.point-3 { left: 100%; right: 0; }

.pr-slider-value {
  position: absolute;
  width: 12px;
  height: 12px;
  background: #555;
  border-radius: 50%;
  top: -5px;
  transform: translateX(-50%);
}

.pr-slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.8rem;
  color: #888;
}

.pr-helpfulness {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  font-size: 0.8rem;
  color: #888;
  margin-top: auto;
}

.pr-vote {
  background: none;
  border: none;
  color: #888;
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  padding: 0;
}

@media (max-width: 800px) {
  .product-reviews-wrapper {
    padding: 40px 20px;
  }
  .pr-item {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .pr-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  .pr-actions {
    width: 100%;
    justify-content: space-between;
  }
  .pr-item-sidebar {
    order: 2;
    margin-top: 10px;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 24px;
  }
  .pr-item-content {
    order: 1;
  }
}
</style>

{% schema %}
{
  "name": "Product Reviews",
  "settings": [],
  "presets": [
    {
      "name": "Product Reviews",
      "category": "Product"
    }
  ]
}
{% endschema %}
