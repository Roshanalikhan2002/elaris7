<style>
.product-reviews-wrapper {
  background-color: #f3f0ec;
  padding: 60px;
  margin: 0;
  color: #555;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.pr-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  margin-bottom: 40px;
}

.pr-rating-score {
  font-size: 1.1rem;
  font-weight: 700;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.pr-stars {
  color: #777;
  letter-spacing: 2px;
  font-size: 0.95rem;
}

.pr-rating-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: #555;
  margin-bottom: 2px;
}

.pr-rating-count {
  font-size: 0.8rem;
  color: #777;
}

.pr-actions {
  display: flex;
  gap: 12px;
}

.pr-btn-pill {
  background: transparent;
  border: 1px solid #d5d1c8;
  border-radius: 50px;
  padding: 8px 16px;
  font-size: 0.75rem;
  font-weight: 700;
  color: #555;
  cursor: pointer;
  display: flex;
  align-items: center;
  letter-spacing: 0.05em;
  transition: all 0.2s ease;
}

.pr-btn-pill:hover {
  background: #fff;
  border-color: #bbb;
}

.pr-list {
  display: flex;
  flex-direction: column;
}

.pr-item {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 40px;
  padding-bottom: 40px;
  margin-bottom: 40px;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.pr-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.pr-item-sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.pr-meta-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.pr-reviewer-name {
  font-size: 0.85rem;
  font-weight: 700;
  color: #333;
}

.pr-verified {
  font-size: 0.8rem;
  color: #555;
  display: flex;
  align-items: center;
  gap: 4px;
}

.pr-meta-title {
  font-size: 0.85rem;
  font-weight: 700;
  color: #555;
}

.pr-meta-value {
  font-size: 0.8rem;
  color: #777;
  line-height: 1.4;
}

.pr-meta-link {
  font-size: 0.8rem;
  color: #777;
  text-decoration: underline;
}

.pr-item-content {
  display: flex;
  flex-direction: column;
}

.pr-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.pr-date {
  font-size: 0.8rem;
  color: #888;
}

.pr-review-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #333;
  margin: 0 0 12px 0;
}

.pr-review-text {
  font-size: 0.9rem;
  color: #555;
  line-height: 1.6;
  margin: 0 0 32px 0;
}

.pr-attribute-slider {
  max-width: 450px;
  margin-bottom: 40px;
}

.pr-slider-label {
  font-size: 0.85rem;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
}

.pr-slider-track {
  height: 2px;
  background: #d5d1c8;
  position: relative;
  border-radius: 2px;
  margin-bottom: 12px;
}

.pr-slider-point {
  position: absolute;
  width: 1px;
  height: 10px;
  background: #a8a49c;
  top: -4px;
}

.point-1 { left: 0; }
.point-2 { left: 50%; }
.point-3 { left: 100%; right: 0; }

.pr-slider-value {
  position: absolute;
  width: 12px;
  height: 12px;
  background: #555;
  border-radius: 50%;
  top: -5px;
  transform: translateX(-50%);
}

.pr-slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.8rem;
  color: #888;
}

.pr-helpfulness {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  font-size: 0.8rem;
  color: #888;
  margin-top: auto;
}

.pr-vote {
  background: none;
  border: none;
  color: #888;
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  padding: 0;
}

@media (max-width: 800px) {
  .product-reviews-wrapper {
    padding: 40px 20px;
  }
  .pr-item {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .pr-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  .pr-actions {
    width: 100%;
    justify-content: space-between;
  }
  .pr-item-sidebar {
    order: 2;
    margin-top: 10px;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 24px;
  }
  .pr-item-content {
    order: 1;
  }
}
</style>

{% schema %}
{
  "name": "Product Reviews",
  "settings": [],
  "presets": [
    {
      "name": "Product Reviews",
      "category": "Product"
    }
  ]
}
{% endschema %}
