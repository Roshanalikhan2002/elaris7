<section class="section routine-steps">
  <div class="container">
    <h2 class="text-center mb-4">{{ section.settings.heading }}</h2>
    <p class="text-center mb-8" style="color:var(--text-light)">{{ section.settings.subheading }}</p>
    <div class="routine-grid">
      {% for block in section.blocks %}
        <div class="routine-step" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Routine Steps",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Glass Skin Routine"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Follow our 4-step daily process"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Cleanse"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Use our Centella Face Wash to gently remove impurities."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Routine Steps",
      "category": "List"
    }
  ]
}
{% endschema %}
