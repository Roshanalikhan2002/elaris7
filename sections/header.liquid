.mega-product-info {
  padding: 20px;
  text-align: left;
}

.mega-product-name {
  font-size: 0.7rem;
  font-weight: 900;
  color: #333;
  margin: 0 0 5px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  line-height: 1.2;
}

.mega-product-desc {
  font-size: 0.6rem;
  color: #8c8b84;
  margin: 0;
  line-height: 1.4;
