        </li>
        <li><a href="/pages/about" class="nav-link">ABOUT</a></li>
        <li><a href="/pages/futures" class="nav-link">FUTURES</a></li>
      </ul>
    </nav>
    <div class="header-logo">
      <a href="{{ routes.root_url }}" class="logo-text">elaris7</a>
    </div>
    <nav class="header-nav header-right">
      <ul class="desktop-only site-nav">
        <li><a href="/search" class="nav-link search-trigger" id="search-open-desktop">SEARCH</a></li>
        <li><a href="/account" class="nav-link">ACCOUNT</a></li>
        <li><a href="/cart" class="nav-link cart-count">CART ({{ cart.item_count }})</a></li>
      </ul>
      <div class="mobile-only mobile-header-icons">
        <a href="/search" class="mobile-icon search-trigger" id="search-open-mobile">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
