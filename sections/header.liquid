  {%- assign mega_handles = "night-cream,tranexamic-serum-v2,keratin-serum-v2,glow-serum,glutathione-cream,hair-mist,face-wash,anti-acne,sunscreen-v2,renewal-cleanser,e7-korean-glass-skin-moisturizer,renewal-toner,elaris-7-korean-glass-skin-bundle,elaris-7-korean-brightening-bundle,anti-acne-serum,elaris-7-korean-hair-care-bundle" | split: "," -%}

  <div class="announcement-bar">
    {{ section.settings.announcement_text }}
