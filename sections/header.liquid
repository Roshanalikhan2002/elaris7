/* Mega Menu Footer */
.mega-menu-footer {
  display: flex;
  justify-content: center;
  margin-top: 50px;
}

.mega-shop-btn {
  background: #fff;
  border: 1px solid #d1d1cf;
  border-radius: 50px;
  padding: 12px 40px;
  font-size: 0.72rem;
  font-weight: 800;
  color: #5b5a53;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  transition: all 0.3s ease;
}

.mega-shop-btn:hover {
