</div>
<style>
/* ===== Search Overlay ===== */
.search-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100dvh;
  background: #f1efea;
  z-index: 4000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  justify-content: center;
  padding: 100px 40px;
}

.search-overlay.active {
  opacity: 1;
  visibility: visible;
}

.search-container {
  max-width: 900px;
  width: 100%;
}

.search-top {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 40px;
}

.search-close {
  background: none;
  border: none;
  font-size: 2.5rem;
  color: #5b5a53;
  cursor: pointer;
  line-height: 1;
  transition: opacity 0.3s ease;
}
.search-close:hover { opacity: 0.5; }

.search-form {
  width: 100%;
  position: relative;
}

.search-input {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(91, 90, 83, 0.4);
  font-size: 2rem;
  font-weight: 700;
  color: #333;
  padding: 12px 0;
  outline: none;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-family: 'Inter', sans-serif;
}

.search-input::placeholder {
  color: rgba(91, 90, 83, 0.2);
}

.search-suggestions {
  margin-top: 50px;
}

.suggestion-label {
  font-size: 0.62rem;
  font-weight: 800;
  color: #9a9990;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 24px;
}

.suggestion-items {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.suggestion-items a {
  background: #fff;
  border: 1px solid #d1d1cf;
  border-radius: 50px;
  padding: 8px 22px;
  font-size: 0.65rem;
  font-weight: 700;
  color: #5b5a53;
  text-decoration: none;
  text-transform: uppercase;
  transition: all 0.2s ease;
}

.suggestion-items a:hover {
  background: #5b5a53;
  color: #fff;
  border-color: #5b5a53;
}

@media (max-width: 768px) {
  .search-overlay { padding: 80px 20px; }
  .search-input { font-size: 1.4rem; padding: 10px 0; }
  .search-top { margin-bottom: 25px; }
}

/* ===== Hamburger & Mobile Trigger ===== */
.menu-trigger {
  display: none;
  cursor: pointer;
  z-index: 20;
}

.hamburger-box {
  width: 22px;
  height: 16px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.hamburger-box .line {
  display: block;
  width: 22px;
  height: 1.5px;
  background: #5b5a53;
  border-radius: 2px;
  transform-origin: center;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, width 0.3s ease;
}

/* Clockwise rotation into X */
.menu-trigger.is-open .hamburger-box {
  transform: rotate(180deg);
}

.menu-trigger.is-open .hamburger-box .line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.menu-trigger.is-open .hamburger-box .line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.menu-trigger.is-open .hamburger-box .line:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ===== Mobile Menu Drawer ===== */
.mobile-menu-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100dvh;
  background: #f1efea;
  z-index: 3000;
  transform: translateY(-100%);
  transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}

.mobile-menu-drawer.open {
  transform: translateY(0);
}

.menu-inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* Prevent inner scroll to make header sticky */
}

.menu-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 20px;
  border-bottom: 1px solid rgba(91,90,83,0.12);
  position: relative;
  background: #f1efea;
  z-index: 20;
}

.menu-scroll-area {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.menu-scroll-area::-webkit-scrollbar { display: none; }

.menu-close {
  font-size: 1.8rem;
  cursor: pointer;
  color: #5b5a53;
  line-height: 1;
  transition: transform 0.3s ease;
  width: 32px;
  height: 32px;
