  left: 50%;
  transform: translateX(-50%);
}

.menu-tabs-container {
  padding: 15px 0;
  background: #f1efea;
  border-bottom: 1px solid rgba(91,90,83,0.12);
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  display: block;
  z-index: 15;
  flex-shrink: 0;
}
.menu-tabs-container::-webkit-scrollbar { display: none; }

.menu-tabs {
  display: flex;
  flex-wrap: nowrap;
  gap: 12px;
  padding: 0 20px;
  white-space: nowrap;
}

.menu-tabs .tab {
  background: #fff;
  border: 1px solid #d1d1cf;
  border-radius: 50px;
  padding: 8px 18px;
  font-size: 0.62rem;
  font-weight: 800;
  color: #7A7973;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all 0.3s ease;
  flex-shrink: 0;
  text-decoration: none;
}

.menu-tabs .tab.active {
  background: #5b5a53 !important;
  color: #fff !important;
  border-color: #5b5a53 !important;
}

.menu-products {
  padding: 10px 16px 30px; /* Added bottom padding for better scroll end */
  display: flex;
  flex-direction: column;
  gap: 0;
}

.menu-product-row {
  display: flex !important;
  align-items: center;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(91,90,83,0.08);
