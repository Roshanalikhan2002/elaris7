<header class="site-header">
  <div class="announcement-bar">
    {{ section.settings.announcement_text }}
  </div>
  <div class="header-main">
    <nav class="header-nav header-left">
      <div class="menu-trigger" id="menu-open">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <ul class="desktop-only">
        <li><a href="/collections/all">SHOP</a></li>
        <li><a href="/pages/about">ABOUT</a></li>
        <li><a href="/pages/futures">FUTURES</a></li>
      </ul>
    </nav>
    <div class="header-logo">
      <a href="/" class="logo-text">{{ shop.name }}</a>
    </div>
    <nav class="header-nav header-right">
      <ul class="desktop-only">
        <li><a href="/search">SEARCH</a></li>
        <li><a href="/account">ACCOUNT</a></li>
        <li><a href="/cart">CART ({{ cart.item_count }})</a></li>
      </ul>
      <div class="mobile-only mobile-header-icons">
        <a href="/search" class="mobile-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </a>
        <a href="/cart" class="mobile-icon cart-icon-wrapper">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
(function() {
  var header = document.querySelector('.site-header');
  if (!header) return;

  var lastScrollY = window.scrollY;
  var hideTimer = null;
  var isHidden = false;
  var threshold = 5; // buffer to prevent jitter

  function showHeader() {
    if (hideTimer) {
      clearTimeout(hideTimer);
      hideTimer = null;
    }
    if (isHidden) {
      header.classList.remove('header-hidden');
      header.classList.add('header-visible');
      isHidden = false;
    }
  }

  function scheduleHide() {
    if (hideTimer) clearTimeout(hideTimer);
    hideTimer = setTimeout(function() {
      if (!isHidden && window.scrollY > 100) { // Only hide if we're not at the very top
        header.classList.remove('header-visible');
        header.classList.add('header-hidden');
        isHidden = true;
      }
    }, 2000); // 2 second delay
  }

  window.addEventListener('scroll', function() {
    var currentScrollY = window.scrollY;
    
    // Ignore tiny scrolls
    if (Math.abs(currentScrollY - lastScrollY) < threshold) return;

    if (currentScrollY <= 20) {
      // Force show at top
      showHeader();
    } else if (currentScrollY > lastScrollY) {
      // Scrolling DOWN
      scheduleHide();
    } else {
      // Scrolling UP
      showHeader();
    }

    lastScrollY = currentScrollY;
  }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "free shipping on all orders over rs. 2000"
    }
  ]
}
{% endschema %}
