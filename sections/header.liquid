  <div class="header-main">
    <nav class="header-nav header-left">
      <div class="menu-trigger" id="menu-toggle">
        <div class="hamburger-box">
          <span class="line"></span>
          <span class="line"></span>
          <span class="line"></span>
        </div>
      </div>
      <ul class="desktop-only site-nav">
        <li class="nav-item-shop">
          <a href="/collections/all" class="nav-link">SHOP</a>
          <div class="mega-menu-container">
            <div class="mega-menu-categories">
              <div class="mega-cat-list">
                <a href="/collections/all" class="mega-cat-item active">FEATURED</a>
                <a href="/collections/korean-glass-skin" class="mega-cat-item">KOREAN GLASS SKIN</a>
                <a href="/collections/anti-acne" class="mega-cat-item">ANTI ACNE</a>
                <a href="/collections/korean-brightening" class="mega-cat-item">KOREAN BRIGHTENING</a>
                <a href="/collections/hair-care" class="mega-cat-item">HAIR CARE</a>
                <a href="/collections/sets" class="mega-cat-item">SETS</a>
              </div>
            </div>
            
            <div class="mega-menu-products">
              <div class="mega-products-grid">
                {% for i in (0..15) %}
                  {%- assign mname = mega_names[i] -%}
                  {%- assign mimage = mega_images[i] -%}
                  {%- assign mdesc = mega_descs[i] -%}
                  {%- assign mhandle = mega_handles[i] -%}
                  
                  <a href="/products/{{ mhandle }}" class="mega-product-card">
                    <div class="mega-product-image">
