<style>
/* ===== Hamburger & Mobile Trigger ===== */
.menu-trigger {
  display: none;
  cursor: pointer;
  z-index: 20;
}

.hamburger-box {
  width: 22px;
  height: 16px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.hamburger-box .line {
  display: block;
  width: 22px;
  height: 1.5px;
  background: #5b5a53;
  border-radius: 2px;
  transform-origin: center;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, width 0.3s ease;
}

/* Clockwise rotation into X */
.menu-trigger.is-open .hamburger-box {
  transform: rotate(180deg);
}

.menu-trigger.is-open .hamburger-box .line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.menu-trigger.is-open .hamburger-box .line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.menu-trigger.is-open .hamburger-box .line:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ===== Mobile Menu Drawer ===== */
.mobile-menu-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100dvh;
  background: #f1efea;
  z-index: 3000;
  transform: translateY(-100%);
  transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}

.mobile-menu-drawer.open {
  transform: translateY(0);
}

.menu-inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  scrollbar-width: none;
}
.menu-inner::-webkit-scrollbar { display: none; }

.menu-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 20px;
  border-bottom: 1px solid rgba(91,90,83,0.12);
  position: relative;
}

.menu-close {
  font-size: 1.8rem;
  cursor: pointer;
  color: #5b5a53;
  line-height: 1;
  transition: transform 0.3s ease;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.menu-close:hover { transform: rotate(90deg); }

.menu-logo-small {
  font-family: 'Inter', sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  letter-spacing: -0.05em;
  color: #5b5a53;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.menu-tabs-container {
  padding: 18px 0;
  border-bottom: 1px solid rgba(91,90,83,0.12);
  overflow-x: auto;
  scrollbar-width: none;
}
.menu-tabs-container::-webkit-scrollbar { display: none; }

.menu-tabs {
  display: flex;
  gap: 28px;
  padding: 0 20px;
  white-space: nowrap;
}

.menu-tabs .tab {
  font-size: 0.68rem;
  font-weight: 800;
  color: #9a9990;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
  padding-bottom: 4px;
  border-bottom: 2px solid transparent;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.menu-tabs .tab.active {
  color: #5b5a53;
  border-bottom-color: #5b5a53;
}

.menu-products {
  padding: 10px 16px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.menu-product-row {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(91,90,83,0.08);
