}

.menu-shop-btn-wrap {
  padding: 24px 16px;
  border-bottom: 1px solid rgba(91,90,83,0.12);
}

.menu-shop-btn-wrap .mega-shop-btn {
  display: block;
  text-align: center;
  padding: 12px;
  border: 1px solid #5b5a53;
  border-radius: 50px;
  font-size: 0.7rem;
  font-weight: 800;
  color: #5b5a53;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
  transition: all 0.3s ease;
}

.menu-shop-btn-wrap .mega-shop-btn:hover {
  background: #5b5a53;
  color: #fff;
}

.menu-secondary {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  border-top: none;
}

.menu-secondary a {
  font-size: 0.78rem;
  font-weight: 800;
  color: #5b5a53;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  text-decoration: none;
  transition: opacity 0.2s ease;
}
.menu-secondary a:hover { opacity: 0.6; }

.menu-footer {
  padding: 20px;
  background: rgba(91,90,83,0.04);
  margin-top: auto;
}

.region-selector {
  font-size: 0.7rem;
  font-weight: 600;
  color: #8c8b84;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.region-selector span { font-weight: 800; color: #5b5a53; }

/* Body lock when menu is open */
body.menu-open { overflow: hidden; }

