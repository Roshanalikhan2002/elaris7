}

.menu-product-row:active { background: rgba(91,90,83,0.04); }

.mini-thumb {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  background: #fff;
  border-radius: 8px;
  display: flex;
  align-items: center;
