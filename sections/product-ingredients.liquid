{%- style -%}
  .ingredients-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 16px 60px 16px;
    min-height: 600px;
  }
  
  .ing-left {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
  }
  .ing-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ing-full-btn {
    position: absolute;
    top: 24px;
    right: 24px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.8);
    color: white;
    padding: 10px 24px;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.3s, color 0.3s;
  }

  .ing-right {
    background-color: #f3f0ec;
    border-radius: 14px;
    position: relative;
    padding: 80px 80px 80px 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ing-vertical-title {
    position: absolute;
    top: 60px;
    left: 80px;
    transform: rotate(90deg);
    transform-origin: 0 0;
    font-size: 1.8rem;
    font-weight: 900;
    color: #a09d94;
    letter-spacing: -0.02em;
  }
  
  .ing-content {
    color: #6a6863;
    max-width: 500px;
  }
  .ing-intro {
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 40px;
  }
  
  .hero-ingredient {
    margin-bottom: 40px;
  }
  .hero-title {
    font-size: 1.4rem;
    font-weight: 900;
    color: #8c8a82;
    margin: 0 0 12px 0;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .ing-footer {
    font-size: 0.75rem;
    line-height: 1.6;
    margin-top: 50px;
    font-weight: 700;
    color: #7a7873;
  }

  @media (max-width: 900px) {
    .ingredients-section {
      grid-template-columns: 1fr;
      margin: 0;
      gap: 0;
    }
    .ing-vertical-title {
      position: static;
      transform: none;
      margin-bottom: 30px;
    }
    .ing-right { padding: 40px 24px; border-radius: 0; }
    .ing-left { min-height: 400px; border-radius: 0; }
  }
{%- endstyle -%}

{%- assign title_color = '#003087' -%}
{%- if product.handle == 'renewal-cleanser' or product.handle == 'centella-skin-toner-copy' or product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
  {%- assign title_color = '#333333' -%}
{%- endif -%}

{%- assign display_title = product.title -%}

{%- assign handle_down = product.handle | downcase -%}
{%- assign title_up = product.title | upcase -%}
{%- assign is_centella_serum = false -%}
{%- assign is_glutathione_cream = false -%}
{%- if handle_down == 'centella-serum' or handle_down == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or title_up contains 'CENTELLA SERUM' or title_up contains 'GLOW SERUM' -%}
  {%- assign is_centella_serum = true -%}
{%- elsif handle_down == 'glutathione-cream' or title_up contains 'GLUTATHIONE' -%}
  {%- assign is_glutathione_cream = true -%}
{%- endif -%}

<section class="ingredients-section" id="section-{{ section.id }}">
  <div class="ing-left">
    {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
      <img class="ing-image" src="{{ 'night-cream-last.jpeg' | asset_url }}" alt="Night Cream Ingredients">
    {%- elsif product.handle == 'tranexamic-serum' -%}
      <img class="ing-image" src="{{ 'tranexamic-serum.jpg' | asset_url }}" alt="Tranexamic Serum Ingredients">
    {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
      <img class="ing-image" src="{{ 'keratin-serum.jpg' | asset_url }}" alt="Keratin Serum Ingredients">
    {%- elsif is_centella_serum -%}
      <img class="ing-image" src="{{ 'glow-meet-1.jpg' | asset_url }}" alt="Centella Serum Ingredients">
    {%- elsif is_glutathione_cream -%}
      <img class="ing-image" src="{{ 'glutathione-cream-100.jpg' | asset_url }}" alt="Glutathione Cream Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
      <img class="ing-image" src="{{ 'facewash-ingredients-v2.jpg' | asset_url }}" alt="Face Wash Ingredients">
    {%- elsif product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
      <img class="ing-image" src="{{ 'cleanser-meet-1.jpg' | asset_url }}" alt="Renewal Cleanser Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' or product.handle == 'hydra-burst-moisturizer' -%}
      <img class="ing-image" src="{{ 'moisturizer-whats-inside.jpg' | asset_url }}" alt="Moisturizer Ingredients">
    {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
      <img class="ing-image" src="{{ 'hair-mist.jpg' | asset_url }}" alt="Hair Mist Ingredients">
    {%- elsif product.handle == 'sunscreen' -%}
      <img class="ing-image" src="{{ 'sunscreen-100.jpg' | asset_url }}" alt="Sunscreen Ingredients">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'ing-image', alt: 'Ingredients visual' }}
    {%- else -%}
      <img class="ing-image" src="https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=1000" alt="Abstract Texture">
    {%- endif -%}
    
    {% if section.settings.show_btn %}
      <button class="ing-full-btn">{{ section.settings.btn_label }}</button>
    {% endif %}
  </div>

  <div class="ing-right">
    <div class="ing-vertical-title">{{ section.settings.title }}</div>
    <div class="ing-content">
      <div class="ing-intro">
        {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          Our formula is powered by advanced repair and brightening actives. Meet 2 of our favorites for overnight renewal.
        {%- elsif product.handle == 'tranexamic-serum' -%}
          A potent brightening serum formulated to target dark spots, even skin tone, and enhance natural radiance.
        {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
          A lightweight, smoothing hair serum that tames frizz, protects strands, and enhances shine without weighing hair down.
        {%- elsif is_centella_serum -%}
          A powerful blend of tone-correcting actives and skin-repairing hydrators designed to target dullness, uneven tone, and texture. Here are 2 key ingredients behind the glow transformation:
        {%- elsif is_glutathione_cream -%}
          A nourishing cream that brightens, repairs, and hydrates skin for a clearer, more even complexion.
        {%- elsif product.handle == 'sunscreen' -%}
          A high-protection formula that hydrates skin while defending against harmful UV rays and environmental stress.
        {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
          A clarifying toner that smooths and rebalances the skin. Meet 2 standout ingredients:
        {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
          {%- assign display_intro = "A weightless mist that refreshes your hair instantly with a delicate scent and nourishing finish." -%}
          {{ display_intro }}
        {%- else -%}
          {{ section.settings.intro | default: "Our formula is powered by gentle cleansers and glow-boosting hydrators." }}
        {%- endif -%}
      </div>
      
      <div class="ing-dynamic-blocks">
        {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">a calming botanical that helps repair the skin barrier, reduce redness, and support healthier, more resilient skin overnight</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">MOISTURE-LOCK TECHNOLOGY</h3><p class="hero-desc">a deep hydration system that helps retain moisture, prevent overnight dryness, and keep skin plump and smooth by morning</p></div>
        {%- elsif product.handle == 'tranexamic-serum' -%}
          <div class="hero-ingredient"><h3 class="hero-title">TRANEXAMIC ACID (4%)</h3><p class="hero-desc">helps visibly reduce dark spots and discoloration</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">NIACINAMIDE (10%)</h3><p class="hero-desc">supports even tone and improves dullness</p></div>
        {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
          <div class="hero-ingredient"><h3 class="hero-title">ARGAN OIL</h3><p class="hero-desc">nourishes and softens hair while reducing breakage</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">KERATIN COMPLEX</h3><p class="hero-desc">strengthens hair fibers for smoother, frizz-free strands</p></div>
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">calms and repairs the skin barrier during cleansing</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">RICE EXTRACT</h3><p class="hero-desc">natural brightener for a clear, radiant after-wash glow</p></div>
        {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">soothes and clarifies skin texture</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">HYDRATION COMPLEXES</h3><p class="hero-desc">locks in moisture for a glass-like finish</p></div>
        {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
          <div class="hero-ingredient"><h3 class="hero-title">PANTHENOL</h3><p class="hero-desc">hydrates and adds a healthy shine</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">FLORAL EXTRACTS</h3><p class="hero-desc">provide a delicate, long-lasting scent</p></div>
        {%- elsif is_centella_serum -%}
          <div class="hero-ingredient"><h3 class="hero-title">NIACINAMIDE</h3><p class="hero-desc">a multitasking ingredient that helps visibly even out skin tone, reduce the look of pores, and strengthen the skin barrier for a smoother, clearer complexion</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">ALPHA ARBUTIN</h3><p class="hero-desc">a targeted brightening active known to help fade dark spots, post-acne marks, and discoloration for a more uniform, radiant look over time</p></div>
        {%- elsif is_glutathione_cream -%}
          <div class="hero-ingredient"><h3 class="hero-title">GLUTATHIONE</h3><p class="hero-desc">a powerful antioxidant known for its brightening properties, helping to reduce the look of dark spots and promote an even, glowing skin tone</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">VITAMIN E</h3><p class="hero-desc">deeply nourishes and protects the skin while supporting repair for a smoother, healthier complexion</p></div>
        {%- endif -%}
      </div>

      <div class="ing-footer">
        {%- if product.handle == 'night-cream' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          also made with BRIGHTENING COMPLEX, COLLAGEN SUPPORT BLEND, SPOT-CORRECTIVE ACTIVES, LINE-REDUCING COMPLEX, BARRIER REPAIR ACTIVES, EVEN-TONE ENHANCERS
        {%- elsif product.handle == 'tranexamic-serum' -%}
          also made with Vitamin C, Alpha Arbutin, Hyaluronic Acid, Glycerin, Panthenol, Vitamin E, peptides, and botanical extracts for hydration, barrier support, and glowing skin
        {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
          also made with Wheat Germ Oil, Almond Oil, Olive Oil, Grapeseed Oil, Coconut Oil, Flaxseed Oil, Safflower Oil, Shea Butter, Squalene, Niacinamide
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          also made with RICE EXTRACT, LICORICE EXTRACT, VITAMIN C, HONEY, D-PANTHENOL, GLYCERIN, APPLE EXTRACT, CENTELLA ASIATICA
        {%- elsif is_centella_serum -%}
          also made with VITAMIN C, HYALURONIC ACID, ALOE VERA, ROSE EXTRACT, VITAMIN E, HONEY, PEPTIDES, CENTELLA ASIATICA, VITAMIN B5, WITCH HAZEL
        {%- elsif is_glutathione_cream -%}
          also made with Centella Asiatica, Niacinamide, Vitamin C, Hyaluronic Acid, Glycerin, Vitamin E, and Amla Extract for hydration, skin barrier support, and smooth texture
        {%- else -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Ingredients",
  "settings": [
    { "type": "text", "id": "title", "label": "Vertical Title", "default": "what's inside" },
    { "type": "textarea", "id": "intro", "label": "Intro Text" },
    { "type": "textarea", "id": "footer_text", "label": "Footer Text" },
    { "type": "image_picker", "id": "image", "label": "Side Image" },
    { "type": "checkbox", "id": "show_btn", "label": "Show Button", "default": true },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "FULL INGREDIENTS LIST" }
  ],
  "presets": [{ "name": "Product Ingredients" }]
}
{% endschema %}
