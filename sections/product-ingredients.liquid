{%- style -%}
  .ingredients-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 16px 60px 16px;
    min-height: 600px;
  }
  
  .ing-left {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
  }
  .ing-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ing-full-btn {
    position: absolute;
    top: 24px;
    right: 24px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.8);
    color: white;
    padding: 10px 24px;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.3s, color 0.3s;
  }

  .ing-right {
    background-color: #f3f0ec;
    border-radius: 14px;
    position: relative;
    padding: 80px 80px 80px 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ing-vertical-title {
    position: absolute;
    top: 60px;
    left: 80px;
    transform: rotate(90deg);
    transform-origin: 0 0;
    font-size: 1.8rem;
    font-weight: 900;
    color: #a09d94;
    letter-spacing: -0.02em;
  }
  
  .ing-content {
    color: #6a6863;
    max-width: 500px;
  }
  .ing-intro {
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 40px;
  }
  
  .hero-ingredient {
    margin-bottom: 40px;
  }
  .hero-title {
    font-size: 1.4rem;
    font-weight: 900;
    color: #8c8a82;
    margin: 0 0 12px 0;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .ing-footer {
    font-size: 0.75rem;
    line-height: 1.6;
    margin-top: 50px;
    font-weight: 700;
    color: #7a7873;
  }

  @media (max-width: 900px) {
    .ingredients-section {
      grid-template-columns: 1fr;
      margin: 0;
      gap: 0;
    }
    .ing-vertical-title {
      position: static;
      transform: none;
      margin-bottom: 30px;
    }
    .ing-right { padding: 40px 24px; border-radius: 0; }
    .ing-left { min-height: 400px; border-radius: 0; }
  }
{%- endstyle -%}

<section class="ingredients-section">
  <div class="ing-left">
    {%- if product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
      <img class="ing-image" src="{{ 'toner-whats-inside.jpg' | asset_url }}" alt="Toner Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' or product.handle == 'hydra-burst-moisturizer' -%}
      <img class="ing-image" src="{{ 'moisturizer-whats-inside.jpg' | asset_url }}" alt="Moisturizer Ingredients">
    {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
      <img class="ing-image" src="{{ 'hair-mist.jpg' | asset_url }}" alt="Hair Mist Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
      <img class="ing-image" src="{{ 'facewash-ingredients.jpg' | asset_url }}" alt="Face Wash Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy-sunscreen' or product.handle == 'sunscreen' -%}
      <img class="ing-image" src="{{ 'sunscreen-100.jpg' | asset_url }}" alt="Sunscreen Ingredients">
    {%- elsif product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or product.handle == 'centella-serum' -%}
      <img class="ing-image" src="{{ 'centella-serum-ingredients.jpg' | asset_url }}" alt="Serum Ingredients">
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'ing-image', alt: 'Ingredients visual' }}
    {%- else -%}
      <img class="ing-image" src="https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=1000" alt="Abstract Texture">
    {%- endif -%}
    
    {% if section.settings.show_btn %}
      <button class="ing-full-btn">{{ section.settings.btn_label }}</button>
    {% endif %}
  </div>

  <div class="ing-right">
    <div class="ing-vertical-title">{{ section.settings.title }}</div>
    <div class="ing-content">
      <div class="ing-intro">
        {%- if product.handle == 'glutathione-cream' -%}
          A nourishing cream that brightens, repairs, and hydrates skin for a clearer, more even complexion.
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          A gentle daily face wash that cleanses while repairing the skin barrier and revealing a radiant glow.
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
          A gentle foam cleanser powered by Centella Asiatica and Hyaluronic Acid. Purifies pores, balances pH, and leaves skin fresh and radiant.
        {%- elsif product.handle == 'sunscreen' -%}
          A high-protection formula that hydrates skin while defending against harmful UV rays and environmental stress.
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or product.handle == 'centella-serum' -%}
          A concentrated serum designed to brighten dark spots, even skin tone, and restore a youthful, glass-like glow.
        {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
          A clarifying toner that smooths and rebalances the skin. Meet 2 standout ingredients:
        {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
          {%- assign display_intro = "A weightless mist that refreshes your hair instantly with a delicate scent and nourishing finish." -%}
          {{ display_intro }}
        {%- else -%}
          {{ section.settings.intro }}
        {%- endif -%}
      </div>
      
      <div class="ing-dynamic-blocks">
        {%- if product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">calms and repairs the skin barrier</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">HONEY EXTRACT</h3><p class="hero-desc">moisturizes and provides natural brightness</p></div>
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">soothes, repairs, and calms irritated skin</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">HYALURONIC ACID</h3><p class="hero-desc">deeply hydrates and keeps skin plump after cleansing</p></div>
        {%- elsif product.handle == 'sunscreen' -%}
          <div class="hero-ingredient"><h3 class="hero-title">SPF 60 PA+++</h3><p class="hero-desc">maximum defense against aging sun rays</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">soothes and hydrates sensitive skin</p></div>
        {%- elsif product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or product.handle == 'centella-serum' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">concentrated repair for glass-smooth skin</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">NIACINAMIDE</h3><p class="hero-desc">brightens dark spots and evens texture</p></div>
        {%- elsif product.handle == 'centella-skin-toner' or product.handle == 'renewal-toner' -%}
          <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">soothes and clarifies skin texture</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">HYDRATION COMPLEXES</h3><p class="hero-desc">locks in moisture for a glass-like finish</p></div>
        {%- elsif product.handle == 'floral-blossom-hair-mist' or product.handle == 'hair-mist' -%}
          <div class="hero-ingredient"><h3 class="hero-title">PANTHENOL</h3><p class="hero-desc">hydrates and adds a healthy shine</p></div>
          <div class="hero-ingredient"><h3 class="hero-title">FLORAL EXTRACTS</h3><p class="hero-desc">provide a delicate, long-lasting scent</p></div>
        {%- else -%}
          <!-- Default ingredients if no handle match -->
           <div class="hero-ingredient"><h3 class="hero-title">CENTELLA ASIATICA</h3><p class="hero-desc">repairs and calms skin</p></div>
        {%- endif -%}
      </div>

      <div class="ing-footer">{{ section.settings.footer_text }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Ingredients",
  "settings": [
    { "type": "text", "id": "title", "label": "Vertical Title", "default": "what's inside" },
    { "type": "textarea", "id": "intro", "label": "Intro Text" },
    { "type": "textarea", "id": "footer_text", "label": "Footer Text" },
    { "type": "image_picker", "id": "image", "label": "Side Image" },
    { "type": "checkbox", "id": "show_btn", "label": "Show Button", "default": true },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "FULL INGREDIENTS LIST" }
  ],
  "presets": [{ "name": "Product Ingredients" }]
}
{% endschema %}
