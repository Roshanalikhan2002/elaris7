<div class="section-grid">
  <div class="card showcase-image" style="position: relative !important; height: 100% !important; background: none !important;">
    {% if section.settings.model_image != blank %}
      {{ section.settings.model_image | image_url: width: 2000 | image_tag: class: 'full-img', alt: 'Model', style: 'position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important;' }}
    {% else %}
      <img src="{{ 'new-bundle-banner.jpg' | asset_url }}" alt="New Bundle Banner" class="full-img" style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important;">
    {% endif %}
  </div>
  <div class="card showcase-image" style="position: relative !important; height: 100% !important; background: none !important;">
     {% if section.settings.smear_image != blank %}
        {{ section.settings.smear_image | image_url: width: 2000 | image_tag: class: 'full-img', alt: 'Product Shot', style: 'position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important;' }}
      {% else %}
        <img src="https://images.unsplash.com/photo-1629198688000-71f23e745b6e?q=80&w=1200" alt="Product Swirl" class="full-img" style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important;">
      {% endif %}
      <div class="page-count">{{ section.settings.count }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Rhode Split Showcase",
  "settings": [
    {
      "type": "image_picker",
      "id": "model_image",
      "label": "Model Image (Left)"
    },
    {
      "type": "image_picker",
      "id": "smear_image",
      "label": "Smear Image (Right)"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating Text",
      "default": "★ ★ ★ ★ ★ (6,944)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Product Title",
      "default": "COMPLETE ELARIS BUNDLE"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The ultimate glow routine collection"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "RS. 6,500"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "BUY NOW"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "count",
      "label": "Page Count",
      "default": "1/4"
    }
  ],
  "presets": [
    {
      "name": "Rhode Split Showcase",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
