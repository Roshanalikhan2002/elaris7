<div class="section-grid">
  <div style="position: relative; height: 100%; width: 100%; border-radius: 12px; overflow: hidden;">
    {% if section.settings.model_image != blank %}
      {{ section.settings.model_image | image_url: width: 2000 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover; display: block;', alt: 'Model' }}
    {% else %}
      <img src="{{ 'new-bundle-banner.jpg' | asset_url }}" style="width: 100%; height: 100%; object-fit: cover; display: block;" alt="Banner">
    {% endif %}
  </div>
  <div style="position: relative; height: 100%; width: 100%; border-radius: 12px; overflow: hidden;">
     {% if section.settings.smear_image != blank %}
        {{ section.settings.smear_image | image_url: width: 2000 | image_tag: style: 'width: 100%; height: 100%; object-fit: cover; display: block;', alt: 'Product Shot' }}
      {% else %}
        <img src="https://images.unsplash.com/photo-1629198688000-71f23e745b6e?q=80&w=1200" style="width: 100%; height: 100%; object-fit: cover; display: block;" alt="Product">
      {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Rhode Split Showcase",
  "settings": [
    {
      "type": "image_picker",
      "id": "model_image",
      "label": "Model Image (Left)"
    },
    {
      "type": "image_picker",
      "id": "smear_image",
      "label": "Smear Image (Right)"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating Text",
      "default": "★ ★ ★ ★ ★ (6,944)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Product Title",
      "default": "COMPLETE ELARIS BUNDLE"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The ultimate glow routine collection"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "RS. 6,500"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "BUY NOW"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "count",
      "label": "Page Count",
      "default": "1/4"
    }
  ],
  "presets": [
    {
      "name": "Rhode Split Showcase",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
