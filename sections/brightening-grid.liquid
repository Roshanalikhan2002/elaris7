<div class="collection-page">
  <div class="collection-main">
    <div class="collection-grid-rhode">
      {%- assign b_products = "tranexamic-serum,glutathione-cream,renewal-cleanser,renewal-toner" | split: "," -%}
      {% for handle in b_products %}
        {%- assign product = all_products[handle] -%}
        {% if product != blank %}
          <div class="card card-rhode" onclick="window.location.href='{{ product.url }}'">
            <div class="card-image-wrapper">
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="card-img" alt="{{ product.title }}">
              {% if product.images[1] != blank %}
                <img src="{{ product.images[1] | image_url: width: 600 }}" class="card-img-hover" alt="{{ product.title }}">
              {% endif %}
            </div>
            <div class="card-info">
              <div class="card-meta">
                <span class="card-tag">{{ product.type | upcase }}</span>
                <span class="card-rating">★ 5.0 (16K)</span>
              </div>
              <h3 class="card-name">{{ product.title | upcase }}</h3>
              <p class="card-price">RS. {{ product.price | money_without_currency }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
.collection-grid-rhode {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  padding: 30px 40px;
  max-width: 1200px;
  margin: 0 auto;
}
@media (max-width: 768px) {
  .collection-grid-rhode {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    padding: 15px;
  }
}

/* Reusing existing card styles from main theme */
.card-rhode {
  cursor: pointer;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
}
.card-image-wrapper {
  position: relative;
  aspect-ratio: 1/1.3;
  overflow: hidden;
  background: #fff;
  padding: 20px;
}
.card-img, .card-img-hover {
  width: 100%;
  height: 100%;
  object-fit: contain;
  mix-blend-mode: multiply;
  transition: transform 0.5s ease, opacity 0.4s ease;
}
.card-img-hover {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  padding: 20px;
}
.card-rhode:hover .card-img { opacity: 0; transform: scale(1.05); }
.card-rhode:hover .card-img-hover { opacity: 1; transform: scale(1.05); }

.card-info { padding: 15px; text-align: left; }
.card-name { font-size: 0.75rem; font-weight: 900; color: #333; margin-bottom: 5px; letter-spacing: 0.05em; }
.card-price { font-size: 0.8rem; font-weight: 800; color: #333; }
.card-tag { font-size: 0.6rem; color: #8c8b84; font-weight: 700; margin-right: 8px; }
</style>

{% schema %}
{
  "name": "Brightening Grid",
  "settings": []
}
{% endschema %}
