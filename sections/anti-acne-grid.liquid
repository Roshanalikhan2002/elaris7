<div class="collection-page">
  <div class="collection-main">
    <div class="collection-grid-rhode single-card">
      {%- assign product = all_products['anti-acne'] -%}
      {% if product != blank %}
        <div class="card card-rhode" onclick="window.location.href='{{ product.url }}'">
          <div class="card-image-wrapper">
            <img src="{{ product.featured_image | image_url: width: 600 }}" class="card-img" alt="{{ product.title }}">
            <img src="{{ 'hover-anti-acne.png' | asset_url }}" class="card-img-hover" alt="{{ product.title }}">
          </div>
          <div class="card-info">
            <h3 class="card-name">{{ product.title | upcase }}</h3>
            <div class="card-buy-btn">
              BUY - RS. {{ product.price | money_without_currency }}
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
.collection-grid-rhode.single-card {
  display: grid;
  grid-template-columns: 350px;
  justify-content: center;
  padding: 60px 20px;
  max-width: 1200px;
  margin: 0 auto;
}
@media (max-width: 768px) {
  .collection-grid-rhode.single-card {
    grid-template-columns: 1fr;
    padding: 30px 20px;
  }
}

.card-rhode {
  cursor: pointer;
  background: #f4f4f2;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}
.card-image-wrapper {
  position: relative;
  aspect-ratio: 1/1.4;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px;
  background: #f4f4f2;
}
.card-img {
  width: 90%;
  height: 90%;
  object-fit: contain;
  mix-blend-mode: multiply;
  transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  display: block;
}
.card-img-hover {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 90%;
  height: 90%;
  object-fit: contain;
  mix-blend-mode: multiply;
  transform: translate(-50%, -50%) scale(1);
  opacity: 0;
  transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  pointer-events: none;
}
.card-rhode:hover .card-img {
  opacity: 0;
  transform: scale(1.08);
}
.card-rhode:hover .card-img-hover {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1.08);
}

.card-info { 
  padding: 15px 10px 20px; 
  text-align: center;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.card-name { 
  font-size: 0.65rem; 
  font-weight: 800; 
  color: #333; 
  margin-bottom: 12px; 
  letter-spacing: 0.05em;
  line-height: 1.4;
}
.card-buy-btn {
  border: 1px solid #333;
  border-radius: 50px;
  padding: 8px 15px;
  font-size: 0.65rem;
  font-weight: 800;
  color: #333;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: all 0.3s ease;
}
.card-rhode:hover .card-buy-btn {
  background: #333;
  color: #fff;
}
</style>

{% schema %}
{
  "name": "Anti Acne Grid",
  "settings": []
}
{% endschema %}
