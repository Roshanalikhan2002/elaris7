<div class="split-category-wrapper">
  <div class="split-cat-grid">
    <!-- Left: Lifestyle Image -->
    <div class="split-cat-left">
      {%- if section.settings.image_left != blank -%}
        {{ section.settings.image_left | image_url: width: 1200 | image_tag: class: 'split-cat-img', loading: 'lazy' }}
      {%- else -%}
        <div class="placeholder-bg" style="background:#f2f0ed; height:100%;">Lifestyle Image</div>
      {%- endif -%}
    </div>

    <!-- Right: Product Detail with 1/4 layout -->
    <div class="split-cat-right">
      <div class="product-showcase-card">
        <div class="product-swirl-wrap">
          {%- if section.settings.product_image != blank -%}
            {{ section.settings.product_image | image_url: width: 800 | image_tag: class: 'product-swirl-img' }}
          {%- else -%}
            <div class="placeholder-bg swirl-placeholder">Product Swirl</div>
          {%- endif -%}
        </div>

        <div class="product-showcase-details">
          <div class="stars-row">★ ★ ★ ★ ★ (6,944)</div>
          <h2 class="showcase-title">{{ section.settings.product_title | default: 'CENTELLA NIGHT CREAM' | upcase }}</h2>
          <p class="showcase-subtitle">{{ section.settings.product_subtitle | default: 'A raspberry pink glow' }}</p>
          
          <div class="buy-action-row">
            <a href="{{ section.settings.product_link | default: '#' }}" class="btn-pill-buy">
              BUY NOW — {{ section.settings.product_price | default: 'RS. 2,500' }}
            </a>
          </div>
        </div>

        <div class="pagination-counter">1/4</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Rhode Split Category",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left Lifestyle Image"
    },
    {
      "type": "header",
      "content": "Product Detail (Right)"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Swirl Image"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Centella Night Cream"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Subtitle",
      "default": "A raspberry pink glow"
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Price Label",
      "default": "RS. 2,500"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Buy Link"
    }
  ],
  "presets": [
    {
      "name": "Rhode Split Category",
      "category": "High Fidelity"
    }
  ]
}
{% endschema %}
