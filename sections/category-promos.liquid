<style>
  #shopify-section-{{ section.id }} .split-cat-grid {
    display: flex;
    flex-direction: row;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .split-cat-grid.flipped {
    flex-direction: row-reverse;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .split-cat-grid {
      flex-direction: column !important;
      gap: 0 !important;
    }
    #shopify-section-{{ section.id }} .split-cat-left,
    #shopify-section-{{ section.id }} .split-cat-right {
      flex: none !important;
      width: 100% !important;
    }
  }
</style>

<div class="split-category-wrapper">
  <div class="split-cat-grid {% if section.settings.flip_layout %}flipped{% endif %}">
    <!-- Lifestyle Image Column -->
    <div class="split-cat-left" style="flex: 1;">
      {%- if section.settings.image_left != blank -%}
        {{ section.settings.image_left | image_url: width: 1200 | image_tag: class: 'split-cat-img', loading: 'lazy' }}
      {%- else -%}
        <div class="placeholder-bg" style="background:#f2f0ed; height:100%; min-height:400px; display:flex; align-items:center; justify-content:center;">Lifestyle Image</div>
      {%- endif -%}
    </div>

    <!-- Product/Right Image Column (Now Mirrored for 100% Fit) -->
    <div class="split-cat-right" style="flex: 1;">
      {%- if section.settings.product_image != blank -%}
        {{ section.settings.product_image | image_url: width: 1200 | image_tag: class: 'split-cat-img', loading: 'lazy' }}
      {%- else -%}
        <div class="placeholder-bg" style="background:#f2f0ed; height:100%; min-height:400px; display:flex; align-items:center; justify-content:center;">Lifestyle Image</div>
      {%- endif -%}

      <!-- Product Details Overlay (Exact Bottom Left) -->
      <div class="product-overlay-details" style="position: absolute; bottom: 25px; left: 25px; text-align: left; z-index: 10;">
        <div class="stars-row" style="font-size: 0.65rem; color: {% if section.settings.white_text %}#ffffff{% else %}#5b5a53{% endif %}; margin-bottom: 6px; opacity: 0.9;">★ ★ ★ ★ ★ (6,955)</div>
        <h2 class="showcase-title" style="font-size: 1.15rem; font-weight: 800; color: {% if section.settings.white_text %}#ffffff{% else %}#5b5a53{% endif %}; margin-bottom: 15px; letter-spacing: -0.01em;">{{ section.settings.product_title | default: 'CENTELLA NIGHT CREAM' | upcase }}</h2>
        <a href="{{ section.settings.product_link | default: '#' }}" class="btn-pill-buy" style="display: inline-block; padding: 10px 24px; border: 1.2px solid {% if section.settings.white_text %}#ffffff{% else %}#5b5a53{% endif %}; border-radius: 50px; font-size: 0.75rem; font-weight: 700; color: {% if section.settings.white_text %}#ffffff{% else %}#5b5a53{% endif %}; text-decoration: none; transition: opacity 0.2s;">
          BUY BLUSH — {{ section.settings.product_price | default: 'RS. 2,500' }}
        </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Rhode Split Category",
  "settings": [
    {
      "type": "checkbox",
      "id": "flip_layout",
      "label": "Flip Layout (Image on Right)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "white_text",
      "label": "White Text (for Dark Images)",
      "default": false
    },
    {
      "type": "text",
      "id": "pagination_text",
      "label": "Pagination Counter Text",
      "default": "1/4"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Lifestyle Image"
    },
    {
      "type": "header",
      "content": "Product Detail"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Swirl Image"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Centella Night Cream"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Subtitle",
      "default": "A raspberry pink glow"
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Price Label",
      "default": "RS. 2,500"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Buy Link"
    },
    {
      "type": "checkbox",
      "id": "hide_details",
      "label": "Hide Text & Buttons (Full Bleed Image)",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Rhode Split Category",
      "category": "High Fidelity"
    }
  ]
}
{% endschema %}
