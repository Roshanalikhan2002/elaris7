<style>
  #shopify-section-{{ section.id }} .split-cat-grid {
    display: flex;
    flex-direction: row;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .split-cat-grid.flipped {
    flex-direction: row-reverse;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .split-cat-grid {
      flex-direction: column !important;
      gap: 0 !important;
    }
    #shopify-section-{{ section.id }} .split-cat-left,
    #shopify-section-{{ section.id }} .split-cat-right {
      flex: none !important;
      width: 100% !important;
    }
  }
</style>

<div class="split-category-wrapper">
  <div class="split-cat-grid {% if section.settings.flip_layout %}flipped{% endif %}">
    <!-- Lifestyle Image Column -->
    <div class="split-cat-left" style="flex: 1;">
      {%- if section.settings.image_left != blank -%}
        {{ section.settings.image_left | image_url: width: 1200 | image_tag: class: 'split-cat-img', loading: 'lazy' }}
      {%- else -%}
        <div class="placeholder-bg" style="background:#f2f0ed; height:100%; min-height:400px; display:flex; align-items:center; justify-content:center;">Lifestyle Image</div>
      {%- endif -%}
    </div>

    <!-- Product Detail Column -->
    <div class="split-cat-right" style="flex: 1; min-width: 50%;">
      <div class="product-showcase-card" style="width: 100% !important; height: 100% !important; position: relative !important; overflow: hidden !important; border-radius: 12px; background: none !important; padding: 0 !important; margin: 0 !important;">
        <div class="product-swirl-wrap" style="width: 100% !important; height: 100% !important; margin: 0 !important; padding: 0 !important;">
          {%- if section.settings.product_image != blank -%}
            {{ section.settings.product_image | image_url: width: 2400 | image_tag: class: 'product-swirl-img', style: 'width:100% !important; height:100% !important; object-fit:cover !important; display:block !important;' }}
          {%- else -%}
            <div class="placeholder-bg swirl-placeholder">Product Swirl</div>
          {%- endif -%}
        </div>

        {%- unless section.settings.hide_details -%}
          <div class="product-showcase-details">
            <div class="stars-row">★ ★ ★ ★ ★ (6,944)</div>
            <h2 class="showcase-title">{{ section.settings.product_title | default: 'CENTELLA NIGHT CREAM' | upcase }}</h2>
            <p class="showcase-subtitle">{{ section.settings.product_subtitle | default: 'A raspberry pink glow' }}</p>
            
            <div class="buy-action-row">
              <a href="{{ section.settings.product_link | default: '#' }}" class="btn-pill-buy">
                BUY NOW — {{ section.settings.product_price | default: 'RS. 2,500' }}
              </a>
            </div>
          </div>
        {%- endunless -%}

        <div class="pagination-counter">{{ section.settings.pagination_text | default: '1/4' }}</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Rhode Split Category",
  "settings": [
    {
      "type": "checkbox",
      "id": "flip_layout",
      "label": "Flip Layout (Image on Right)",
      "default": false
    },
    {
      "type": "text",
      "id": "pagination_text",
      "label": "Pagination Counter Text",
      "default": "1/4"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Lifestyle Image"
    },
    {
      "type": "header",
      "content": "Product Detail"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Swirl Image"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Centella Night Cream"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Subtitle",
      "default": "A raspberry pink glow"
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Price Label",
      "default": "RS. 2,500"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Buy Link"
    },
    {
      "type": "checkbox",
      "id": "hide_details",
      "label": "Hide Text & Buttons (Full Bleed Image)",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Rhode Split Category",
      "category": "High Fidelity"
    }
  ]
}
{% endschema %}
