<div class="faq-split-wrapper">
  <div class="faq-split-grid">
    <div class="faq-split-content">
      <div class="faq-split-text-area">
        <h2 class="faq-split-title">{{ section.settings.title | default: 'FAQ' }}</h2>
      </div>

      <div class="faq-accordion-wrap">
        {%- if product.handle == 'floral-blossom-hair-mist' -%}
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use this hair mist daily?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is safe for daily use and can be applied multiple times a day.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Will it make my hair sticky?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>No, the formula is designed to feel fresh and does not leave stickiness.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use it on wet hair?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>It works best on dry hair for instant freshness and fragrance.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Does the fragrance last long?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it leaves a soft floral scent that lasts for hours.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Is it suitable for all hair types?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is suitable for all hair types and textures.</p></div>
              </div>
            </div>
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="faq-acc-item {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
              <div class="faq-acc-header">
                <span>{{ block.settings.question | upcase }}</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner">
                  <p>{{ block.settings.answer }}</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- if product.handle == 'glutathione-cream' -%}
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use this cream every day?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is suitable for daily use, both morning and evening.</p></div>
              </div>
            </div>
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Is it suitable for dull skin?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is specifically designed to target dullness and uneven skin tone.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'centella-skin-toner' -%}
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>When should I use this toner?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Use it after cleansing and before your serum or moisturizer.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use this hair mist daily?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is safe for daily use and can be applied multiple times a day.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Will it make my hair sticky?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>No, the formula is designed to feel fresh and does not leave stickiness.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use it on wet hair?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>It works best on dry hair for instant freshness and fragrance.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Does the fragrance last long?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it leaves a soft floral scent that lasts for hours.</p></div>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Is it suitable for all hair types?</span>
                <div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is suitable for all hair types and textures.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this serum on dry hair?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it works well on both damp and dry hair to control frizz and add shine.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it make my hair greasy?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, the formula is designed to be non-greasy and does not weigh hair down.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use it before heat styling?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it acts as a heat protectant and helps reduce damage from styling tools.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is it suitable for all hair types?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it works for all hair types, especially dry, frizzy, or damaged hair.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>How often should I use it?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>You can use it daily or whenever your hair needs smoothness and control.</p></div></div></div>
          {%- elsif product.handle == 'tranexamic-serum' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this serum every day?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it is suitable for daily use, both morning and night.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is it suitable for sensitive skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it includes soothing ingredients, but patch testing is recommended.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it help with dark spots and pigmentation?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it is designed to target discoloration and improve uneven tone.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I layer it with other skincare products?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it works well with moisturizers, sunscreens, and other gentle actives.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Do I need to use sunscreen with this?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, sunscreen is essential during the day to protect and maintain results.</p></div></div></div>
          {%- assign handle_down = product.handle | downcase -%}
          {%- assign title_up = product.title | upcase -%}
          {%- assign is_night_cream = false -%}
          {%- assign is_face_wash = false -%}
          {%- if handle_down == 'night-cream' or title_up contains 'NIGHT CREAM' -%}
            {%- assign is_night_cream = true -%}
          {%- elsif title_up contains 'FACE WASH' or product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or handle_down contains 'face-wash' or handle_down contains 'cleanser' -%}
            {%- assign is_face_wash = true -%}
          {%- endif -%}

          {%- if handle_down == 'centella-serum' or handle_down == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or title_up contains 'CENTELLA SERUM' or title_up contains 'GLOW SERUM' -%}
            {%- assign is_centella_serum = true -%}
          {%- elsif handle_down contains 'glutathione' or title_up contains 'GLUTATHIONE' -%}
            {%- assign is_glutathione_cream = true -%}
          {%- endif -%}

          {%- if is_centella_serum -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this serum with other active ingredients?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it layers well with most skincare actives. For stronger treatments like retinol, apply them separately and allow time before layering.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is this suitable for acne-prone or sensitive skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, the formula includes calming ingredients like Centella Asiatica and Aloe Vera, making it suitable for sensitive and acne-prone skin.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this serum both morning and night?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Absolutely, it is designed for daily use and works effectively in both AM and PM routines.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it help with hyperpigmentation and acne marks?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, brightening ingredients like Niacinamide, Vitamin C, and Alpha Arbutin help visibly reduce dark spots and uneven tone over time.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it feel heavy or sticky on the skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, the formula is lightweight and fast-absorbing, leaving the skin smooth without any sticky residue.</p></div></div></div>
          {%- elsif is_glutathione_cream -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this cream every day?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it is suitable for daily use, both morning and evening.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is it suitable for dull and uneven skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it is designed to target dullness, pigmentation, and uneven tone.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it feel heavy on my skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, it absorbs well while still providing deep hydration and comfort.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use it with other skincare products?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it works well with serums, toners, and sunscreen.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Do I need sunscreen while using this?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, sunscreen is essential during the day to protect and maintain results.</p></div></div></div>
          {%- elsif is_night_cream -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this night cream with my serum?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, applying serum before the night cream enhances hydration and repair benefits.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is it suitable for oily skin at night?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Absolutely, it hydrates without clogging pores or leaving a greasy residue.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>How often should I use it?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>For optimal results, use every night as the final step in your evening routine.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it help with dull or uneven skin tone?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, its brightening and repair ingredients work overnight to improve radiance and evenness.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can it reduce the appearance of fine lines?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, regular use helps visibly minimize fine lines and promotes firmer, youthful-looking skin.</p></div></div></div>
          {%- elsif is_face_wash -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use this face wash twice a day?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it's gentle enough for both your morning and evening skincare routines.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it dry out my skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, it is formulated to cleanse deeply while maintaining your skin's natural moisture barrier.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it help with acne and breakouts?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, Centella Asiatica helps soothe inflammation and calm breakout-prone skin.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Is it safe for sensitive skin?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Absolutely. It is free from harsh sulfates and perfectly pH-balanced.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it remove makeup?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>It removes light, everyday makeup, but we recommend double-cleansing for heavy or waterproof makeup.</p></div></div></div>
          {%- elsif product.handle == 'sunscreen' or product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it leave a white cast?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, it is formulated to blend invisibly into all skin tones for a smooth finish.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use it under makeup?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, its weightless texture makes it a perfect primer for makeup application.</p></div></div></div>
          {%- else -%}
             <!-- Default FAQ mapping if no handle matches -->
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>How should I use this product?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Apply to clean skin and massage gently until absorbed.</p></div>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="faq-split-image">
      {%- if product.handle == 'anti-frizz-keratin-serum' or product.handle == 'anti-frizz-serum' or product.handle == 'keratin-serum' -%}
        <img class="faq-image faq-bg-img" src="{{ 'keratin-serum.jpg' | asset_url }}" alt="FAQ Keratin Serum Visual">
      {%- elsif product.handle == 'tranexamic-serum' -%}
        <img class="faq-image faq-bg-img" src="{{ 'tranexamic-meet-2.jpg' | asset_url }}" alt="FAQ Tranexamic Serum Visual">
      {%- elsif is_night_cream -%}
        <img class="faq-image faq-bg-img" src="{{ 'faq-100-nc.jpg' | asset_url }}" alt="FAQ Night Cream Visual">
      {%- elsif product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
        <img class="faq-image faq-bg-img" src="{{ 'cleanser-meet-1.jpg' | asset_url }}" alt="FAQ Cleanser Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' or product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or product.handle == 'sunscreen' -%}
        <img class="faq-image faq-bg-img" src="{{ 'sunscreen-lifestyle-2.jpg' | asset_url }}" alt="FAQ Sunscreen Visual">
      {%- elsif product.handle == 'centella-skin-toner' -%}
        <img class="faq-image faq-bg-img" src="{{ 'toner-meet-4.jpg' | asset_url }}" alt="FAQ Toner Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' -%}
        <img class="faq-image faq-bg-img" src="{{ 'moisturizer-faq.jpg' | asset_url }}" alt="FAQ Moisturizer Visual">
      {%- elsif is_face_wash -%}
        <img class="faq-image faq-bg-img" src="{{ 'meet-elaris-you-2-100-10.jpg' | asset_url }}" alt="FAQ Face Wash Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}
        <img class="faq-image faq-bg-img" src="{{ 'glow-meet-4.jpg' | asset_url }}" alt="FAQ Serum Visual">
      {%- elsif handle_down contains 'glutathione' -%}
        <img class="faq-image faq-bg-img" src="{{ 'glutathione-cream-100.jpg' | asset_url }}" alt="FAQ Glutathione Cream Visual">
      {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
        <img class="faq-image faq-bg-img" src="{{ 'hair-mist-faq.jpg' | asset_url }}" alt="FAQ Hair Mist Visual">
      {%- elsif product.handle == 'anti-frizz-keratin-serum' -%}
        <img class="faq-image faq-bg-img" src="{{ 'keratin-meet-1.jpg' | asset_url }}" alt="FAQ Keratin Visual">
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'faq-bg-img', loading: 'lazy' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1615397323136-2eb83d8bdf9b?q=80&w=1200" class="faq-bg-img" alt="Products Placeholder">
      {%- endif -%}
    </div>
  </div>
</div>

<style>
.faq-split-wrapper {
  margin: 0;
  background-color: #f3f0ec; /* beige background */
}

.faq-split-grid {
  display: flex;
  min-height: 700px;
}

.faq-split-content {
  flex: 1;
  padding: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.faq-split-text-area {
  margin-bottom: 40px;
}

.faq-split-title {
  font-size: 2rem;
  font-weight: 300;
  color: #5b5a53;
  margin: 0 0 16px 0;
  letter-spacing: -0.01em;
}

.faq-accordion-wrap {
  border-top: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-item {
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-header {
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 0.82rem;
  font-weight: 700;
  color: #7a7873;
  letter-spacing: 0.04em;
}

.acc-icon-faq {
  position: relative;
  width: 24px;
  height: 24px;
  background: #a8a39a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.4s;
}

.acc-icon-faq .line {
  position: absolute;
  background: white;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
}

.acc-icon-faq .v-line { width: 2px; height: 10px; }
.acc-icon-faq .h-line { width: 10px; height: 2px; }

.faq-acc-item.active .acc-icon-faq {
  transform: rotate(-135deg);
  background: #5b5a53;
}

.faq-acc-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
  opacity: 0;
  pointer-events: none;
}

.faq-acc-item.active .faq-acc-content {
  max-height: 500px;
  opacity: 1;
  pointer-events: auto;
}

.faq-acc-content-inner {
  min-height: 0;
  padding-bottom: 24px;
}

.faq-acc-content p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #5b5a53;
  margin: 0;
}

.faq-split-image {
  flex: 1;
  position: relative;
}

.faq-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (max-width: 900px) {
  .faq-split-grid {
    flex-direction: column;
    min-height: auto;
  }
  .faq-split-image {
    height: 450px;
    order: -1;
  }
  .faq-split-content {
    padding: 40px 24px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const faqHeaders = document.querySelectorAll('.faq-acc-header');
  faqHeaders.forEach(header => {
    header.addEventListener('click', () => {
      const item = header.parentElement;
      const isActive = item.classList.contains('active');
      const wrap = item.closest('.faq-accordion-wrap');
      wrap.querySelectorAll('.faq-acc-item').forEach(el => el.classList.remove('active'));
      if (!isActive) item.classList.add('active');
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Split",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "FAQ" },
    { "type": "image_picker", "id": "image", "label": "Right Side Image" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ Split" }]
}
{% endschema %}
