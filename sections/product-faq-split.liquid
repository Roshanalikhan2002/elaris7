<style>
.faq-split-wrapper {
  margin: 0;
  background-color: #f3f0ec; /* beige background */
}

.faq-split-grid {
  display: flex;
  min-height: 700px;
}

.faq-split-content {
  flex: 1;
  padding: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.faq-split-text-area {
  margin-bottom: 40px;
}

.faq-split-title {
  font-size: 2rem;
  font-weight: 300;
  color: #5b5a53;
  margin: 0 0 16px 0;
  letter-spacing: -0.01em;
}

.faq-split-subtitle {
  font-size: 0.95rem;
  color: #7a7873;
  margin: 0;
}

.faq-accordion-wrap {
  border-top: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-item {
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-header {
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 0.82rem;
  font-weight: 700;
  color: #7a7873;
  letter-spacing: 0.04em;
}

.acc-icon-faq {
  position: relative;
  width: 24px;
  height: 24px;
  background: #a8a39a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.4s;
}

.acc-icon-faq .line {
  position: absolute;
  background: white;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
}

.acc-icon-faq .v-line {
  width: 2px;
  height: 10px;
}

.acc-icon-faq .h-line {
  width: 10px;
  height: 2px;
}

.faq-acc-item.active .acc-icon-faq {
  transform: rotate(-135deg); /* Anticlockwise rotation into an X/minus feel */
  background: #5b5a53;
}

.faq-acc-item.active .v-line {
  /* Optionally hide the vertical line to make it a perfect minus, but rotation looks cooler move moved moves move move */
  /* opacity: 0; */
}

.faq-acc-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
  opacity: 0;
  pointer-events: none;
}

.faq-acc-item.active .faq-acc-content {
  max-height: 500px; /* Large enough for content */
  opacity: 1;
  pointer-events: auto;
}

.faq-acc-content-inner {
  min-height: 0;
  padding-bottom: 24px;
}

.faq-acc-content p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #5b5a53;
  margin: 0;
}

.faq-split-image {
  flex: 1;
  position: relative;
}

.faq-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (max-width: 900px) {
  .faq-split-grid {
    flex-direction: column;
    min-height: auto;
  }
  .faq-split-image {
    height: 450px;
    order: -1;
  }
  .faq-split-content {
    padding: 40px 24px;
    border-radius: 0;
  }
  .faq-split-title {
    font-size: 1.8rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const faqHeaders = document.querySelectorAll('.faq-acc-header');
  if (faqHeaders.length === 0) return;

  faqHeaders.forEach(header => {
    header.addEventListener('click', () => {
      const item = header.parentElement;
      const isActive = item.classList.contains('active');
      
      const wrap = item.closest('.faq-accordion-wrap');
      wrap.querySelectorAll('.faq-acc-item').forEach(el => {
        el.classList.remove('active');
      });

      if (!isActive) {
        item.classList.add('active');
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Split",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find out more about Barrier Butter."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "QUESTION HERE?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Answer goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Split",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
