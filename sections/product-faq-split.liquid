<div class="faq-split-wrapper">
  <div class="faq-split-grid">
    <div class="faq-split-content">
      <div class="faq-split-text-area">
        <h2 class="faq-split-title">{{ section.settings.title | default: 'FAQ' }}</h2>
      </div>

      <div class="faq-accordion-wrap">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="faq-acc-item {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
              <div class="faq-acc-header">
                <span>{{ block.settings.question | upcase }}</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner">
                  <p>{{ block.settings.answer }}</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- if product.handle == 'glutathione-cream' -%}
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use this cream every day?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is suitable for daily use, both morning and evening.</p></div>
              </div>
            </div>
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Is it suitable for dull skin?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Yes, it is specifically designed to target dullness and uneven skin tone.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'centella-skin-toner' -%}
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>When should I use this toner?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Use it after cleansing and before your serum or moisturizer.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>Can I use this on wet hair?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>It works best on dry hair for instant fragrance and shine refresh.</p></div>
              </div>
            </div>
          {%- elsif product.handle == 'centella-serum' or product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>When should I apply this serum?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Apply it to clean skin, before your moisturizer, in both morning and evening routines.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Will it help with dark spots?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it contains brightening complexes designed to even out skin tone and fade dullness over time.</p></div></div></div>
          {%- elsif product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>CAN I USE THIS FACE WASH TWICE A DAY?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, it is gentle enough for both morning and evening use without over-drying your skin.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>IS IT SUITABLE FOR SENSITIVE SKIN?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, the formula includes calming ingredients like Centella Asiatica and honey, making it ideal for sensitive skin.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>WILL IT HELP WITH ACNE OR BREAKOUTS?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>It helps cleanse pores, remove excess oil, and soothe irritation, which can support clearer skin over time.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>DOES IT REMOVE MAKEUP?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>It can remove light makeup, but for heavy or waterproof makeup, use a remover before cleansing.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>WILL MY SKIN FEEL DRY AFTER WASHING?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, it is designed to maintain hydration and leave your skin feeling soft and balanced.</p></div></div></div>
          {%- elsif product.handle == 'sunscreen' or product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Does it leave a white cast?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>No, it is formulated to blend invisibly into all skin tones for a smooth finish.</p></div></div></div>
            <div class="faq-acc-item"><div class="faq-acc-header"><span>Can I use it under makeup?</span><div class="acc-icon-faq"><div class="line v-line"></div><div class="line h-line"></div></div></div><div class="faq-acc-content"><div class="faq-acc-content-inner"><p>Yes, its weightless texture makes it a perfect primer for makeup application.</p></div></div></div>
          {%- else -%}
             <!-- Default FAQ mapping if no handle matches -->
             <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>How should I use this product?</span>
                <div class="acc-icon-faq">
                  <div class="line v-line"></div>
                  <div class="line h-line"></div>
                </div>
              </div>
              <div class="faq-acc-content">
                <div class="faq-acc-content-inner"><p>Apply to clean skin and massage gently until absorbed.</p></div>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="faq-split-image">
      {%- if product.handle == 'centella-skin-toner-copy' or product.handle == 'renewal-cleanser' -%}
        <img class="faq-image faq-bg-img" src="{{ 'cleanser-meet-1.jpg' | asset_url }}" alt="FAQ Cleanser Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' -%}
        <img class="faq-image faq-bg-img" src="{{ 'facewash-faq-squeeze.jpg' | asset_url }}" alt="FAQ Face Wash Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' or product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' or product.handle == 'sunscreen' -%}
        <img class="faq-image faq-bg-img" src="{{ 'sunscreen-lifestyle-2.jpg' | asset_url }}" alt="FAQ Sunscreen Visual">
      {%- elsif product.handle == 'centella-skin-toner' -%}
        <img class="faq-image faq-bg-img" src="{{ 'toner-meet-4.jpg' | asset_url }}" alt="FAQ Toner Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-moisturizer' -%}
        <img class="faq-image faq-bg-img" src="{{ 'moisturizer-faq.jpg' | asset_url }}" alt="FAQ Moisturizer Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-night-cream-copy' or product.handle == 'e7-korean-glass-skin-centella-face-wash-copy' -%}
        <img class="faq-image faq-bg-img" src="{{ 'facewash-faq-squeeze.jpg' | asset_url }}" alt="FAQ Face Wash Visual">
      {%- elsif product.handle == 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}
        <img class="faq-image faq-bg-img" src="{{ 'glow-meet-4.jpg' | asset_url }}" alt="FAQ Serum Visual">
      {%- elsif product.handle == 'floral-blossom-hair-mist' -%}
        <img class="faq-image faq-bg-img" src="{{ 'hair-mist-faq.jpg' | asset_url }}" alt="FAQ Hair Mist Visual">
      {%- elsif product.handle == 'anti-frizz-keratin-serum' -%}
        <img class="faq-image faq-bg-img" src="{{ 'keratin-meet-1.jpg' | asset_url }}" alt="FAQ Keratin Visual">
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'faq-bg-img', loading: 'lazy' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1615397323136-2eb83d8bdf9b?q=80&w=1200" class="faq-bg-img" alt="Products Placeholder">
      {%- endif -%}
    </div>
  </div>
</div>

<style>
.faq-split-wrapper {
  margin: 0;
  background-color: #f3f0ec; /* beige background */
}

.faq-split-grid {
  display: flex;
  min-height: 700px;
}

.faq-split-content {
  flex: 1;
  padding: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.faq-split-text-area {
  margin-bottom: 40px;
}

.faq-split-title {
  font-size: 2rem;
  font-weight: 300;
  color: #5b5a53;
  margin: 0 0 16px 0;
  letter-spacing: -0.01em;
}

.faq-accordion-wrap {
  border-top: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-item {
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-header {
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 0.82rem;
  font-weight: 700;
  color: #7a7873;
  letter-spacing: 0.04em;
}

.acc-icon-faq {
  position: relative;
  width: 24px;
  height: 24px;
  background: #a8a39a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.4s;
}

.acc-icon-faq .line {
  position: absolute;
  background: white;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
}

.acc-icon-faq .v-line { width: 2px; height: 10px; }
.acc-icon-faq .h-line { width: 10px; height: 2px; }

.faq-acc-item.active .acc-icon-faq {
  transform: rotate(-135deg);
  background: #5b5a53;
}

.faq-acc-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.3s;
  opacity: 0;
  pointer-events: none;
}

.faq-acc-item.active .faq-acc-content {
  max-height: 500px;
  opacity: 1;
  pointer-events: auto;
}

.faq-acc-content-inner {
  min-height: 0;
  padding-bottom: 24px;
}

.faq-acc-content p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #5b5a53;
  margin: 0;
}

.faq-split-image {
  flex: 1;
  position: relative;
}

.faq-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (max-width: 900px) {
  .faq-split-grid {
    flex-direction: column;
    min-height: auto;
  }
  .faq-split-image {
    height: 450px;
    order: -1;
  }
  .faq-split-content {
    padding: 40px 24px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const faqHeaders = document.querySelectorAll('.faq-acc-header');
  faqHeaders.forEach(header => {
    header.addEventListener('click', () => {
      const item = header.parentElement;
      const isActive = item.classList.contains('active');
      const wrap = item.closest('.faq-accordion-wrap');
      wrap.querySelectorAll('.faq-acc-item').forEach(el => el.classList.remove('active'));
      if (!isActive) item.classList.add('active');
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Split",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "FAQ" },
    { "type": "image_picker", "id": "image", "label": "Right Side Image" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ Split" }]
}
{% endschema %}
