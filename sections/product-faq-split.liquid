<div class="faq-split-wrapper">
  <div class="faq-split-grid">
    <div class="faq-split-content">
      <div class="faq-split-text-area">
        <h2 class="faq-split-title">{{ section.settings.title | default: 'FAQ' }}</h2>
        <p class="faq-split-subtitle">{{ section.settings.subtitle | default: 'Find out more about Barrier Butter.' }}</p>
      </div>

      <div class="faq-accordion-wrap">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="faq-acc-item {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
              <div class="faq-acc-header">
                <span>{{ block.settings.question | upcase }}</span>
                <span class="acc-icon-faq">{% if forloop.first %}−{% else %}+{% endif %}</span>
              </div>
              <div class="faq-acc-content">
                <p>{{ block.settings.answer }}</p>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
            <div class="faq-acc-item active">
              <div class="faq-acc-header">
                <span>WHERE DOES BARRIER BUTTER FIT INTO MY DAILY ROUTINE?</span>
                <span class="acc-icon-faq">−</span>
              </div>
              <div class="faq-acc-content">
                <p>Use it as the last step in your PM routine to seal in moisture, or anytime your skin needs extra care.</p>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>HOW IS BARRIER BUTTER DIFFERENT FROM BRC?</span>
                <span class="acc-icon-faq">+</span>
              </div>
              <div class="faq-acc-content">
                <p>Barrier Butter is formulated for intensive overnight repair with a richer, more occlusive texture.</p>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>CAN IT BE USED FOR ALL SKIN TYPES?</span>
                <span class="acc-icon-faq">+</span>
              </div>
              <div class="faq-acc-content">
                <p>Yes, it's formulated to be safe and effective for all skin types, including sensitive skin.</p>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>IS IT NON-COMEDOGENIC?</span>
                <span class="acc-icon-faq">+</span>
              </div>
              <div class="faq-acc-content">
                <p>Yes, Barrier Butter is non-comedogenic and will not clog your pores.</p>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>IS IT DERMATOLOGIST TESTED?</span>
                <span class="acc-icon-faq">+</span>
              </div>
              <div class="faq-acc-content">
                <p>Yes, all of our products are dermatologist tested.</p>
              </div>
            </div>
            <div class="faq-acc-item">
              <div class="faq-acc-header">
                <span>IS IT VEGAN OR CRUELTY-FREE?</span>
                <span class="acc-icon-faq">+</span>
              </div>
              <div class="faq-acc-content">
                <p>Absolutely. We are proud to be 100% vegan and PETA-certified cruelty-free.</p>
              </div>
            </div>
        {%- endif -%}
      </div>
    </div>

    <div class="faq-split-image">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'faq-bg-img', loading: 'lazy' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1615397323136-2eb83d8bdf9b?q=80&w=1200" class="faq-bg-img" alt="Products Placeholder">
      {%- endif -%}
    </div>
  </div>
</div>

<style>
.faq-split-wrapper {
  margin: 0;
  background-color: #f3f0ec; /* beige background */
}

.faq-split-grid {
  display: flex;
  min-height: 700px;
}

.faq-split-content {
  flex: 1;
  padding: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.faq-split-text-area {
  margin-bottom: 40px;
}

.faq-split-title {
  font-size: 2rem;
  font-weight: 300;
  color: #5b5a53;
  margin: 0 0 16px 0;
  letter-spacing: -0.01em;
}

.faq-split-subtitle {
  font-size: 0.95rem;
  color: #7a7873;
  margin: 0;
}

.faq-accordion-wrap {
  border-top: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-item {
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.faq-acc-header {
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 0.82rem;
  font-weight: 700;
  color: #7a7873;
  letter-spacing: 0.04em;
}

.acc-icon-faq {
  font-size: 1.1rem;
  font-weight: 500;
  color: #fff;
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #a8a39a;
}

.faq-acc-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.faq-acc-item.active .faq-acc-content {
  max-height: 300px;
  padding-bottom: 24px;
}

.faq-acc-content p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #5b5a53;
  margin: 0;
}

.faq-split-image {
  flex: 1;
  position: relative;
}

.faq-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (max-width: 900px) {
  .faq-split-grid {
    flex-direction: column;
  }
  .faq-split-image {
    height: 450px;
    order: -1;
  }
  .faq-split-content {
    padding: 60px 20px;
  }
  .faq-split-title {
    font-size: 1.8rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const faqHeaders = document.querySelectorAll('.faq-acc-header');
  if (faqHeaders.length === 0) return;

  faqHeaders.forEach(header => {
    // Prevent duplicate event listeners if this runs multiple times
    const newHeader = header.cloneNode(true);
    header.parentNode.replaceChild(newHeader, header);
    
    newHeader.addEventListener('click', () => {
      const item = newHeader.parentElement;
      const isActive = item.classList.contains('active');
      
      const wrap = item.closest('.faq-accordion-wrap');
      wrap.querySelectorAll('.faq-acc-item').forEach(el => {
        el.classList.remove('active');
        const icon = el.querySelector('.acc-icon-faq');
        if (icon) icon.textContent = '+';
      });

      if (!isActive) {
        item.classList.add('active');
        const icon = newHeader.querySelector('.acc-icon-faq');
        if (icon) icon.textContent = '−';
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Split",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find out more about Barrier Butter."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "QUESTION HERE?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Answer goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Split",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
