<nav class="category-bar">
  <ul class="category-list">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <li>
          <a href="{{ block.settings.link | default: '#' }}" class="cat-link {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
            {{ block.settings.title | uppercase }}
          </a>
        </li>
      {% endfor %}
    {% else %}
      {% assign default_cats = "FEATURED,SKIN,LIP+CHEEK,SETS,COLOUR" | split: "," %}
      {% for cat in default_cats %}
        <li>
          <a href="#" class="cat-link {% if forloop.first %}active{% endif %}">
            {{ cat }}
          </a>
        </li>
      {% endfor %}
    {% endif %}
  </ul>
</nav>

{% schema %}
{
  "name": "Category Navigation",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Navigation",
      "blocks": [
        { "type": "category", "settings": { "title": "FEATURED" } },
        { "type": "category", "settings": { "title": "SKIN" } },
        { "type": "category", "settings": { "title": "LIP+CHEEK" } },
        { "type": "category", "settings": { "title": "SETS" } },
        { "type": "category", "settings": { "title": "COLOUR" } }
      ]
    }
  ]
}
{% endschema %}
