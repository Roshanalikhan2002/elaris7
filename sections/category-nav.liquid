<nav class="category-bar">
  <ul class="category-list">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <li>
          <a href="{{ block.settings.link | default: '#' }}" 
             class="cat-link {% if forloop.first %}active{% endif %}" 
             data-category="{{ block.settings.title | handleize }}"
             {{ block.shopify_attributes }}>
            {{ block.settings.title | uppercase }}
          </a>
        </li>
      {% endfor %}
    {% else %}
      {% assign default_cats = "Featured,Korean glass skin,Anti acne,Korean brightening,Hair care,Sets" | split: "," %}
      {% for cat in default_cats %}
        <li>
          <a href="#" class="cat-link {% if forloop.first %}active{% endif %}" data-category="{{ cat | handleize }}">
            {{ cat | uppercase }}
          </a>
        </li>
      {% endfor %}
    {% endif %}
  </ul>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const catLinks = document.querySelectorAll('.cat-link');
  // Use class selectors instead of Shopify generated IDs which can vary
  const scrollSection = document.querySelector('.product-scroll-wrapper');
  const gridSection = document.getElementById('featured-grid-section');

  function toggleView(catName) {
    if (catName === 'featured') {
      if (gridSection) gridSection.style.setProperty('display', 'block', 'important');
      if (scrollSection) scrollSection.closest('.shopify-section').style.setProperty('display', 'none', 'important');
    } else {
      if (gridSection) gridSection.style.setProperty('display', 'none', 'important');
      if (scrollSection) scrollSection.closest('.shopify-section').style.setProperty('display', 'block', 'important');
    }
  }

  // Initial state: Show Featured Grid, hide Scroll
  toggleView('featured');

  catLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      if (this.getAttribute('href') === '#') e.preventDefault();
      
      catLinks.forEach(l => l.classList.remove('active'));
      this.classList.add('active');

      const catName = this.dataset.category;
      toggleView(catName);
    });
  });
});
</script>

{% schema %}
{
  "name": "Category Navigation",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Navigation",
      "blocks": [
        { "type": "category", "settings": { "title": "Featured" } },
        { "type": "category", "settings": { "title": "Korean glass skin" } },
        { "type": "category", "settings": { "title": "Anti acne" } },
        { "type": "category", "settings": { "title": "Korean brightening" } },
        { "type": "category", "settings": { "title": "Hair care" } },
        { "type": "category", "settings": { "title": "Sets" } }
      ]
    }
  ]
}
{% endschema %}
