<nav class="category-bar">
  <ul class="category-list">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <li>
          <a href="{{ block.settings.link | default: '#' }}" 
             class="cat-link {% if block.settings.title == 'Featured' %}active{% endif %}" 
             data-category="{{ block.settings.title | handleize }}"
             {{ block.shopify_attributes }}>
            {{ block.settings.title | uppercase }}
          </a>
        </li>
      {% endfor %}
    {% else %}
      {% assign default_cats = "Featured,Korean glass skin,Anti acne,Korean brightening,Hair care,Sets" | split: "," %}
      {% for cat in default_cats %}
        <li>
          <a href="/pages/{{ cat | handleize }}" class="cat-link {% if forloop.first %}active{% endif %}" data-category="{{ cat | handleize }}">
            {{ cat | uppercase }}
          </a>
        </li>
      {% endfor %}
    {% endif %}
  </ul>
</nav>

<style>
.category-bar {
  padding: 30px 40px;
  background: #fff;
  overflow-x: auto;
  scrollbar-width: none;
}
.category-bar::-webkit-scrollbar { display: none; }
.category-list {
  display: flex;
  gap: 12px;
  list-style: none;
  padding: 0;
  margin: 0;
  justify-content: center;
}
.cat-link {
  text-decoration: none;
  font-size: 0.75rem;
  font-weight: 700;
  color: #7A7973;
  padding: 10px 24px;
  border: 1px solid #e5e5e5;
  border-radius: 50px;
  letter-spacing: 0.08em;
  transition: all 0.3s ease;
  white-space: nowrap;
  display: inline-block;
  cursor: pointer;
}
.cat-link:hover {
  border-color: #333;
  color: #333;
}
.cat-link.active {
  background-color: #5b5a53;
  color: #fff;
  border-color: #5b5a53;
}
@media (max-width: 768px) {
  .category-list {
    justify-content: flex-start;
    padding: 0 16px;
  }
  .category-bar {
    padding: 20px 0;
  }
}
</style>

{% schema %}
{
  "name": "Category Navigation",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Navigation",
      "blocks": [
        { "type": "category", "settings": { "title": "Featured" } },
        { "type": "category", "settings": { "title": "Korean glass skin" } },
        { "type": "category", "settings": { "title": "Anti acne" } },
        { "type": "category", "settings": { "title": "Korean brightening" } },
        { "type": "category", "settings": { "title": "Hair care" } },
        { "type": "category", "settings": { "title": "Sets" } }
      ]
    }
  ]
}
{% endschema %}
