<section class="section testimonials" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>
    <div class="testimonial-slider">
      {% for block in section.blocks %}
        <div class="testimonial-item" {{ block.shopify_attributes }}>
          <p class="testimonial-text">"{{ block.settings.quote }}"</p>
          <p class="testimonial-author">— {{ block.settings.author }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#e8e4dc"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "My acne cleared up in just two weeks. Finally a halal-conscious Korean skincare routine that actually gives the glass skin effect!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Ayesha A."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider",
      "category": "Text"
    }
  ]
}
{% endschema %}
