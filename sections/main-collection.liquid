{% schema %}
{
  "name": "Main Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}

{%- assign is_landing_mode = false -%}
{%- if collection.handle == 'elaris-7-korean-glass-skin-bundle' or collection.handle == 'elaris-7-korean-brightening-bundle' or collection.handle == 'elaris-7-korean-hair-care-bundle' -%}
  {%- assign is_landing_mode = true -%}
{%- endif -%}

{%- comment -%} FORCE GRID MODE FOR SHORT URLS {%- endcomment -%}
{%- if request.path contains '/collections/korean-brightening' or request.path contains '/collections/korean-glass-skin' -%}
  {%- if request.path != '/collections/elaris-7-korean-brightening-bundle' and request.path != '/collections/elaris-7-korean-glass-skin-bundle' -%}
    {%- assign is_landing_mode = false -%}
  {%- endif -%}
{%- endif -%}

<div class="collection-page">
  {% unless is_landing_mode %}
    <!-- MOBILE HERO BANNER (Homepage Style) -->
    <div class="mobile-only coll-mobile-banner">
      <img src="{{ 'new bundle banner-100.jpg' | asset_url }}" alt="New Bundle Launch">
    </div>

    <div class="collection-nav-bar">
      <div class="collection-nav-inner">
         {% assign default_cats = "Featured,Korean glass skin,Anti acne,Korean brightening,Hair care,Sets" | split: "," %}
          <div class="collection-pills">
            {% for cat in default_cats %}
              {%- assign c_handle = cat | strip | handleize -%}
              {%- if c_handle == 'sets' or c_handle == 'set' -%}
                {%- assign c_handle = 'set' -%}
              {%- endif -%}

              {%- assign pill_url = "/collections/" | append: c_handle -%}
              {%- if c_handle == 'featured' -%}{%- assign pill_url = "/collections/all" -%}{%- endif -%}
              
              {%- assign is_active = false -%}
              {%- if c_handle == 'featured' and (collection.handle == 'all' or collection.handle == 'frontpage') -%}
                {%- assign is_active = true -%}
              {%- elsif c_handle == collection.handle -%}
                {%- assign is_active = true -%}
              {%- endif -%}

              <a href="{{ pill_url }}" class="coll-pill cat-link {% if is_active %}active{% endif %}" data-category="{{ c_handle }}">
                {{ cat | uppercase }}
              </a>
            {% endfor %}
          </div>
      </div>
    </div>
  {% endunless %}

  {% if is_landing_mode %}
    <!-- 
       LANDING PAGE MODE: 
       Replicating the exact design from your custom bundle templates 
    -->
    <div class="landing-page-container">
      {%- case collection.handle -%}
        {%- when 'elaris-7-korean-glass-skin-bundle' -%}
           {% include 'content-glass-bundle' %}
        {%- when 'elaris-7-korean-brightening-bundle' -%}
           {% include 'content-bright-bundle' %}
        {%- when 'elaris-7-korean-hair-care-bundle' -%}
           {% include 'content-hair-bundle' %}
        {%- when 'anti-acne' -%}
           {% include 'content-anti-acne' %}
      {%- endcase -%}
    </div>

    <style>
      .landing-page-container { background: #fff; min-height: 100vh; padding-bottom: 100px; }
      {% if is_landing_mode %}
        header.site-header, 
        .announcement-bar,
        #shopify-section-header,
        #shopify-section-announcement-bar,
        #shopify-section-hero,
        .collection-hero,
        .skip-to-content-link { 
          display: none !important; 
        }
        .collection-page { padding-top: 0 !important; }
        #MainContent { padding-top: 0 !important; }
      {% endif %}
    </style>

  {% else %}
    <!-- STANDARD COLLECTION GRID MODE -->
    <div class="collection-main">
      <div class="collection-grid-rhode" id="product-collection-scroll">
        
        {% comment %} 1. Hardcoded NEW PRODUCTS {% endcomment %}
        <div class="card card-rhode" data-category="korean-glass-skin">
           <a href="/products/oil-to-foam-cleanser" class="card-link-wrapper">
             <img src="{{ 'oil-to-foam-hover.jpg' | asset_url }}" class="card-hover-bg" alt="Oil to Foam Cleanser Hover">
             <div class="card-rhode-top"><span class="card-brand-label">oil-to-foam</span></div>
             <div class="card-rhode-image"><img src="{{ 'oil-to-foam-main.jpg' | asset_url }}" alt="Oil to Foam Cleanser" class="product-main-img"></div>
             <div class="card-rhode-footer">
               <div class="card-meta"><h3 class="card-name">OIL TO FOAM CLEANSER (makeup removal)</h3></div>
               <span class="btn-rhode-buy-pill">BUY - RS. 2,820</span>
             </div>
             <div class="buy-button-hover" data-handle="oil-to-foam-cleanser">BUY OIL TO FOAM CLEANSER (makeup removal) - RS. 2,820</div>
           </a>
        </div>
        <div class="card card-rhode" data-category="korean-glass-skin">
           <a href="/products/skin-refining-toner" class="card-link-wrapper">
             <img src="{{ 'skin-refining-toner-hover.jpg' | asset_url }}" class="card-hover-bg" alt="Skin Refining Toner Hover">
             <div class="card-rhode-top"><span class="card-brand-label">toner</span></div>
             <div class="card-rhode-image"><img src="{{ 'skin-refining-toner-main.jpeg' | asset_url }}" alt="Skin Refining Toner" class="product-main-img"></div>
             <div class="card-rhode-footer">
               <div class="card-meta"><h3 class="card-name">SKIN REFINING TONER</h3></div>
               <span class="btn-rhode-buy-pill">BUY - RS. 2,780</span>
             </div>
             <div class="buy-button-hover" data-handle="skin-refining-toner">BUY SKIN REFINING TONER - RS. 2,780</div>
           </a>
        </div>
        <div class="card card-rhode" data-category="hair-care">
           <a href="/products/hair-regrow-spray" class="card-link-wrapper">
             <img src="{{ 'hair-regrow-hover.jpg' | asset_url }}" class="card-hover-bg" alt="Hair Regrow Spray Hover">
             <div class="card-rhode-top"><span class="card-brand-label">regrow-spray</span></div>
             <div class="card-rhode-image"><img src="{{ 'hair-regrow-main.jpeg' | asset_url }}" alt="Hair Regrow Spray" class="product-main-img"></div>
             <div class="card-rhode-footer">
               <div class="card-meta"><h3 class="card-name">HAIR REGROW SPRAY</h3></div>
               <span class="btn-rhode-buy-pill">BUY - RS. 2,790</span>
             </div>
             <div class="buy-button-hover" data-handle="hair-regrow-spray">BUY HAIR REGROW SPRAY - RS. 2,790</div>
           </a>
        </div>

        {% comment %} 2. Fallback List (Featured Collection) {% endcomment %}
        {%- assign f_names = "Centella Night Cream,Tranexamic Brightening Serum,Anti Frizz Keratin Serum,Glow Serum,Glutathione Brightening Cream,Floral Blossom Hair Mist,Centella Face Wash,Anti Acne Serum ( Tea Tree Oil),Tinted Centella Sunscreen SPF 60+,Korean Brightening Cleanser,Centella Hydra Moisturizer,Glycolic Renewal Toner" | split: "," -%}
        {%- assign f_handles = "night-cream,tranexamic-serum,anti-frizz-keratin-serum,e7-korean-glass-skin-centella-sunscreen-spf50-copy,glutathione-cream,floral-blossom-hair-mist,e7-korean-glass-skin-centella-night-cream-copy,anti-acne,e7-korean-glass-skin-centella-face-wash-copy,renewal-cleanser,centella-moisturizer,renewal-toner" | split: "," -%}
        {%- assign f_images = "night-cream.jpg,tranexamic-serum.jpg,keratin-serum.jpg,glow-serum-100.jpg,glutathione-cream-100.jpg,hair-mist.jpg,facewash-100.jpg,anti-acne-100.jpg,sunscreen-100.jpg,rc-gal-1.jpg,moisturizer-100.jpg,renewal toner-100.jpg" | split: "," -%}
        {%- assign f_hovers = "night-cream-hover.jpg,tranexamic-meet-1.jpg,keratin-serum-hover.jpg,glow-serum-hover.jpg,deep-hydration-100.jpg,hair-mist-hover.jpg,deep-hydration-facewash.jpg,hover-anti-acne.png,sunscreen-hover.jpg,rc-gal-2.jpg,moisturizer-hover.jpg,toner-hover.jpg" | split: "," -%}
        {%- assign f_labels = "featured korean-glass-skin,featured korean-brightening,featured hair-care,featured korean-glass-skin,featured korean-brightening,featured hair-care,featured korean-glass-skin,featured anti-acne,featured korean-glass-skin,featured korean-brightening,featured korean-glass-skin,featured" | split: "," -%}
        
        {% for i in (0..11) %}
          {%- assign pname = f_names[i] -%}
          {%- assign phandle = f_handles[i] -%}
          {%- assign cur_p = all_products[phandle] -%}
          {%- assign pimg = f_images[i] | asset_url -%}
          {%- assign phov = f_hovers[i] | asset_url -%}
          {%- assign plab = f_labels[i] -%}

          {%- assign c_price = "2,620" -%}
          {%- case phandle -%}
            {%- when 'night-cream' -%}{%- assign c_price = "2,675" -%}
            {%- when 'tranexamic-serum' -%}{%- assign c_price = "2,740" -%}
            {%- when 'anti-frizz-keratin-serum' -%}{%- assign c_price = "2,680" -%}
            {%- when 'e7-korean-glass-skin-centella-sunscreen-spf50-copy' -%}{%- assign c_price = "2,645" -%}
            {%- when 'glutathione-cream' -%}{%- assign c_price = "2,640" -%}
            {%- when 'floral-blossom-hair-mist' -%}{%- assign c_price = "2,960" -%}
            {%- when 'e7-korean-glass-skin-centella-night-cream-copy' -%}{%- assign c_price = "2,620" -%}
            {%- when 'anti-acne' -%}{%- assign c_price = "2,755" -%}
            {%- when 'e7-korean-glass-skin-centella-face-wash-copy' -%}{%- assign c_price = "2,735" -%}
            {%- when 'renewal-cleanser' -%}{%- assign c_price = "2,820" -%}
            {%- when 'centella-moisturizer' -%}{%- assign c_price = "2,680" -%}
            {%- when 'renewal-toner' -%}{%- assign c_price = "2,780" -%}
          {%- endcase -%}

          {%- assign bundle_href = "/products/" | append: phandle -%}
          {%- if phandle == 'elaris-7-korean-hair-care-bundle' or phandle == 'hair-care' -%}
            {%- assign bundle_href = "/collections/hair-care" -%}
          {%- elsif phandle == 'elaris-7-korean-glass-skin-bundle' or phandle == 'korean-glass-skin' -%}
            {%- assign bundle_href = "/collections/korean-glass-skin" -%}
          {%- elsif phandle == 'elaris-7-korean-brightening-bundle' or phandle == 'korean-brightening' -%}
            {%- assign bundle_href = "/collections/korean-brightening" -%}
          {%- endif -%}

          <div class="card card-rhode" data-category="{{ plab }}">
             <a href="{{ bundle_href }}" class="card-link-wrapper">
               {% if phov != blank and phov != 'none' %}<img src="{{ phov }}" class="card-hover-bg" alt="Hover">{% endif %}
               <div class="card-rhode-top"><span class="card-brand-label">{{ plab | split: ' ' | last }}</span></div>
               <div class="card-rhode-image"><img src="{{ pimg }}" class="product-main-img" alt="{{ pname }}"></div>
               <div class="card-rhode-footer">
                 <div class="card-meta"><h3 class="card-name">{{ pname | upcase }}</h3></div>
                 <span class="btn-rhode-buy-pill">BUY - RS. {{ c_price }}</span>
               </div>
               <div class="buy-button-hover" data-handle="{{ phandle }}">BUY {{ pname | upcase }} - RS. {{ c_price }}</div>
             </a>
          </div>
        {% endfor %}

        {% comment %} 3. Bundle Cards {% endcomment %}
        <div class="card card-rhode bundle-card" data-category="set" onclick="window.location.href='/collections/korean-glass-skin'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
          <img src="{{ 'glassskinbundle.jpeg' | asset_url }}" class="bundle-card-img" style="width: 100%; height: 100%; object-fit: cover;">
          <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); padding: 18px 15px; border-top: 1px solid #eee; text-align: center;">
            <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0 0 5px;">Korean Glass Skin Bundle</h3>
            <div style="margin-bottom: 8px;"><span style="font-size: 11px; text-decoration: line-through; color: #999; margin-right: 8px;">RS. 13,354</span><span style="font-size: 13px; font-weight: 800; color: #2c2b28;">RS. 6,677</span></div>
            <span style="font-size: 10px; font-weight: 800; color: #555; text-transform: uppercase; border: 1px solid #555; padding: 4px 10px; border-radius: 20px;">SHOP THE SET</span>
          </div>
        </div>
        <div class="card card-rhode bundle-card" data-category="set" onclick="window.location.href='/collections/korean-brightening'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
          <img src="{{ 'main.jpg' | file_img_url: '600x' }}" class="bundle-card-img" style="width: 100%; height: 100%; object-fit: cover;">
          <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); padding: 18px 15px; border-top: 1px solid #eee; text-align: center;">
            <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0 0 5px;">Korean Brightening Bundle</h3>
            <div style="margin-bottom: 8px;"><span style="font-size: 11px; text-decoration: line-through; color: #999; margin-right: 8px;">RS. 10,784</span><span style="font-size: 13px; font-weight: 800; color: #2c2b28;">RS. 5,392</span></div>
            <span style="font-size: 10px; font-weight: 800; color: #555; text-transform: uppercase; border: 1px solid #555; padding: 4px 10px; border-radius: 20px;">SHOP THE SET</span>
          </div>
        </div>
        <div class="card card-rhode bundle-card" data-category="set" onclick="window.location.href='/collections/hair-care'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
          <img src="{{ 'hairmain.jpg' | file_img_url: '600x' }}" class="bundle-card-img" style="width: 100%; height: 100%; object-fit: cover;">
          <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); padding: 18px 15px; border-top: 1px solid #eee; text-align: center;">
            <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0 0 5px;">Hair Care Bundle</h3>
            <div style="margin-bottom: 8px;"><span style="font-size: 11px; text-decoration: line-through; color: #999; margin-right: 8px;">RS. 8,430</span><span style="font-size: 13px; font-weight: 800; color: #2c2b28;">RS. 4,215</span></div>
            <span style="font-size: 10px; font-weight: 800; color: #555; text-transform: uppercase; border: 1px solid #555; padding: 4px 10px; border-radius: 20px;">SHOP THE SET</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
  /* Standard Styles */
  .collection-page { background: #f1efea; min-height: 100vh; }
  .collection-nav-bar { border-bottom: 1px solid rgba(91,90,83,0.1); background: #fff; position: sticky; top: 0; z-index: 1000; }
  .collection-nav-inner { max-width: 1200px; margin: 0 auto; padding: 15px 40px; overflow-x: auto; scrollbar-width: none; }
  .collection-pills { display: flex; gap: 15px; justify-content: center; white-space: nowrap; }
  .coll-pill { text-decoration: none; font-size: 0.72rem; font-weight: 800; color: #5b5a53; padding: 10px 24px; border-radius: 50px; border: 1px solid #e5e5e5; transition: all 0.3s ease; }
  .coll-pill.active { background: #5b5a53; color: #fff; border-color: #5b5a53; }
  .collection-main { max-width: 1400px; margin: 0 auto; padding: 40px; }
  
  /* Rhode Grid Style */
  .collection-grid-rhode {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding: 0;
  }
  
  .collection-grid-rhode .card-rhode {
    width: 100% !important;
    flex: none !important;
    scroll-snap-align: none !important;
    display: flex !important; /* Default show, JS will hide */
  }

  @media (max-width: 1100px) {
    .collection-grid-rhode { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 850px) {
    .collection-grid-rhode { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .collection-main { padding: 20px 12px; }
    .collection-nav-inner { padding: 12px 10px; }
    .collection-pills { justify-content: flex-start; padding-left: 10px; padding-right: 10px; }
  }
  @media (max-width: 500px) {
    .collection-grid-rhode { grid-template-columns: 1fr; }
  }

  /* Mobile Banner Styles */
  .coll-mobile-banner { width: 100%; aspect-ratio: 4/5; background: #f1efea; }
  .coll-mobile-banner img { width: 100%; height: 100%; object-fit: cover; display: block; }
  
  @media (min-width: 769px) {
    .coll-mobile-banner { display: none !important; }
  }
</style>


