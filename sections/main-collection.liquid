{% schema %}
{
  "name": "Main Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}

<div class="collection-page">
  {%- assign special_handles = "korean-glass-skin,anti-acne,korean-brightening,hair-care" | split: "," -%}
  {%- assign is_special = false -%}
  {% if special_handles contains collection.handle %}
    {%- assign is_special = true -%}
    {%- case collection.handle -%}
      {%- when 'korean-glass-skin' -%}{%- assign target_prod = all_products['elaris-7-korean-glass-skin-bundle'] -%}
      {%- when 'anti-acne' -%}{%- assign target_prod = all_products['elaris-7-anti-acne-bundle'] -%}
      {%- when 'korean-brightening' -%}{%- assign target_prod = all_products['elaris-7-korean-brightening-bundle'] -%}
      {%- when 'hair-care' -%}{%- assign target_prod = all_products['elaris-7-korean-hair-care-bundle'] -%}
    {%- endcase -%}
  {% endif %}

  <div class="collection-nav-bar">
    <div class="collection-nav-inner">
       {%- assign cats = "Featured,Korean Glass Skin,Anti Acne,Korean Brightening,Hair Care,Sets" | split: "," -%}
       <div class="collection-pills">
         {% for cat in cats %}
           {%- assign c_handle = cat | handleize -%}
           <a href="/collections/{{ c_handle }}" class="coll-pill {% if collection.handle == c_handle %}active{% endif %}">
             {{ cat | uppercase }}
           </a>
         {% endfor %}
       </div>
    </div>
  </div>

  {% if is_special and target_prod != blank %}
    <!-- SPECIAL PRODUCT LANDING MODE -->
    <div class="special-product-landing">
      <div class="landing-grid">
        <div class="landing-gallery">
          <div class="sticky-gallery">
            <img src="{{ target_prod.featured_image | img_url: 'master' }}" alt="{{ target_prod.title }}" class="main-landing-img">
          </div>
        </div>
        <div class="landing-details">
          <div class="badge-row"><span class="landing-brand">ELARIS7</span> <span class="stars">★ ★ ★ ★ ★ (16k+)</span></div>
          <h1 class="landing-title">{{ target_prod.title | upcase }}</h1>
          <div class="landing-price-row">{{ target_prod.price | money }}</div>
          
          <div class="landing-desc">
            {{ target_prod.description }}
          </div>
          
          <div class="landing-actions">
            {%- form 'product', target_prod -%}
              <input type="hidden" name="id" value="{{ target_prod.selected_or_first_available_variant.id }}">
              <button type="submit" class="landing-btn primary">ADD TO BAG — {{ target_prod.price | money }}</button>
            {%- endform -%}
          </div>
          
          <div class="landing-specs">
             <details open>
               <summary>BENEFITS <span class="icon">+</span></summary>
               <div class="content">
                 <ul>
                   <li>Dermatologist Tested</li>
                   <li>Sulfate & Paraben Free</li>
                   <li>Vegan & Cruelty Free</li>
                   <li>High Performance Formula</li>
                 </ul>
               </div>
             </details>
             <details>
               <summary>HOW TO USE <span class="icon">+</span></summary>
               <div class="content">Apply daily for best results. Follow with your favorite Elaris routine.</div>
             </details>
          </div>
        </div>
      </div>
    </div>
    
    <style>
      .special-product-landing { padding: 80px 40px; background: #f1efea; }
      .landing-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 60px; max-width: 1300px; margin: 0 auto; align-items: start; }
      .sticky-gallery { position: sticky; top: 120px; border-radius: 20px; overflow: hidden; background: #fff; padding: 40px; }
      .main-landing-img { width: 100%; height: auto; display: block; mix-blend-mode: multiply; }
      .landing-brand { font-weight: 800; font-size: 0.65rem; color: #fff; background: #000; padding: 4px 12px; border-radius: 50px; }
      .stars { font-size: 0.7rem; color: #ccc; margin-left: 10px; }
      .landing-title { font-size: 3.5rem; font-weight: 950; color: #1a1a1a; margin: 20px 0; line-height: 0.95; letter-spacing: -0.04em; }
      .landing-price-row { font-size: 1.5rem; font-weight: 700; color: #5b5a53; margin-bottom: 30px; }
      .landing-desc { font-size: 1.05rem; line-height: 1.8; color: #444; margin-bottom: 40px; }
      .landing-btn.primary { width: 100%; background: #5b5a53; color: #fff; border: none; padding: 22px; border-radius: 50px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: all 0.3s; }
      .landing-btn.primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
      
      .landing-specs { margin-top: 50px; border-top: 1px solid #ddd; }
      .landing-specs details { border-bottom: 1px solid #ddd; }
      .landing-specs summary { list-style: none; padding: 25px 0; font-weight: 800; font-size: 0.9rem; cursor: pointer; display: flex; justify-content: space-between; }
      .landing-specs .content { padding-bottom: 25px; color: #666; font-size: 0.95rem; line-height: 1.6; }
      
      @media (max-width: 900px) {
        .landing-grid { grid-template-columns: 1fr; gap: 40px; }
        .landing-title { font-size: 2.2rem; }
        .special-product-landing { padding: 40px 20px; }
        .sticky-gallery { padding: 20px; }
      }
    </style>

  {% else %}
    <!-- STANDARD COLLECTION GRID MODE -->
    <div class="collection-main">
      {%- assign featured_handles = "night-cream,tranexamic-serum,anti-frizz-keratin-serum,e7-korean-glass-skin-centella-sunscreen-spf50-copy,glutathione-cream,floral-blossom-hair-mist,e7-korean-glass-skin-centella-night-cream-copy,anti-acne-cream,e7-korean-glass-skin-centella-face-wash-copy,centella-skin-toner-copy,e7-korean-glass-skin-moisturizer,centella-skin-toner,e7-glass-skin-set,e7-complete-glass-skin-set,e7-hair-care-set,elaris-7-korean-brightening-bundle" | split: "," -%}
      {%- assign fallback_names = "Night Cream,Tranexamic Serum,Anti Frizz Keratin Serum,Glow Serum,Glutathione Cream,Floral Blossom Hair Mist,Face Wash,Anti Acne,Sunscreen,Renewal Cleanser,Hydra Burst Moisturizer,Renewal Toner,E7 Glass Skin Set,E7 Complete Glass Skin Set,E7 Hair Care Set,Elaris 7 Korean Brightening Bundle" | split: "," -%}
      {%- assign fallback_images = "night-cream.jpg,tranexamic-serum.jpg,keratin-serum.jpg,glow-serum-100.jpg,glutathione-cream-100.jpg,hair-mist.jpg,facewash-100.jpg,anti-acne-100.jpg,sunscreen-100.jpg,gel cleanser-100.jpg,moisturizer-100.jpg,toner1.jpeg,new-bundle-banner.jpg,new-bundle-banner.jpg,new-bundle-banner.jpg,new-bundle-banner.jpg" | split: "," -%}
      {%- assign fallback_hovers = "night-cream-hover.jpg,tranexamic-meet-1.jpg,keratin-serum-hover.jpg,glow-serum-hover.jpg,deep-hydration-100.jpg,hair-mist-hover.jpg,deep-hydration-facewash.jpg,hover-anti-acne.png,model.png,,,,new-bundle-banner.jpg,new-bundle-banner.jpg,new-bundle-banner.jpg,new-bundle-banner.jpg" | split: "," -%}
      {%- assign fallback_prices = "Rs. 2,500,Rs. 2,800,Rs. 2,700,Rs. 2,540,Rs. 2,950,Rs. 2,400,Rs. 2,200,Rs. 2,450,Rs. 2,630,Rs. 2,850,Rs. 2,499,Rs. 2,670,Rs. 4,500,Rs. 7,500,Rs. 3,200,Rs. 5,900" | split: "," -%}

      {% paginate collection.products by section.settings.products_per_page %}
        <div class="collection-grid">
          {% for product in collection.products %}
            {% if collection.handle == 'all' %}
              {% unless featured_handles contains product.handle %}
                {% continue %}
              {% endunless %}
            {% endif %}

            {%- assign p_index = -1 -%}
            {% for fh in featured_handles %}
              {% if fh == product.handle %}
                {%- assign p_index = forloop.index0 -%}
                {% break %}
              {% endif %}
            {% endfor %}

            {%- assign p_img = product.featured_image | image_url: width: 800 -%}
            {%- assign h_img = product.images[1] | image_url: width: 800 -%}
            {%- assign p_price = product.price | money -%}

            {% if p_index != -1 %}
              {%- assign p_img = fallback_images[p_index] | asset_url -%}
              {% if fallback_hovers[p_index] != blank %}
                {%- assign h_img = fallback_hovers[p_index] | asset_url -%}
              {% endif %}
              {%- assign p_price = fallback_prices[p_index] -%}
            {% endif %}

            <div class="coll-item">
              <a href="{{ product.url }}" class="coll-card">
                <div class="coll-image">
                  <img src="{{ p_img }}" alt="{{ product.title }}" loading="lazy" class="main-img">
                  {% if h_img != blank %}
                    <img src="{{ h_img }}" alt="{{ product.title }}" loading="lazy" class="hover-img">
                  {% else %}
                    <img src="{{ p_img }}" alt="{{ product.title }}" loading="lazy" class="hover-img">
                  {% endif %}
                  <div class="coll-badge-top">
                     <div class="coll-brand">ELARIS7</div>
                  </div>
                  <div class="coll-buy-btn quick-add-btn" data-variant-id="{{ product.first_available_variant.id }}">
                      BUY NOW — {{ p_price }}
                  </div>
                </div>
                <div class="coll-info">
                   <div class="coll-stars">★ ★ ★ ★ ★ (16k)</div>
                   <h3 class="coll-title">{{ product.title | upcase }}</h3>
                   <p class="coll-price">{{ p_price }}</p>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  {% endif %}
</div>

<style>
.collection-page { background: #f1efea; min-height: 100vh; }
.collection-nav-bar { border-bottom: 1px solid rgba(91,90,83,0.1); background: #fff; position: sticky; top: 0; z-index: 1000; }
.collection-nav-inner { max-width: 1200px; margin: 0 auto; padding: 15px 40px; overflow-x: auto; scrollbar-width: none; }
.collection-nav-inner::-webkit-scrollbar { display: none; }
.collection-pills { display: flex; gap: 15px; justify-content: center; white-space: nowrap; }
.coll-pill { text-decoration: none; font-size: 0.72rem; font-weight: 800; color: #5b5a53; padding: 10px 24px; border-radius: 50px; border: 1px solid #e5e5e5; transition: all 0.3s ease; }
.coll-pill:hover { border-color: #5b5a53; }
.coll-pill.active { background: #5b5a53; color: #fff; border-color: #5b5a53; }

.collection-main { max-width: 1400px; margin: 0 auto; padding: 60px 40px; }
.collection-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
.coll-card { text-decoration: none; display: flex; flex-direction: column; position: relative; background: #fff; border-radius: 8px; overflow: hidden; transition: transform 0.3s ease; }
.coll-image { aspect-ratio: 1/1.3; position: relative; overflow: hidden; }
.coll-image .main-img { width: 100%; height: 100%; object-fit: contain; padding: 30px; transition: opacity 0.4s ease; mix-blend-mode: multiply; }
.coll-image .hover-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease; }
.coll-card:hover .hover-img { opacity: 1; }
.coll-card:hover .main-img { opacity: 0; }
.coll-badge-top { position: absolute; top: 15px; left: 15px; z-index: 5; }
.coll-brand { font-size: 0.6rem; font-weight: 800; color: #fff; background: #000; padding: 4px 10px; border-radius: 20px; }
.coll-info { padding: 16px 20px; text-align: left; }
.coll-stars { font-size: 0.65rem; color: #c4c4c4; margin-bottom: 6px; }
.coll-title { font-size: 0.8rem; font-weight: 900; color: #333; margin-bottom: 4px; letter-spacing: 0.05em; line-height: 1.2; }
.coll-price { font-size: 0.75rem; font-weight: 700; color: #5b5a53; }
.coll-buy-btn { position: absolute; bottom: 0; left: 0; width: 100%; background: rgba(91,90,83,0.9); backdrop-filter: blur(6px); color: #fff; text-align: center; padding: 16px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0; transform: translateY(100%); transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1); z-index: 10; }
.coll-card:hover .coll-buy-btn { opacity: 1; transform: translateY(0); }

.pagination { margin-top: 50px; text-align: center; }
.pagination a, .pagination span { padding: 10px 18px; border: 1px solid #ddd; margin: 0 4px; border-radius: 4px; text-decoration: none; color: #333; font-weight: 600; }
.pagination .current { background: #5b5a53; color: #fff; border-color: #5b5a53; }

@media (max-width: 1024px) { .collection-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) {
  .collection-main { padding: 30px 16px; }
  .collection-grid { grid-template-columns: 1fr; gap: 20px; }
  .collection-nav-inner { padding: 12px 16px; }
  .collection-pills { justify-content: flex-start; }
  .coll-buy-btn { opacity: 1; transform: translateY(0); width: 85%; left: 50%; transform: translateX(-50%); bottom: 15px; border-radius: 50px; font-size: 0.7rem; }
}
</style>
