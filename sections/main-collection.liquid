{% schema %}
{
  "name": "Main Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}

<div class="collection-page">
  <div class="collection-header">
    <div class="collection-hero-content">
       <h1 class="collection-title">{{ collection.title | uppercase }}</h1>
       {% if collection.description != blank %}
         <div class="collection-desc">{{ collection.description }}</div>
       {% endif %}
    </div>
  </div>

  <div class="collection-nav-bar">
    <div class="collection-nav-inner">
       {%- assign cats = "Featured,Korean Glass Skin,Anti Acne,Korean Brightening,Hair Care,Sets" | split: "," -%}
       <div class="collection-pills">
         {% for cat in cats %}
           {%- assign c_handle = cat | handleize -%}
           <a href="/collections/{{ c_handle }}" class="coll-pill {% if collection.handle == c_handle %}active{% endif %}">
             {{ cat | uppercase }}
           </a>
         {% endfor %}
       </div>
    </div>
  </div>

  <div class="collection-main">
    {% paginate collection.products by section.settings.products_per_page %}
      <div class="collection-grid">
        {% for product in collection.products %}
           <div class="coll-item">
             <a href="{{ product.url }}" class="coll-card">
               <div class="coll-image">
                 <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy" class="main-img">
                 {% if product.images[1] != blank %}
                   <img src="{{ product.images[1] | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy" class="hover-img">
                 {% endif %}
                 <div class="coll-badge-top">
                   <div class="coll-brand">ELARIS7</div>
                 </div>
               </div>
               <div class="coll-info">
                 <div class="coll-stars">★ ★ ★ ★ ★ (16k)</div>
                 <h3 class="coll-title">{{ product.title | upcase }}</h3>
                 <p class="coll-price">{{ product.price | money }}</p>
               </div>
               <div class="coll-buy-btn">
                  BUY - {{ product.price | money }}
               </div>
             </a>
           </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

<style>
.collection-page {
  background: #f1efea;
  min-height: 100vh;
}

.collection-header {
  padding: 100px 40px 60px;
  text-align: center;
}

.collection-title {
  font-size: 2.8rem;
  font-weight: 800;
  color: #5b5a53;
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}

.collection-desc {
  font-size: 0.95rem;
  color: #8c8b84;
  max-width: 600px;
  margin: 0 auto;
}

.collection-nav-bar {
  border-top: 1px solid rgba(91,90,83,0.1);
  border-bottom: 1px solid rgba(91,90,83,0.1);
  background: #fff;
  position: sticky;
  top: 70px;
  z-index: 100;
}

.collection-nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 15px 40px;
  overflow-x: auto;
  scrollbar-width: none;
}
.collection-nav-inner::-webkit-scrollbar { display: none; }

.collection-pills {
  display: flex;
  gap: 15px;
  justify-content: center;
  white-space: nowrap;
}

.coll-pill {
  text-decoration: none;
  font-size: 0.7rem;
  font-weight: 700;
  color: #5b5a53;
  padding: 8px 24px;
  border-radius: 50px;
  border: 1px solid #e5e5e5;
  transition: all 0.3s ease;
}

.coll-pill:hover { border-color: #5b5a53; }
.coll-pill.active {
  background: #5b5a53;
  color: #fff;
  border-color: #5b5a53;
}

.collection-main {
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px 40px;
}

.collection-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
}

.coll-card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  position: relative;
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.3s ease;
}

.coll-image {
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  padding: 30px;
}

.coll-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.4s ease;
}

.coll-image .hover-img {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  padding: 30px;
}

.coll-card:hover .hover-img { opacity: 1; }
.coll-card:hover .main-img { opacity: 0; }

.coll-badge-top {
  position: absolute;
  top: 15px;
  left: 15px;
}

.coll-brand {
  font-size: 0.6rem;
  font-weight: 800;
  color: #fff;
  background: #000;
  padding: 4px 10px;
  border-radius: 20px;
}

.coll-info {
  padding: 20px;
  text-align: left;
}

.coll-stars {
  font-size: 0.65rem;
  color: #c4c4c4;
  margin-bottom: 8px;
}

.coll-title {
  font-size: 0.8rem;
  font-weight: 800;
  color: #333;
  margin-bottom: 5px;
  letter-spacing: 0.05em;
}

.coll-price {
  font-size: 0.75rem;
  font-weight: 600;
  color: #8c8b84;
}

.coll-buy-btn {
  background: #5b5a53;
  color: #fff;
  text-align: center;
  padding: 15px;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0;
  transform: translateY(100%);
  transition: all 0.4s ease;
}

.coll-card:hover .coll-buy-btn {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 1024px) {
  .collection-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .collection-header { padding: 80px 20px 40px; }
  .collection-title { font-size: 2rem; }
  .collection-nav-inner { justify-content: flex-start; }
}
</style>
