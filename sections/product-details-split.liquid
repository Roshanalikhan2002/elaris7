{%- style -%}
  .details-split-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 16px 60px 16px;
  }
  .ds-left {
    background-color: #f3f0ec;
    border-radius: 14px;
    padding: 60px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ds-title {
    font-size: 2rem;
    font-weight: 500;
    color: #6a6863;
    margin: 0 0 60px 0;
    line-height: 1.3;
    letter-spacing: -0.02em;
    max-width: 90%;
  }
  .ds-list {
    display: flex;
    flex-direction: column;
  }
  .ds-row {
    display: flex;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid rgba(91,90,83,0.15);
    font-size: 0.85rem;
    color: #5b5a53;
  }
  .ds-row:last-child {
    border-bottom: none;
  }
  .ds-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex: 0 0 80px;
  }
  .ds-value {
    text-align: right;
    line-height: 1.5;
    flex: 1;
  }
  .ds-right {
    border-radius: 14px;
    overflow: hidden;
    display: flex;
  }
  .ds-image {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .details-split-section {
      display: flex !important;
      flex-direction: column !important;
      gap: 0 !important;
      margin: 0 !important;
    }
    .ds-left {
      padding: 40px 24px;
      border-radius: 0 !important;
      margin-top: 0 !important;
    }
    .ds-right {
      order: -1;
      border-radius: 0 !important;
      margin-bottom: 0 !important;
    }
    .ds-image {
      min-height: 350px;
      border-radius: 0 !important;
      margin-bottom: 0 !important;
      display: block;
    }
  }
{%- endstyle -%}

