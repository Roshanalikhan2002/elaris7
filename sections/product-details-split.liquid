<section class="details-split-section">
  <div class="ds-left">
    <h2 class="ds-title">{{ ds_title | default: section.settings.title }}</h2>
    <div class="ds-list">
        {%- if use_custom_list -%}
          {{ ds_list_content }}
        {%- elsif section.blocks.size > 0 -%}
          {% for block in section.blocks %}
            <div class="ds-row">
              <div class="ds-label">{{ block.settings.label }}</div>
              <div class="ds-value">{{ block.settings.value }}</div>
            </div>
          {% endfor %}
        {%- else -%}
          <div class="ds-row">
            <div class="ds-label">GOOD FOR:</div>
            <div class="ds-value">All skin types, including dry and sensitive skin</div>
          </div>
        {%- endif -%}
    </div>
  </div>
  <div class="ds-right">
    {%- if ds_image_name != blank -%}
      <img class="ds-image" src="{{ ds_image_name | asset_url }}" alt="{{ product.title }}">
    {%- elsif ds_image != blank -%}
      {{ ds_image | image_url: width: 1000 | image_tag: class: 'ds-image', alt: ds_title }}
    {%- else -%}
      <img class="ds-image" src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?q=80&w=1000" alt="Glossier Cosmetic Layout">
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Details Split",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "A creamy blush for BUILDABLE color + BABY-SOFT cheeks."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    }
  ],
  "blocks": [
    {
      "type": "detail_row",
      "name": "Detail Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. GOOD FOR:)"
        },
        {
          "type": "textarea",
          "id": "value",
          "label": "Value (e.g. All skin types)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Details Split"
    }
  ]
}
{% endschema %}
