{% schema %}
{
  "name": "Product Details Split",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "A creamy blush for BUILDABLE color + BABY-SOFT cheeks."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    }
  ],
  "blocks": [
    {
      "type": "detail_row",
      "name": "Detail Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. GOOD FOR:)"
        },
        {
          "type": "textarea",
          "id": "value",
          "label": "Value (e.g. All skin types)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Details Split"
    }
  ]
}
{% endschema %}
