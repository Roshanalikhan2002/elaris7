<div class="product-scroll-wrapper">
  <div class="product-scroll-header">
    <span class="product-scroll-count">
      {% if section.blocks.size > 0 %}
        {{ section.blocks.size }} products
      {% elsif collections[section.settings.collection] != blank %}
        {{ collections[section.settings.collection].products_count }} products
      {% endif %}
    </span>
    <div class="scroll-arrow-btn" id="scroll-right-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </div>
  </div>

  <section id="shop">
    <div class="product-collection" id="product-collection-scroll">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="card-rhode" {{ block.shopify_attributes }}>
            {% if block.settings.hover_image != blank %}
              {{ block.settings.hover_image | image_url: width: 1000 | image_tag: class: 'card-hover-bg', alt: block.settings.title }}
            {% endif %}
            
            <div class="card-rhode-top">
              <div class="card-brand-label">{{ block.settings.brand_label | lowercase | default: 'skincare' }}</div>
              {% if block.settings.badge != blank %}
                <span class="card-badge">{{ block.settings.badge | lowercase }}</span>
              {% endif %}
            </div>

            <div class="card-rhode-image">
              {% if block.settings.main_image != blank %}
                {{ block.settings.main_image | image_url: width: 800 | image_tag: alt: block.settings.title }}
              {% else %}
                <div class="product-placeholder-img"></div>
              {% endif %}
            </div>

            <div class="card-rhode-details">
              <div class="stars">★ ★ ★ ★ ★ ({{ block.settings.reviews | default: '14k' }})</div>
              <div class="product-name-row">
                <h3 class="card-product-title">{{ block.settings.title | upcase }}</h3>
                <span class="card-price">{{ block.settings.price }}</span>
              </div>
              <p class="card-subtitle">{{ block.settings.subtitle }}</p>
            </div>

            <div class="buy-button-hover">
               BUY {{ block.settings.title | upcase }} - {{ block.settings.price }}
            </div>
          </div>
        {% endfor %}
      {% elsif collections[section.settings.collection].products.size > 0 %}
        {% assign limit_count = section.settings.product_limit | default: 15 %}
        {% for product in collections[section.settings.collection].products limit: limit_count %}
          <a href="{{ product.url }}" class="card-rhode">
            {% if product.images.size > 1 %}
              {{ product.images[1] | image_url: width: 1000 | image_tag: class: 'card-hover-bg', alt: product.title }}
            {% endif %}
            
            <div class="card-rhode-top">
              <div class="card-brand-label">{{ product.type | lowercase | default: 'skincare' }}</div>
              {% if product.tags contains 'new' or product.tags contains 'New' %}
                <span class="card-badge">new shades</span>
              {% elsif product.tags contains 'limited' %}
                <span class="card-badge">limited edition</span>
              {% endif %}
            </div>

            <div class="card-rhode-image">
              {{ product.featured_image | image_url: width: 800 | image_tag: alt: product.title }}
            </div>

            <div class="card-rhode-details">
              <div class="stars">★ ★ ★ ★ ★ ({{ product.metafields.reviews.rating_count | default: '16k' }})</div>
              <div class="product-name-row">
                <h3 class="card-product-title">{{ product.title | upcase }}</h3>
                <span class="card-price">{{ product.price | money }}</span>
              </div>
              <p class="card-subtitle">{{ product.description | truncate: 50 }}</p>
            </div>

            <div class="buy-button-hover">
               BUY {{ product.title | upcase }} - {{ product.price | money }}
            </div>
          </a>
        {% endfor %}
      {% else %}
        {%- assign fallback_names = "Anti Acne Serum,Glass Skin Toner,Barrier Cream,Peptide Serum,Niacinamide Essence,Hyaluronic Mist,SPF 50 Sunscreen,Vitamin C Serum,Retinol Night Cream,Ceramide Moisturiser,AHA Exfoliant,Eye Cream,Lip Balm,Cleansing Balm,Glow Booster" | split: "," -%}
        {% for i in (1..15) %}
          {%- assign pname = fallback_names[forloop.index0] -%}
          <div class="card-rhode">
            {% if forloop.first %}
              <img src="{{ 'hover-anti-acne.png' | asset_url }}" class="card-hover-bg" alt="Hover Background">
            {% endif %}

            <div class="card-rhode-top">
              <div class="card-brand-label">antiacne</div>
              {% if forloop.first %}
                <span class="card-badge">new shades</span>
              {% endif %}
            </div>

            <div class="card-rhode-image">
              {% if forloop.first %}
                <img src="{{ 'product-anti-acne.jpg' | asset_url }}" alt="{{ pname }}">
              {% else %}
                <div class="product-placeholder-img"></div>
              {% endif %}
            </div>

            <div class="card-rhode-details">
              <div class="stars">★ ★ ★ ★ ★ (16k)</div>
              <div class="product-name-row">
                <h3 class="card-product-title">{{ pname | upcase }}</h3>
                <span class="card-price">Rs. 1,500</span>
              </div>
              <p class="card-subtitle">Premium Korean skincare formula</p>
            </div>

            <div class="buy-button-hover">
               BUY {{ pname | upcase }} - Rs. 1,500
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </section>
</div>

<script>
  (function() {
    var btn = document.getElementById('scroll-right-btn');
    var track = document.getElementById('product-collection-scroll');
    if (btn && track) {
      btn.addEventListener('click', function() {
        track.scrollBy({ left: 380, behavior: 'smooth' });
      });
      // Hide arrow when scrolled to end
      track.addEventListener('scroll', function() {
        var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
        btn.style.opacity = atEnd ? '0.3' : '1';
        btn.style.pointerEvents = atEnd ? 'none' : 'auto';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Rhode Product Scroll",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (Auto Mode)"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 15,
      "step": 1,
      "label": "Product Limit",
      "default": 15
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Manual Product Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Pocket Blush"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$25.00"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "The natural flush"
        },
        {
          "type": "text",
          "id": "brand_label",
          "label": "Top Label (e.g. blush)",
          "default": "blush"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. new shades)"
        },
        {
          "type": "text",
          "id": "reviews",
          "label": "Review Count (e.g. 6,949)",
          "default": "6,949"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Primary Image (Product)"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image (Model Portrait)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rhode Product Scroll",
      "category": "Collection"
    }
  ]
}
{% endschema %}
