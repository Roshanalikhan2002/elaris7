<section class="product-scroll-section">
  <!-- Scroll Controls -->
  <div class="product-scroll-controls desktop-only">
    <button class="scroll-arrow prev" id="scroll-prev-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    </button>
    <button class="scroll-arrow next" id="scroll-next-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
    </button>
  </div>

  <div class="product-collection" id="product-collection-scroll">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="card card-rhode" data-category="{{ block.settings.brand_label }}" {{ block.shopify_attributes }}>
          {%- assign final_link = block.settings.product_link | default: '#' -%}
          <a href="{{ final_link }}" class="card-link-wrapper">
            {% if block.settings.hover_image != blank %}
              {{ block.settings.hover_image | image_url: width: 1200 | image_tag: class: 'card-hover-bg', alt: block.settings.title }}
            {% elsif block.settings.asset_hover_image != blank %}
              <img src="{{ block.settings.asset_hover_image | asset_url }}" class="card-hover-bg" alt="Hover Background">
            {% endif %}
            
            <div class="card-rhode-top">
              <span class="card-brand-label">{{ block.settings.brand_label | default: 'nightcream' }}</span>
              {% if block.settings.badge != blank %}
                <span class="card-badge">{{ block.settings.badge }}</span>
              {% endif %}
            </div>
            <div class="card-rhode-image">
              {% if block.settings.main_image != blank %}
                {{ block.settings.main_image | image_url: width: 800 | image_tag: alt: block.settings.title, class: 'product-main-img' }}
              {% elsif block.settings.asset_image != blank %}
                <img src="{{ block.settings.asset_image | asset_url }}" alt="{{ block.settings.title }}" class="product-main-img">
              {% else %}
                <div class="product-placeholder-img"></div>
              {% endif %}
            </div>
            <div class="card-rhode-footer">
              <div class="card-meta">
                <div class="card-stars">★★★★★ <span class="review-count">({{ block.settings.reviews | default: '16k' }})</span></div>
                <h3 class="card-name">{{ block.settings.title | default: 'NIGHT CREAM' }}</h3>
              </div>
              <span class="btn-rhode-buy-pill">BUY - {{ block.settings.price | default: 'RS. 1,500' }}</span>
            </div>
            <div class="buy-button-hover" data-handle="{{ block.settings.product_link | split: '/' | last }}">
              BUY {{ block.settings.title | default: 'NIGHT CREAM' | upcase }} - {{ block.settings.price | default: 'RS. 1,500' }}
            </div>
          </a>
          
          {% if forloop.first %}
            <div class="swipe-bubble mobile-only">
              <span>swipe</span>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      {% comment %} Fallback Items if no blocks exist move move moved moves move move move move move move move move move {% endcomment %}
      {%- assign fallback_names = "Night Cream,Tranexamic Serum,Anti Frizz Keratin Serum,Glow Serum,Glutathione Cream,Floral Blossom Hair Mist,Face Wash,Anti Acne,Sunscreen SPF60+,Renewal Cleanser,Hydra Burst Moisturizer,Renewal Toner" | split: "," -%}
      {%- assign fallback_images = "night-cream.jpg,tranexamic-serum.jpg,keratin-serum.jpg,glow-serum-100.jpg,glutathione-cream-100.jpg,hair-mist.jpg,facewash-100.jpg,anti-acne-100.jpg,sunscreen-100.jpg,renewal-cleanser-1.jpg,moisturizer-100.jpg,toner1.jpeg" | split: "," -%}
      {%- assign fallback_hovers = "night-cream-hover.jpg,tranexamic-meet-1.jpg,keratin-serum-hover.jpg,glow-serum-hover.jpg,deep-hydration-100.jpg,hair-mist-hover.jpg,deep-hydration-facewash.jpg,hover-anti-acne.png,sunscreen-hover.jpg,renewal-cleanser-2.jpg,moisturizer-hover.jpg,toner-hover.jpg" | split: "," -%}
      {%- assign fallback_labels = "featured korean-glass-skin,featured korean-brightening,featured hair-care,featured korean-glass-skin,featured korean-brightening,featured hair-care,featured korean-glass-skin,featured anti-acne,featured korean-glass-skin,featured korean-glass-skin,featured korean-glass-skin,featured korean-glass-skin" | split: "," -%}
      
      {% for i in (0..11) %}
        {%- assign pname = fallback_names[i] -%}
        {%- assign phandle = pname | handleize -%}
        {%- if pname contains "Keratin Serum" -%}
          {%- assign phandle = "anti-frizz-keratin-serum" -%}
        {%- elsif pname == "Glow Serum" -%}
          {%- assign phandle = "e7-korean-glass-skin-centella-sunscreen-spf50-copy" -%}
        {%- elsif pname == "Face Wash" -%}
          {%- assign phandle = "e7-korean-glass-skin-centella-night-cream-copy" -%}
        {%- elsif pname == "Sunscreen SPF60+" -%}
          {%- assign phandle = "e7-korean-glass-skin-centella-face-wash-copy" -%}
        {%- elsif pname == "Renewal Cleanser" -%}
          {%- assign phandle = "renewal-cleanser" -%}
        {%- elsif pname == "Hydra Burst Moisturizer" -%}
          {%- assign phandle = "e7-korean-glass-skin-moisturizer" -%}
        {%- elsif pname == "Renewal Toner" -%}
          {%- assign phandle = "centella-skin-toner" -%}
        {%- elsif pname contains "Brightening Bundle" -%}
          {%- assign phandle = "elaris-7-korean-brightening-bundle" -%}
        {%- elsif pname contains "Set" or pname contains "Bundle" -%}
          {%- assign phandle = "e7-complete-glass-skin-set" -%}
        {%- endif -%}


        {%- assign current_prod = all_products[phandle] -%}
        {%- assign pimage = fallback_images[i] | asset_url -%}
        {%- if current_prod.featured_image != blank -%}
          {%- assign pimage = current_prod.featured_image | img_url: '800x800' -%}
        {%- endif -%}
        
        {%- assign phover = fallback_hovers[i] | asset_url -%}
        {%- if current_prod.images.size > 1 -%}
          {%- assign phover = current_prod.images[1] | img_url: '1200x' -%}
        {%- endif -%}

        {%- assign plabel = fallback_labels[i] -%}
        <div class="card card-rhode" data-category="{{ plabel }}">
          <a href="/products/{{ phandle }}" class="card-link-wrapper">
            {% if phover != blank and phover != 'none' %}
              <img src="{{ phover }}" class="card-hover-bg" alt="Hover Background">
            {% endif %}

            <div class="card-rhode-top">
              <span class="card-brand-label">{{ plabel }}</span>
            </div>
            <div class="card-rhode-image">
              <img src="{{ pimage }}" class="product-main-img" alt="{{ pname }}">
            </div>
            <div class="card-rhode-footer">
              {%- assign pprice = current_prod.price | money | default: "RS. 1,500" -%}
              {%- assign previews = "16k" -%}
              {%- if pname == "Glutathione Cream" -%}
                {%- assign previews = "9k" -%}
              {%- endif -%}
              <div class="card-meta">
                <div class="card-stars">★★★★★ <span class="review-count">({{ previews }})</span></div>
                <h3 class="card-name">{{ current_prod.title | default: pname | upcase }}</h3>
              </div>
              <span class="btn-rhode-buy-pill">BUY - {{ pprice }}</span>
            </div>
            <div class="buy-button-hover" data-handle="{{ phandle }}" onclick="window.location.href='/products/{{ phandle }}'">
              BUY {{ current_prod.title | default: pname | upcase }} - {{ pprice }}
            </div>
          </a>
          
          {% if forloop.first %}
            <div class="swipe-bubble mobile-only">
              <span>swipe</span>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}

    <!-- SET BUNDLES -->
    <!-- SET BUNDLES -->
    <div class="card card-rhode" data-category="set korean-glass-skin" onclick="window.location.href='/products/elaris-7-korean-glass-skin-bundle'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
      <img src="{{ 'glassmain.jpg' | file_img_url: '600x' }}" style="width: 100%; height: 100%; object-fit: cover;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.9); padding: 15px; border-top: 1px solid #eee; text-align: center;">
        <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0;">Korean Glass Skin Bundle</h3>
        <span style="font-size: 11px; font-weight: 700; color: #777;">SHOP THE SET</span>
      </div>
    </div>

    <div class="card card-rhode" data-category="set korean-brightening" onclick="window.location.href='/products/elaris-7-korean-brightening-bundle'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
      <img src="{{ 'main.jpg' | file_img_url: '600x' }}" style="width: 100%; height: 100%; object-fit: cover;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.9); padding: 15px; border-top: 1px solid #eee; text-align: center;">
        <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0;">Korean Brightening Bundle</h3>
        <span style="font-size: 11px; font-weight: 700; color: #777;">SHOP THE SET</span>
      </div>
    </div>

    <div class="card card-rhode" data-category="set anti-acne" onclick="window.location.href='/products/anti-acne-serum'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
      <img src="{{ 'anti-acne-100.jpg'| asset_url }}" style="width: 100%; height: 100%; object-fit: cover;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.9); padding: 15px; border-top: 1px solid #eee; text-align: center;">
        <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0;">Anti Acne Set</h3>
        <span style="font-size: 11px; font-weight: 700; color: #777;">SHOP THE SET</span>
      </div>
    </div>

    <div class="card card-rhode" data-category="set hair-care" onclick="window.location.href='/products/elaris-7-korean-hair-care-bundle'" style="display: none; background: #fff; border: 1px solid #eee; justify-content: center; align-items: center; min-height: 480px; cursor: pointer; overflow: hidden; padding: 0;">
      <img src="{{ 'hairmain.jpg' | file_img_url: '600x' }}" style="width: 100%; height: 100%; object-fit: cover;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.9); padding: 15px; border-top: 1px solid #eee; text-align: center;">
        <h3 style="font-size: 13px; font-weight: 800; text-transform: uppercase; margin: 0;">Hair Care Bundle</h3>
        <span style="font-size: 11px; font-weight: 700; color: #777;">SHOP THE SET</span>
      </div>
    </div>
  </div>
</section>

<script>
  (function initProductSlider() {
    const track = document.getElementById('product-collection-scroll');
    const nextBtn = document.getElementById('scroll-next-btn');
    const prevBtn = document.getElementById('scroll-prev-btn');

    if (track && nextBtn && prevBtn) {
      nextBtn.addEventListener('click', function() {
        const card = track.querySelector('.card-rhode');
        if (card) {
          const moveX = card.offsetWidth + 16;
          track.scrollBy({ left: moveX, behavior: 'smooth' });
        }
      });

      prevBtn.addEventListener('click', function() {
        const card = track.querySelector('.card-rhode');
        if (card) {
          const moveX = card.offsetWidth + 16;
          track.scrollBy({ left: -moveX, behavior: 'smooth' });
        }
      });

      // Update button visibility based on scroll position
      track.addEventListener('scroll', function() {
        const atStart = track.scrollLeft <= 10;
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
        
        prevBtn.style.visibility = atStart ? 'hidden' : 'visible';
        nextBtn.style.visibility = atEnd ? 'hidden' : 'visible';
      });

      // Initial state
      prevBtn.style.visibility = 'hidden';
      // Ensure right arrow is shown if content overflows
      setTimeout(() => {
        if (track.scrollWidth > track.clientWidth) {
          nextBtn.style.visibility = 'visible';
        }
      }, 500);

      // Drag to scroll for desktop mice
      let isDown = false;
      let startX;
      let scrollLeft;

      track.addEventListener('mousedown', (e) => {
        isDown = true;
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
        track.style.cursor = 'grabbing';
      });
      track.addEventListener('mouseleave', () => { isDown = false; track.style.cursor = 'grab'; });
      track.addEventListener('mouseup', () => { isDown = false; track.style.cursor = 'grab'; });
      track.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 1.5;
        track.scrollLeft = scrollLeft - walk;
      });
    }

    // Shopify Theme Editor Integration
    document.addEventListener('shopify:section:load', function(event) {
       initProductSlider();
    });
  })();
</script>

{% schema %}
{
  "name": "Rhode Product Scroll",
  "settings": [

    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (Auto Mode)"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 15,
      "step": 1,
      "label": "Product Limit",
      "default": 15
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Manual Product Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Anti Acne Serum"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "Rs. 1,500"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Premium Korean skincare formula"
        },
        {
          "type": "text",
          "id": "brand_label",
          "label": "Top Label (e.g. blush)",
          "default": "anti-acne"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. new shades)",
          "default": "new shades"
        },
        {
          "type": "text",
          "id": "reviews",
          "label": "Review Count (e.g. 6,949)",
          "default": "16k"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Primary Image (Product)"
        },
        {
          "type": "text",
          "id": "asset_image",
          "label": "Asset Image Filename (e.g. night-cream.jpg)"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image (Model Portrait)"
        },
        {
          "type": "text",
          "id": "asset_hover_image",
          "label": "Asset Hover Image Filename (e.g. night-cream-hover.jpg)"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rhode Product Scroll",
      "category": "Collection"
    }
  ]
}
{% endschema %}
