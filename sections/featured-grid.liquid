<section class="featured-grid-section" id="featured-grid-section" style="display: none;">
  <div class="grid-container">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="grid-item">
          <a href="{{ block.settings.product_link | default: '#' }}" class="card-rhode-grid">
            <div class="card-rhode-inner-grid">
              {% if block.settings.hover_image != blank %}
                {{ block.settings.hover_image | image_url: width: 1000 | image_tag: class: 'card-hover-bg', alt: block.settings.title }}
              {% endif %}
              
              <div class="card-rhode-top">
                <div class="card-brand-label">{{ block.settings.brand_label | lowercase | default: 'skincare' }}</div>
                {% if block.settings.badge != blank %}
                  <span class="card-badge">{{ block.settings.badge | lowercase }}</span>
                {% endif %}
              </div>

              <div class="card-rhode-image">
                {% if block.settings.main_image != blank %}
                  {{ block.settings.main_image | image_url: width: 800 | image_tag: alt: block.settings.title }}
                {% else %}
                  <div class="product-placeholder-img"></div>
                {% endif %}
              </div>

              <div class="card-rhode-details">
                <div class="stars">★ ★ ★ ★ ★ ({{ block.settings.reviews | default: '16k' }})</div>
                <h3 class="card-product-title">{{ block.settings.title | upcase }}</h3>
              </div>

              <div class="buy-button-hover">
                 BUY - {{ block.settings.price }}
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    {% else %}
      {% comment %} Fallback items same as scroll section but in grid {% endcomment %}
      {%- assign fallback_names = "Night Cream,Tranexamic Serum,Keratin Serum,Glow Serum,Glutathione Cream,Hair Mist,Face Wash,Anti Acne Serum,Sunscreen,Renewal Cleanser,Hydra Burst Moisturizer,Renewal Toner" | split: "," -%}
      {%- assign fallback_images = "night-cream.jpg,tranexamic-serum.jpg,keratin-serum.jpg,glow-serum-100.jpg,glutathione-cream-100.jpg,hair-mist.jpg,facewash-100.jpg,anti-acne-100.jpg,sunscreen-100.jpg,gel cleanser-100.jpg,moisturizer-100.jpg,renewal toner-100.jpg" | split: "," -%}
      {%- assign fallback_labels = "nightcream,serum,haircare,serum,repair,haircare,cleanser,antiacne,sunscreen,cleanser,moisturizer,toner" | split: "," -%}
      
      {% for i in (0..11) %}
        {%- assign pname = fallback_names[i] -%}
        {%- assign pimage = fallback_images[i] -%}
        {%- assign plabel = fallback_labels[i] | default: 'antiacne' -%}
        <div class="grid-item">
          <a href="#" class="card-rhode-grid">
            <div class="card-rhode-inner-grid">
              {% if pimage != blank %}
                <img src="{{ pimage | asset_url }}" class="card-hover-bg" alt="Hover Background">
              {% endif %}

              <div class="card-rhode-top">
                <div class="card-brand-label">{{ plabel }}</div>
                {% if i < 3 %}
                  <span class="card-badge">featured</span>
                {% endif %}
              </div>

              <div class="card-rhode-image">
                {% if pimage != blank %}
                  <img src="{{ pimage | asset_url }}" alt="{{ pname }}">
                {% else %}
                  <div class="product-placeholder-img"></div>
                {% endif %}
              </div>

              <div class="card-rhode-details">
                <div class="stars">★ ★ ★ ★ ★ (16k)</div>
                <h3 class="card-product-title">{{ pname | upcase }}</h3>
              </div>

              <div class="buy-button-hover">
                 BUY - Rs. 1,500
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{%- style -%}
.featured-grid-section {
  padding: 0 12px 60px;
  background-color: #fff;
}
.grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.card-rhode-grid {
  display: block;
  background-color: #f1efea;
  border-radius: 12px;
  position: relative;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  aspect-ratio: 1 / 1.55;
  border: 1px solid rgba(0,0,0,0.03);
  transition: transform 0.2s ease;
}
.card-rhode-inner-grid {
  position: absolute;
  inset: 0;
  padding: 24px 18px 18px;
  display: flex;
  flex-direction: column;
}
.card-rhode-grid .card-rhode-top {
  display: flex !important;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  height: 24px;
}
.card-rhode-grid .card-brand-label {
  font-size: 1.15rem;
  font-weight: 700;
  color: #5b5a53;
  text-transform: lowercase;
}
.card-rhode-grid .card-badge {
  font-size: 0.52rem;
  background: #5b5a53;
  color: #fff;
  padding: 3px 12px;
  border-radius: 20px;
  text-transform: lowercase;
  font-weight: 600;
}
.card-rhode-grid .card-rhode-image {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 0;
}
.card-rhode-grid .card-rhode-image img {
  max-width: 85%;
  max-height: 85%;
  object-fit: contain;
  mix-blend-mode: multiply;
  transition: transform 0.3s ease;
}
.card-rhode-grid:hover .card-rhode-image img {
  transform: scale(1.05); /* Subtle desktop hover effect */
}
.card-rhode-grid .card-rhode-details {
  width: 100%;
  padding: 0;
  text-align: left;
}
.card-rhode-grid .stars {
  font-size: 0.72rem;
  color: #5b5a53;
  margin-bottom: 2px;
  display: block;
}
.card-rhode-grid .card-product-title {
  font-size: 0.78rem;
  color: #5b5a53;
  margin: 0;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.2;
}
.card-rhode-grid .buy-button-hover {
  position: relative;
  opacity: 1;
  width: 100%;
  margin-top: 12px;
  padding: 10px 0;
  border: 1px solid #5b5a53;
  color: #5b5a53;
  border-radius: 50px;
  font-size: 0.68rem;
  font-weight: 700;
  text-align: center;
  background: transparent;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  box-sizing: border-box;
}
@media (max-width: 900px) {
  .grid-container {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .featured-grid-section {
    padding: 0 16px 40px;
  }
  .card-rhode-grid {
    aspect-ratio: 1 / 1.7;
    background-color: #f1efea;
  }
  .card-rhode-inner-grid {
    position: absolute;
    inset: 0;
    padding: 15px 12px;
    display: flex;
    flex-direction: column;
  }
  .card-rhode-grid .card-rhode-image {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 5px 0;
    overflow: hidden;
  }
  .card-rhode-grid .card-rhode-image img {
    transform: scale(1.6);
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .card-rhode-grid .card-rhode-top {
    width: 100%;
    display: flex !important;
    justify-content: center; /* Label remains centered as per design */
    z-index: 10;
  }
  .card-rhode-grid .card-brand-label {
    font-size: 1rem;
    font-weight: 800;
  }
  .card-rhode-grid .card-rhode-details {
    margin-top: auto;
    width: 100%;
    text-align: left !important; /* Forces Name to the left */
    padding: 5px 0;
  }
  .card-rhode-grid .stars {
    font-size: 0.55rem;
    margin-bottom: 2px;
    text-align: left !important;
  }
  .card-rhode-grid .card-product-title {
    font-size: 0.62rem;
    font-weight: 900;
    margin: 0;
    text-align: left !important; /* Forces Name to the left */
  }
  .card-rhode-grid .buy-button-hover {
    background: transparent;
    margin: 8px 0 0;
    width: 100%;
    border: 1px solid #5b5a53;
    border-radius: 50px;
    padding: 7px 0;
    font-size: 0.55rem;
    font-weight: 700;
    text-align: center;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Featured Grid",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Manual Product Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Anti Acne Serum"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "Rs. 1,500"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Premium Korean skincare formula"
        },
        {
          "type": "text",
          "id": "brand_label",
          "label": "Top Label (e.g. blush)",
          "default": "antiacne"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. new shades)",
          "default": "new shades"
        },
        {
          "type": "text",
          "id": "reviews",
          "label": "Review Count (e.g. 6,949)",
          "default": "16k"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Primary Image (Product)"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image (Model Portrait)"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}
