{%- assign product = all_products['anti-acne'] -%}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@700;800&display=swap');

    .landing-acne-wrap { 
      font-family: 'Inter', sans-serif !important; 
      background-color: #fff; 
      color: #333; 
      width: 100%; 
    }
    .pdp-wrapper { padding: 60px 20px; max-width: 1440px; margin: 0 auto; width: 100%; }
    .pdp-main-box { background: #fff; border: 1px solid #e5e5e5; border-radius: 14px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 24px; overflow: hidden; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; padding: 20px; }
    .details-panel { padding: 60px; border-left: 1px solid #e5e5e5; background: #fdfdfd; }
    
    .product-title { 
      font-family: 'Lexend', sans-serif !important; 
      font-size: 46px; 
      font-weight: 800; 
      letter-spacing: -0.04em; 
      margin-bottom: 25px; 
      line-height: 1; 
      color: #2c2b28 !important; 
      text-transform: uppercase;
    }
    
    .btn-atc { 
      width: 100%; 
      padding: 22px; 
      border-radius: 50px; 
      border: 1.5px solid #2c2b28; 
      background: #fff; 
      font-weight: 700; 
      text-transform: uppercase; 
      cursor: pointer; 
      font-size: 13px; 
      color: #2c2b28; 
      text-align: center; 
      text-decoration: none; 
      display: block; 
      transition: all 0.3s ease;
    }
    .btn-atc:hover { background: #2c2b28; color: #fff; }

    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; color: #5b5a53; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #666; }
    .accordion-item.active .acc-content { display: block; }
    
    .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .island-card { border-radius: 14px; overflow: hidden; background: #f6f5f3; height: 600px; position: relative; }
    
    .faq-section { background-color: #f3f0ec; border-radius: 14px; padding: 80px 60px; margin-top: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
    .faq-title { font-family: 'Lexend', sans-serif !important; font-size: 42px; font-weight: 800; color: #333; margin-bottom: 30px; letter-spacing: -0.02em; }
    .faq-item { border-top: 1px solid rgba(0,0,0,0.1); padding: 25px 0; cursor: pointer; }
    
    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; border-radius: 0; border: none; }
        .details-panel { border-left: none; padding: 30px 20px; }
        .discovery-grid, .faq-section { grid-template-columns: 1fr; }
        .island-card { height: 400px; }
        .product-title { font-size: 32px; }
    }
</style>

<div class="landing-acne-wrap">
  <main class="pdp-wrapper">
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'anti-acne-100.jpg'| file_img_url: 'master' }}" style="width:100%; height:auto;" alt="Anti-Acne">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">CLARIFY & CONTROL</p>
        <h1 class="product-title">Elaris7 Anti-Acne Clarifying Serum</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; color: #333;">★ ★ ★ ★ ★ (1,150)</div>
        <p style="font-size: 15.5px; line-height: 1.7; margin-bottom: 40px; color: #444;">A high-performance serum designed to target blemishes and soothe irritation. Formulated with dermatologist-approved actives to clear pores and refine texture without redness.</p>
        
        <a href="/cart/add?id={{ product.variants.first.id }}&quantity=1" class="btn-atc">BUY NOW — {{ product.price | money }}</a>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">KEY BENEFITS <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Reduces active breakouts, controls excess oil production, and helps fade the appearance of post-acne marks for a balanced, clear complexion.</p></div>
        </div>
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">HOW TO USE <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Apply 2-3 drops to clean, dry skin. Use evening or morning before moisturizer. Always follow with sunscreen during the day.</p></div>
        </div>
      </div>
    </div>

    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'hover-anti-acne.png' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card" style="background: #fdfdfd; display: flex; align-items: center; justify-content: center; padding: 40px; text-align: center;">
         <div>
            <h2 style="font-family:Lexend; font-size:32px; font-weight:800; margin-bottom:20px;">The Science of Clarity.</h2>
            <p style="font-size: 15px; color:#666; line-height:1.6;">Our formula balances salicylic acid with soothing centella to ensure your skin stays calm while fighting acne.</p>
         </div>
      </div>
    </section>

    <section class="faq-section">
      <div>
        <h2 class="faq-title">Ask away.</h2>
        <div class="faq-item" onclick="this.nextElementSibling.classList.toggle('active')">
           <div class="acc-head">Is this good for sensitive skin? <span>+</span></div>
        </div>
        <div class="acc-content" style="padding-bottom: 20px;">Yes, we added soothing agents to prevent the usual stinging sensation associated with acne treatments.</div>
        
        <div class="faq-item" onclick="this.nextElementSibling.classList.toggle('active')">
           <div class="acc-head">How long to see results? <span>+</span></div>
        </div>
        <div class="acc-content" style="padding-bottom: 20px;">Most users notice a reduction in redness within 48 hours and clearer skin in 2 weeks.</div>
      </div>
      <div class="island-card">
        <img src="https://images.pexels.com/photos/3762879/pexels-photo-3762879.jpeg?auto=compress&cs=tinysrgb&w=800" style="width:100%; height:100%; object-fit:cover;">
      </div>
    </section>
  </main>
</div>
