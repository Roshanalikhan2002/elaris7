{%- assign product = all_products['anti-acne'] -%}

<style>
    /* Reset & Base for Snippet */
    .product-page-acne {
        font-family: 'Inter', Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.5;
        background-color: #ffffff;
    }

    /* Product Gallery Styling */
    .product-gallery {
        display: flex;
        gap: 15px;
        background: #fff;
        padding: 10px;
        border-radius: 12px;
        height: 100%;
    }
    .gallery-thumbnails {
        display: flex;
        flex-direction: column;
        gap: 12px;
        justify-content: center;
        width: 60px;
    }
    .thumb-item {
        width: 55px;
        height: 55px;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        background: white;
    }
    .thumb-item:hover, .thumb-item.active {
        border-color: #002d5f;
    }
    .thumb-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .gallery-main-viewport {
        border: 1px solid rgba(0,0,0,0.08);
        background-color: #fff;
        overflow: hidden;
        flex: 1;
        height: 100%;
        border-radius: 12px;
        position: relative;
    }
    .gallery-slider {
        display: flex;
        height: 100%;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .gallery-slide {
        min-width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .gallery-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Desktop Fixed-Height Internal Scroll Logic */
    @media (min-width: 901px) {
        .product-page-acne {
            background-color: #f3f0ec; 
            margin: 20px 12px 12px;
            padding: 0;
            border-radius: 14px;
            overflow: hidden;
        }
        .product-grid-acne {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            height: 700px; 
            gap: 0;
        }
        .product-details {
            height: 100%;
            overflow-y: auto;
            scrollbar-width: none;
            padding: 40px;
        }
        .product-details::-webkit-scrollbar { display: none; }
    }

    @media (max-width: 900px) {
        .product-page-acne {
            margin: 0;
            padding: 0;
        }
        .product-grid-acne {
            display: flex;
            flex-direction: column;
            height: auto;
        }
        .product-gallery {
            flex-direction: column-reverse;
            height: auto;
            aspect-ratio: 1 / 1.1;
            border-radius: 0;
            padding: 10px;
        }
        .gallery-thumbnails {
            flex-direction: row;
            width: 100%;
            height: 70px;
            justify-content: center;
            padding: 5px 0;
            gap: 10px;
        }
        .product-details {
            padding: 24px 20px;
            height: auto;
        }
    }

    /* Accordions & Details */
    .product-title { font-size: 2rem; font-weight: 800; margin-bottom: 10px; text-transform: uppercase; }
    .product-subtitle { font-size: 0.9rem; color: #7A7973; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
    .product-description { font-size: 0.95rem; line-height: 1.6; margin: 20px 0; color: #5b5a53; }
    .divider { border: none; border-top: 1px solid #eee; margin: 25px 0; }
    
    .accordion-item { border-top: 1px solid rgba(0,0,0,0.05); border-bottom: 1px solid rgba(0,0,0,0.1); padding: 5px 0; }
    .accordion-item summary { padding: 20px 0; display: flex; justify-content: space-between; cursor: pointer; font-weight: 700; font-size: 0.85rem; color: #5b5a53; list-style: none; }
    .accordion-content { padding: 15px 0; font-size: 0.85rem; color: #5b5a53; line-height: 1.5; }

    .add-to-cart-btn { background-color: #002d5f !important; color: #fff !important; padding: 18px !important; border-radius: 50px !important; border: none; font-weight: 800; cursor: pointer; width: 100%; text-transform: uppercase; font-size: 0.85rem; }

    /* Sections Styles (Breakdown, FAQ, etc.) */
    .breakdown-section { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 16px; margin: 16px 12px; height: auto; min-height: 600px; }
    .breakdown-content { background-color: #f3f0ec; border-radius: 14px; padding: 60px 40px; display: flex; flex-direction: column; justify-content: center; }
    .bd-title { font-size: 2rem; font-weight: 500; color: #6a6863; margin-bottom: 40px; line-height: 1.2; }
    .bd-row { display: flex; justify-content: space-between; border-bottom: 1px solid rgba(91,90,83,0.15); padding: 16px 0; }
    .bd-label { font-weight: 700; font-size: 0.85rem; color: #5b5a53; width: 30%; }
    .bd-val { font-size: 0.85rem; color: #5b5a53; text-align: right; width: 65%; }
    .breakdown-image { border-radius: 14px; overflow: hidden; display: flex; }
    .breakdown-image img { width: 100%; height: 100%; object-fit: cover; }

    .whats-inside-section { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 12px; }
    .wi-image-col { position: relative; border-radius: 14px; overflow: hidden; height: 600px; }
    .wi-image { width: 100%; height: 100%; object-fit: cover; }
    .wi-content-col { background: #fff; border: 1px solid #eee; border-radius: 14px; padding: 60px; position: relative; display: flex; align-items: center; }
    .wi-vertical-text { position: absolute; left: 20px; top: 50%; transform: rotate(-90deg) translateY(-50%); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: #ccc; }
    
    .stats-section { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 16px; margin: 16px 12px; }
    .stats-content { background: #f3f0ec; border-radius: 14px; padding: 60px; }
    .stat-item { margin-bottom: 40px; }
    .stat-pct { font-size: 2.5rem; font-weight: 800; color: #333; margin-bottom: 10px; }
    .stat-desc { font-size: 0.8rem; font-weight: 700; color: #5b5a53; text-transform: uppercase; letter-spacing: 0.05em; }
    .stats-image { border-radius: 14px; overflow: hidden; }
    .stats-image img { width: 100%; height: 100%; object-fit: cover; }

    .faq-section { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 12px; }
    .faq-content { background: #fff; border: 1px solid #eee; border-radius: 14px; padding: 60px; }
    .faq-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 40px; }
    .faq-item { border-bottom: 1px solid #eee; padding: 20px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .faq-question { font-weight: 700; font-size: 0.9rem; }
    .faq-answer { display: none; margin-top: 15px; font-size: 0.85rem; color: #666; }
    .faq-item.active .faq-answer { display: block; }

    @media (max-width: 900px) {
        .breakdown-section, .whats-inside-section, .stats-section, .faq-section { grid-template-columns: 1fr; height: auto; }
        .wi-image-col { height: 400px; }
        .wi-content-col, .stats-content, .faq-content { padding: 40px 20px; }
    }
</style>

<div class="product-page-acne">
    <div class="product-grid-acne">
        <!-- Gallery -->
        <div class="product-gallery">
            <div class="gallery-thumbnails">
                <div class="thumb-item active" onmouseover="scrollGalleryAcne(0, this)">
                    <img src="{{ 'v2-antiacne-1.jpeg' | asset_url }}" alt="Thumb 1">
                </div>
                <div class="thumb-item" onmouseover="scrollGalleryAcne(1, this)">
                    <img src="{{ 'v2-antiacne-2.jpg' | asset_url }}" alt="Thumb 2">
                </div>
                <div class="thumb-item" onmouseover="scrollGalleryAcne(2, this)">
                    <img src="{{ 'v2-antiacne-3.jpg' | asset_url }}" alt="Thumb 3">
                </div>
                <div class="thumb-item" onmouseover="scrollGalleryAcne(3, this)">
                    <img src="{{ 'v2-antiacne-4.jpg' | asset_url }}" alt="Thumb 4">
                </div>
            </div>
            <div class="gallery-main-viewport">
                <div class="gallery-slider" id="productSliderAcne">
                    <div class="gallery-slide"><img src="{{ 'v2-antiacne-1.jpeg' | asset_url }}"></div>
                    <div class="gallery-slide"><img src="{{ 'v2-antiacne-2.jpg' | asset_url }}"></div>
                    <div class="gallery-slide"><img src="{{ 'v2-antiacne-3.jpg' | asset_url }}"></div>
                    <div class="gallery-slide"><img src="{{ 'v2-antiacne-4.jpg' | asset_url }}"></div>
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="product-details">
            <h1 class="product-title">{{ product.title }}</h1>
            <span class="product-subtitle">Clear & Control</span>
            <div class="product-description">
                <p>A targeted clarifying serum formulated to reduce acne, calm inflammation, and support clearer-looking skin. It helps refine pores, balance oil, and promote a smoother, healthier complexion with consistent use.</p>
                <p style="font-size: 0.75rem; color: #999; margin-top: 10px;">*with continued daily use</p>
            </div>
            <hr class="divider">
            
            <div class="bogo-inline-section">
                {% render 'bogo-selection' %}
            </div>
            
            <div style="margin-top: 30px;">
                <button class="add-to-cart-btn-acne add-to-cart-btn">ADD TO BAG - {{ product.price | money }}</button>
            </div>

            <div class="product-accordions" style="margin-top: 40px;">
                <details class="accordion-item">
                    <summary><span>BENEFITS</span><span>+</span></summary>
                    <div class="accordion-content">
                        <ul>
                            <li>Helps reduce active acne and breakouts</li>
                            <li>Supports clearer pores and controls excess oil</li>
                            <li>Helps calm inflammation and redness</li>
                            <li>Promotes smoother, more refined skin texture</li>
                        </ul>
                    </div>
                </details>
                <details class="accordion-item">
                    <summary><span>APPLICATION</span><span>+</span></summary>
                    <div class="accordion-content">
                        <p>Use morning or evening after cleansing and toning. Apply 2–3 drops to face or affected areas and gently press into skin. Follow with moisturiser.</p>
                    </div>
                </details>
                <details class="accordion-item">
                    <summary><span>KEY INGREDIENTS</span><span>+</span></summary>
                    <div class="accordion-content">
                        <p>Neem Extract, Tea Tree Oil, Mandelic Acid, Niacinamide, Aloe Vera Extract, Glycerin.</p>
                    </div>
                </details>
            </div>
        </div>
    </div>

    <!-- Breakdown -->
    <section class="breakdown-section">
        <div class="breakdown-content">
            <h2 class="bd-title">Targeted Acne Care That Balances Skin</h2>
            <div class="bd-table">
                <div class="bd-row"><span class="bd-label">GOOD FOR:</span><span class="bd-val">Acne-prone and oily skin types</span></div>
                <div class="bd-row"><span class="bd-label">FEELS LIKE:</span><span class="bd-val">A smooth, fast-absorbing serum</span></div>
                <div class="bd-row"><span class="bd-label">LOOKS LIKE:</span><span class="bd-val">Clearer skin with reduced redness</span></div>
            </div>
        </div>
        <div class="breakdown-image"><img src="{{ 'v2-antiacne-plate.jpg' | asset_url }}"></div>
    </section>

    <!-- Stats -->
    <section class="stats-section">
        <div class="stats-content">
            <div class="stat-item"><div class="stat-pct">95%</div><div class="stat-desc">SAID THEIR SKIN FELT SOOTHED AND BALANCED</div></div>
            <div class="stat-item"><div class="stat-pct">94%</div><div class="stat-desc">SAID IT HELPED PREVENT NEW BREAKOUTS</div></div>
        </div>
        <div class="stats-image"><img src="{{ 'v2-antiacne-stats.jpg' | asset_url }}"></div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
        <div class="faq-content">
            <h2 class="faq-title">FAQ</h2>
            <div class="faq-item" onclick="this.classList.toggle('active')">
                <span class="faq-question">Will it dry out my skin?</span>
                <p class="faq-answer">No, it contains soothing Aloe and Niacinamide to maintain moisture.</p>
            </div>
            <div class="faq-item" onclick="this.classList.toggle('active')">
                <span class="faq-question">How often should I use it?</span>
                <p class="faq-answer">Start once a day (evening) and work up to twice daily.</p>
            </div>
        </div>
        <div class="wi-image-col"><img src="{{ 'v2-antiacne-faq.jpg' | asset_url }}" class="wi-image"></div>
    </section>
</div>

<script>
    function scrollGalleryAcne(index, thumb) {
        const slider = document.getElementById('productSliderAcne');
        if(slider) slider.style.transform = `translateX(-${index * 100}%)`;
        document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
    }

    document.querySelectorAll('.add-to-cart-btn-acne').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            const b = this;
            const originalText = b.innerHTML;
            if (b.disabled) return;
            b.innerHTML = 'ADDING...';
            b.disabled = true;

            try {
                const mainVariantId = "{{ product.variants.first.id }}";
                const selectedGift = document.querySelector('input[name="free_gift"]:checked');
                let items = [{ id: mainVariantId, quantity: 1, properties: { '_bogo': 'true' } }];
                
                if (selectedGift) {
                    const giftId = selectedGift.getAttribute('data-variant-id');
                    if (giftId && giftId !== '0') {
                        items.push({ id: giftId, quantity: 1, properties: { '_free_gift': 'true', '_bogo': 'true' } });
                    }
                }

                const response = await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: JSON.stringify({ items: items })
                });

                if (response.ok) {
                    window.location.href = '/cart';
                } else {
                    throw new Error('Failed to add');
                }
            } catch (error) {
                alert('Error adding to bag');
                b.innerHTML = originalText;
                b.disabled = false;
            }
        });
    });
</script>
