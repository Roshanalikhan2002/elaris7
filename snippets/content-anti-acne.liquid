{%- assign product = all_products['anti-acne'] -%}

<!-- LOAD FONTS TO PREVENT WINGDINGS/ICONS ISSUE -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Lexend:wght@700;800&display=swap" rel="stylesheet">

<style>
    :root {
      --bg-color: #ffffff; 
      --surface-color: #f1efea; 
      --text-color: #333333; 
    }
    .landing-acne-wrap { font-family: 'Inter', sans-serif; background-color: #fff; color: #333; width: 100%; position: relative; }
    .pdp-wrapper { padding: 40px 12px; max-width: 1440px; margin: 0 auto; width: 100%; }
    .pdp-main-box { background: #fff; border: 1px solid #d1d1d1; border-radius: 14px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; overflow: hidden; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel { padding: 60px; border-left: 1px solid #d1d1d1; background: #fdfdfd; }
    .product-title { font-family: 'Lexend', sans-serif; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; text-transform: uppercase; color: #000; }
    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; color: #000; text-align: center; text-decoration: none; display: block; border: 1.5px solid #000; }
    .btn-atc:hover { background: #000; color: #fff; }

    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { display: block; }
    
    .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
    .island-card { border-radius: 14px; overflow: hidden; background: #fff; height: 600px; position: relative; }

    /* FAQ Section Styles from your original file */
    .faq-section { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
    .faq-content { background-color: #f3f0ec; border-radius: 14px; padding: 60px 40px; }
    .faq-title { font-family: 'Lexend'; font-size: 42px; font-weight: 800; color: #333; margin-bottom: 30px; letter-spacing: -0.02em; }
    .faq-q-row { border-top: 1px solid rgba(0,0,0,0.1); padding: 25px 0; display: flex; justify-content: space-between; font-size: 12px; font-weight: 800; text-transform: uppercase; cursor: pointer; }

    /* Review Styles */
    .review-block { background: #f3f0ec; border-radius: 14px; padding: 60px 40px; margin-top: 16px; display: grid; grid-template-columns: 250px 1fr; gap: 40px; font-size: 0.9rem; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel { border-left: none; padding: 30px 15px; }
        .discovery-grid, .faq-section { grid-template-columns: 1fr; }
        .island-card { height: 400px; }
        .product-title { font-size: 34px; }
        .review-block { grid-template-columns: 1fr; }
    }
</style>

<div class="landing-acne-wrap">
  <main class="pdp-wrapper">
    <!-- 1. HERO -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'anti-acne-100.jpg' | file_img_url: 'master' }}" style="width:100%; height:auto;" alt="Anti-Acne">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">CLARIFY & CONTROL</p>
        <h1 class="product-title">Elaris7 Anti-Acne Clarifying Serum</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,150)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">A powerful blend of salicylic acid and tea tree oil to target breakouts while calming the skin.</p>
        
        <a href="/cart/add?id={{ product.selected_or_first_available_variant.id }}&quantity=1" class="btn-atc">BUY NOW — {{ product.price | money }}</a>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Salicylic Acid (BHA), Tea Tree Oil, and Niacinamide to clear pores and reduce redness.</p></div>
        </div>
      </div>
    </div>

    <!-- 2. DISCOVERY IMAGES -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'hover-anti-acne.png' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="https://images.unsplash.com/photo-1598440441973-1961609f89b8?q=80&w=1000" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 3. FAQ -->
    <section class="faq-section">
      <div class="faq-content">
        <h2 class="faq-title">Ask away.</h2>
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Is this safe for daily use? <span>+</span></div>
        <div class="acc-content" style="padding-bottom: 20px;">Yes, start once a day and increase to twice if your skin tolerates it.</div>
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Will it dry out my skin? <span>+</span></div>
        <div class="acc-content" style="padding-bottom: 20px;">Our formula includes hydrating ingredients to balance the clarifying acids.</div>
      </div>
      <div class="island-card">
        <img src="https://images.pexels.com/photos/3762879/pexels-photo-3762879.jpeg?auto=compress&cs=tinysrgb&w=1000" style="width:100%; height:100%; object-fit:cover;">
      </div>
    </section>

    <!-- 4. REVIEWS -->
    <section class="review-block">
      <div><h4 style="font-size:16px;">Sara J.</h4><p style="font-size:11px; color:#777;">Verified Buyer</p></div>
      <div>
        <div style="font-size:18px; margin-bottom:10px;">★ ★ ★ ★ ★</div>
        <p>“Cleared my hormonal acne in just two weeks! I love the texture.”</p>
      </div>
    </section>
  </main>
</div>
