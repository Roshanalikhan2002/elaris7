<style>
    .pdp-wrapper-bright { padding-top: 60px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
    .pdp-main-box { background: #fff; border: 1px solid #d1d1d1; border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel { padding: 60px; border-left: 1px solid #d1d1d1; background: #fdfdfd; }
    .product-title { font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; text-transform: uppercase; }
    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.3s ease; }
    .btn-atc:hover { background: #000; color: #fff; }
    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { display: block; }
    .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel { border-left: none; padding: 30px 15px; }
        .discovery-grid { grid-template-columns: 1fr; }
        .island-card { height: 400px; }
    }
</style>

<div class="pdp-wrapper-bright">
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'main.jpg' | asset_url }}" style="width:100%; height:auto;" alt="Brightening Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE BRIGHTENING SYSTEM</p>
        <h1 class="product-title">Elaris 7 Korean Brightening Bundle</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (2,199)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Unlock your skin’s natural radiance with the Elaris 7 Korean Brightening Bundle.</p>
        
        <button class="btn-atc">BUY THE KIT - RS. 4,500</button>
        <div style="text-align: center; font-size: 11px; margin-top: 15px;">or 4 payments with Afterpay Ⓘ</div>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
          <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
          <div class="acc-content"><p>Includes: E7 Brightening Gel Cleanser, E7 Glow Renewal Toner, E7 Tranexamic Brightening Serum, and E7 Korean Gel Sunscreen.</p></div>
        </div>
      </div>
    </div>

    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'twoimagessection1.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'twoimagessection2.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>
</div>
