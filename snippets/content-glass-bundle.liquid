<style>
    :root {
        --bg-page: #f2f2f1;
        --white: #ffffff;
        --text-color: #000000;
        --border-color: #d1d1d1;
    }
    .pdp-wrapper-glass { padding: 40px 12px; max-width: 1440px; margin: 0 auto; width: 100%; }
    .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; }
    .product-title { font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; text-transform: uppercase; }
    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.2s; color: #000; }
    .btn-atc:hover { background: #000; color: #fff; }
    
    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
    .accordion-plus { font-size: 18px; color: #999; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { display: block; }

    .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel { border-left: none; padding: 30px 15px; }
        .discovery-grid { grid-template-columns: 1fr; }
        .island-card { height: 400px; }
        .product-title { font-size: 32px; }
    }
</style>

<div class="pdp-wrapper-glass">
    {%- assign target_product = all_products['elaris-7-korean-glass-skin-bundle'] -%}
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'glassmain.jpg' | file_img_url: 'master' }}" style="width:100%; height:auto;" alt="Glass Skin Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE HYDRATION SYSTEM</p>
        <h1 class="product-title">Elaris 7 Korean Glass Skin Bundle</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Discover the ultimate glow ritual with the E7 Glass Skin Set. Packed with five powerful, multitasking essentials, this set is crafted to hydrate, brighten, and refine your skin from morning to night.</p>
        
        <form action="/cart/add" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="{{ target_product.variants.first.id }}">
          <button type="submit" class="btn-atc">BUY THE KIT - {{ target_product.price | money | default: 'RS. 4,500' }}</button>
        </form>
        
        <div style="text-align: center; font-size: 11px; margin-top: 15px;">or 4 payments with Afterpay Ⓘ</div>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
            <div class="acc-content"><p>The E7 Glass Skin Set includes five full-size products: Centella Face Wash, Centella Serum, Centella Moisturizer, Centella Sunscreen SPF60+, and Centella Night Cream.</p></div>
        </div>
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">THE ROUTINE <div class="accordion-plus">+</div></div>
            <div class="acc-content"><p>Your complete morning and evening skin ritual. Designed to hydrate, brighten, and protected from UV damage.</p></div>
        </div>
      </div>
    </div>

    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'glasstwoimagesection1.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'glasstwoimagesection2.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>
</div>
