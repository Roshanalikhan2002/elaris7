<style>
    .pdp-wrapper-glass { padding: 40px 12px; max-width: 1440px; margin: 0 auto; width: 100%; font-family: 'Inter', sans-serif; }
    .pdp-main-box { background: #fff; border: 1px solid #d1d1d1; border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; overflow: hidden; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel { padding: 60px; border-left: 1px solid #d1d1d1; background: #fdfdfd; }
    .product-title { font-family: 'Lexend', sans-serif; font-size: 44px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 25px; line-height: 1; color: #000; text-transform: uppercase; }
    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.2s; color: #000; text-align: center; display: block; }
    .btn-atc:hover { background: #000; color: #fff; }
    
    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #333; }
    .accordion-item.active .acc-content { display: block; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 500px; margin-top: 20px; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel { border-left: none; padding: 30px 15px; }
        .product-title { font-size: 30px; }
    }
</style>

<div class="pdp-wrapper-glass">
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'glassmain.jpg' | asset_url }}" style="width:100%; height:auto; display: block;" alt="Glass Skin Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE HYDRATION SYSTEM</p>
        <h1 class="product-title">Elaris 7 Korean Glass Skin Bundle</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Discover the ultimate glow ritual with the E7 Glass Skin Set. Crafted to hydrate, brighten, and refine your skin from morning to night.</p>
        
        <a href="/cart/add?id=45678901234567&quantity=1" class="btn-atc">BUY THE KIT — RS. 4,500</a>
        
        <div style="text-align: center; font-size: 11px; margin-top: 15px; color: #777;">or 4 payments with Afterpay Ⓘ</div>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Includes: Centella Face Wash, Centella Serum, Centella Moisturizer, Centella Sunscreen, and Night Cream.</p></div>
        </div>
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">THE ROUTINE <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Your complete morning and evening ritual for that perfect Korean Glass Skin glow.</p></div>
        </div>
      </div>
    </div>

    <div class="discovery-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
      <div class="island-card"><img src="{{ 'glasstwoimagesection1.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'glasstwoimagesection2.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </div>
</div>
