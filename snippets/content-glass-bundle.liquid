{%- assign product = all_products['elaris-7-korean-glass-skin-bundle'] -%}

<style>
    /* CONTENT ONLY - NO HEADER STUFF */
    .pdp-wrapper-glass { 
      padding-top: 10px; 
      max-width: 1440px; 
      margin: 0 auto; 
      width: 100%; 
      font-family: 'Inter', sans-serif;
    }
    .pdp-main-box { background: #fff; border: 1px solid #d1d1d1; border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; overflow: hidden; }
    .gallery-wrap-pdp { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel-pdp { padding: 60px; border-left: 1px solid #d1d1d1; background: #fdfdfd; }
    .pdp-title-main { font-family: 'Lexend', sans-serif !important; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; text-transform: uppercase; color: #000 !important; }
    
    .btn-atc-pdp { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; color: #000; text-align: center; text-decoration: none; display: block; border: 1.5px solid #000; }
    .btn-atc-pdp:hover { background: #000; color: #fff; }

    .acc-item-pdp { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head-pdp { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .acc-content-pdp { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #444; }
    .acc-item-pdp.active .acc-content-pdp { display: block; }

    .discovery-grid-pdp { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
    .island-card-pdp { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel-pdp { border-left: none; padding: 30px 15px; }
        .pdp-title-main { font-size: 32px; }
    }
</style>

<div class="pdp-wrapper-glass">
    <div class="pdp-main-box">
      <div class="gallery-wrap-pdp">
        <img src="{{ 'glassskinbundle.jpeg' | asset_url }}" style="width:100%; height:auto;" alt="Glass Skin Bundle">
      </div>
      <div class="details-panel-pdp">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE HYDRATION SYSTEM</p>
        <h1 class="pdp-title-main">{{ product.title | default: 'Elaris 7 Korean Glass Skin Bundle' }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Discover the ultimate glow ritual with the E7 Glass Skin Set.</p>
        <a href="/cart/add?id={{ product.variants.first.id }}&quantity=1" class="btn-atc-pdp">BUY THE KIT - {{ product.price | money }}</a>

        <div class="acc-item-pdp" onclick="this.classList.toggle('active')">
            <div class="acc-head-pdp">WHAT'S INSIDE <div style="font-size:18px;">+</div></div>
            <div class="acc-content-pdp"><p>Face Wash, Serum, Moisturizer, Sunscreen, and Night Cream.</p></div>
        </div>
      </div>
    </div>
    
    <section class="discovery-grid-pdp">
      <div class="island-card-pdp"><img src="{{ 'glasstwoimagesection1.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card-pdp"><img src="{{ 'glasstwoimagesection2.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>
</div>


