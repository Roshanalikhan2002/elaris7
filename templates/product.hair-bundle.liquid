{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elaris 7 | Korean Hair Care Bundle</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Lexend:wght@700;800&display=swap" rel="stylesheet">
    {{ 'styles.css' | asset_url | stylesheet_tag }}
    <style>
        :root {
            --bg-page: #f2f2f1;
            --white: #ffffff;
            --text-color: #000000;
            --placeholder-bg: #e5e5e5;
            --border-color: #d1d1d1;
            --header-height: 80px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-page); color: var(--text-color); overflow-x: hidden; width: 100%; }
        .site-container { max-width: 1440px; margin: 0 auto; padding: 0 20px; width: 100%; }

        header { 
          display: grid; 
          grid-template-columns: 1fr auto 1fr; 
          align-items: center; 
          height: var(--header-height); 
          background: var(--bg-page); 
          position: sticky; 
          top: 0; 
          z-index: 1000; 
          padding: 0 20px;
        }
        .header-logo { font-family: 'Lexend'; font-size: 34px; font-weight: 800; letter-spacing: -0.05em; text-decoration: none; color: #000; text-transform: lowercase; }
        .nav-links { display: flex; gap: 30px; }
        .nav-links.right { justify-content: flex-end; }
        .nav-links a { text-decoration: none; color: #000; font-size: 13px; font-weight: 700; text-transform: uppercase; }

        /* Main Content Styling */
        .pdp-wrapper { padding-top: 130px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
        .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; }
        .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; height: auto; }
        .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; height: auto; }

        .details-panel::-webkit-scrollbar { width: 6px; }
        .details-panel::-webkit-scrollbar-thumb { background: #dcdcdc; border-radius: 10px; }
        .product-title { font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; }

        .btn-atc { 
          width: 100%; 
          padding: 22px; 
          border-radius: 50px; 
          border: 1.5px solid #000; 
          background: #fff; 
          font-weight: 700; 
          text-transform: uppercase; 
          cursor: pointer; 
          font-size: 13px;
          transition: all 0.2s;
        }
        .btn-atc:hover { background: #000; color: #fff; }

        .afterpay-line { text-align: center; font-size: 11px; margin: 15px 0 50px; display: flex; align-items: center; justify-content: center; gap: 5px; color: #555; }
        .afterpay-badge { background: #000; color: #fff; padding: 2px 6px; border-radius: 4px; font-weight: 800; font-size: 10px; }

        /* Accordions */
        .accordion-item { border-top: 1px solid rgba(0,0,0,0.05); border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
        .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
        .accordion-plus { width: 22px; height: 22px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
        .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; font-size: 14px; line-height: 1.6; color: #444; }
        .accordion-item.active .acc-content { max-height: 1200px; padding-top: 15px; }
        .accordion-item.active .accordion-plus { transform: rotate(45deg); background: #000; color: #fff; }

        /* Discovery Blocks */
        .discovery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px; }
        .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }
        .img-placeholder { width: 100%; height: auto; display: block; }

        /* Results Grid */
        .results-block { background: #f4f4f2; border-radius: 12px; padding: 70px 60px; margin-top: 20px; }
        .results-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 50px; }
        .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }
        .results-pic { border-radius: 12px; overflow: hidden; aspect-ratio: 4/5; background: #ddd; }

        /* FAQ */
        .faq-text-side { padding: 80px 60px; background: #f2f2f1; display: flex; flex-direction: column; justify-content: center; }
        .faq-q-row { border-top: 1px solid #ddd; padding: 25px 0; display: flex; justify-content: space-between; font-size: 12px; font-weight: 800; text-transform: uppercase; cursor: pointer; }
        .acc-content.active { max-height: 200px; }

        /* Review */
        .review-block { background: #fff; border-radius: 12px; padding: 70px 60px; margin-top: 20px; display: grid; grid-template-columns: 280px 1fr; gap: 60px; position: relative; }
        .v-badge::after { content: '✔'; background: #000; color: #fff; width: 14px; height: 14px; border-radius: 50%; font-size: 8px; display: inline-flex; align-items: center; justify-content: center; margin-left: 5px; vertical-align: middle; }

        @media (max-width: 1024px) {
            .pdp-wrapper { padding-top: 90px; }
            header { grid-template-columns: auto 1fr auto; padding: 0 15px; }
            .nav-links { display: none; }
            .header-logo { font-size: 26px; }
            .pdp-main-box { grid-template-columns: 1fr; height: auto; border: none; border-radius: 0; }
            .gallery-wrap { height: auto; padding: 0; margin-bottom: 20px; }
            .details-panel { border-left: none; padding: 30px 15px; height: auto; overflow-y: visible; background: transparent; }
            .discovery-grid { grid-template-columns: 1fr; gap: 10px; }
            .island-card { height: 400px; }
            .results-grid { display: flex; overflow-x: auto; gap: 15px; }
            .results-pic { min-width: 85%; }
            .review-block { grid-template-columns: 1fr; padding: 40px 20px; gap: 40px; }
        }

    </style>
</head>
<body>

  {% section 'header' %}

  <main class="pdp-wrapper">
    <!-- 1. Top Section -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'hairmain.jpg' | file_img_url: 'master' }}" class="img-placeholder" alt="Hair Care Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE NOURISHMENT SYSTEM</p>
        <h1 class="product-title">{{ product.title | default: 'Elaris 7 Korean Hair Care Bundle' }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,240)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Transform your hair routine with the E7 Hair Care Set. This three-product collection is designed to control frizz, strengthen roots, and leave your hair feeling soft, shiny, and beautifully scented. Each product works on its own or together, making styling, protection, and daily care effortless—perfect for home or on-the-go use.</p>
        
        <button class="btn-atc add-to-cart-btn" data-variant-id="{{ product.selected_or_first_available_variant.id }}">BUY THE KIT - {{ product.price | money }}</button>
        <div class="afterpay-line">or 4 payments with <span class="afterpay-badge">Afterpay</span> Ⓘ</div>

        <!-- WHAT'S INSIDE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
            <div class="acc-content">
                <p>The E7 Hair Care Set includes three full-size products in a sleek Elaris pouch: E7 Anti Frizz Keratin Serum, E7 Hair Regrowth Spray, and E7 Floral Blossom Hair Mist.</p>
            </div>
        </div>

        <!-- THE ROUTINE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">THE ROUTINE <div class="accordion-plus">+</div></div>
            <div class="acc-content">
                <p>
                    <strong>Your complete hair care ritual:</strong><br><br>
                    <strong>E7 ANTI FRIZZ KERATIN SERUM — Smooth Control</strong><br> Apply a small amount to damp or dry hair, focusing on mid-lengths and ends. Avoid roots and style as desired. Use before heat styling for added protection.<br><br>
                    <strong>E7 HAIR REGROWTH SPRAY — Stronger Roots</strong><br> Spray directly onto a clean, dry scalp. Massage gently to aid absorption and leave overnight. Use daily for best results.<br><br>
                    <strong>E7 FLORAL BLOSSOM HAIR MIST — Fresh Floral Touch</strong><br> Spray evenly onto dry hair from a short distance. Refresh hair anytime during the day and enjoy a subtle, long-lasting floral fragrance.
                </p>
            </div>
        </div>
      </div>
    </div>

    <!-- 2. Discovery Section -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'hairtwoimagesection1.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'hairtwoimagesection2.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 3. Ingredients Science -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side" style="text-align: center;">
        <p style="font-size:11px; font-weight:700; color:#999; margin-bottom:40px;">THE SCIENCE</p>
        <div style="font-family:Lexend; font-size:42px; font-weight:800; color:#333; line-height:1.1;">The clinically tested performance of the E7 Hair Care Set:</div>
      </div>
      <div class="island-card"><img src="{{ 'hairtextimage.jpg'| file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 4. Results -->
    <section class="results-block">
      <div class="results-header">
        <h2 style="font-family:Lexend; font-size:40px; font-weight:800;">unreal shine</h2>
        <p style="font-size:13px; max-width:320px; color:#555;">Real results from our hair community.</p>
      </div>
      <div class="results-grid">
        <div class="results-pic"></div>
        <div class="results-pic"></div>
        <div class="results-pic"></div>
        <div class="results-pic"></div>
      </div>
    </section>

    <!-- 5. FAQ -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side">
        <h2 style="font-family:Lexend; font-size:42px; font-weight:800; margin-bottom:30px;">Ask away.</h2>
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Can I use the Anti Frizz Keratin Serum on damp and dry hair? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Yes! On damp hair it locks in moisture and smooths strands, and on dry hair it instantly tames flyaways.</div>
        
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">How long until I see results with the Hair Regrowth Spray? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Consistent daily use usually shows noticeable improvement in hair strength and density within 6–8 weeks.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Is the Hair Mist suitable for colored or treated hair? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Absolutely. It is lightweight, non-greasy, and safe for all hair types, including color-treated hair.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Can I use all three products together in one routine? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Yes! Start with the serum after washing, follow with the spray on the scalp, and finish with the hair mist for a refreshed fragrance.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Will the Anti Frizz Serum weigh down fine hair? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">No, the serum is lightweight and formulated to control frizz without heaviness, making it perfect for all hair types.</div>
      </div>
      <div class="island-card"><img src="{{ 'hairfaq.jpg' | file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 6. Reviews -->
    <section class="review-block">
      <div><h4 style="font-size:16px;">Zunaira Tariq</h4><span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span></div>
      <div><div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div><p style="line-height:1.7; color:#333; font-size:15px;">“My hair has never been this smooth! The serum makes styling so easy.”</p></div>
    </section>
    <section class="review-block" style="margin-top:10px;">
      <div><h4 style="font-size:16px;">Sana Iqbal</h4><span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span></div>
      <div><div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div><p style="line-height:1.7; color:#333; font-size:15px;">“I noticed less hair fall within weeks of using the regrowth spray. Amazing results!”</p></div>
    </section>
    <section class="review-block" style="margin-top:10px;">
      <div><h4 style="font-size:16px;">Mahjabeen Riaz</h4><span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span></div>
      <div><div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div><p style="line-height:1.7; color:#333; font-size:15px;">“Love the floral mist! My hair smells fresh all day without feeling sticky.”</p></div>
    </section>
    <section class="review-block" style="margin-top:10px;">
      <div><h4 style="font-size:16px;">Fahad Malik</h4><span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span></div>
      <div><div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div><p style="line-height:1.7; color:#333; font-size:15px;">“The serum and mist combo keeps my hair soft and shiny, even in humid weather.”</p></div>
    </section>
    <section class="review-block" style="margin-top:10px;">
      <div><h4 style="font-size:16px;">Ali Rauf</h4><span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span></div>
      <div><div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div><p style="line-height:1.7; color:#333; font-size:15px;">“My scalp feels healthier, and my hair is growing thicker. So happy with this set.”</p></div>
    </section>
  </main>

  <footer style="padding:100px; text-align:center; font-size:11px; color:#ccc; letter-spacing:0.3em;">ELARIS7.COM</footer>

  <script>
    document.querySelector('.add-to-cart-btn').addEventListener('click', async function() {
      const variantId = this.getAttribute('data-variant-id');
      const btn = this;
      btn.textContent = 'ADDING...';
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        });
        if(res.ok) window.location.href = '/cart';
        else btn.textContent = 'ERROR';
      } catch(e) { btn.textContent = 'ERROR'; }
    });
  </script>

  {{ 'script.js' | asset_url | script_tag }}
</body>
</html>







