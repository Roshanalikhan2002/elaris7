{% layout none %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elaris 7 Korean Brightening Bundle | elaris7</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Lexend:wght@700;800&display=swap" rel="stylesheet">
  <script src="{{ 'script.js' | asset_url }}" defer></script>
  <style>
    :root {
      --bg-color: #ffffff; 
      --surface-color: #f1efea; 
      --text-color: #333333; 
      --text-light: #777777;
      --border-radius: 24px;
      --nav-radius: 30px;
      --font-family-body: 'Inter', Helvetica, Arial, sans-serif;
      --rhode-grey: #5B5A53;
      --bg-page: #f2f2f1;
      --white: #ffffff;
      --placeholder-bg: #e5e5e5;
      --border-color: #d1d1d1;
      --header-height: 115px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }
    body { background-color: var(--bg-page); color: var(--text-color); font-family: var(--font-family-body); font-size: 14px; line-height: 1.5; overflow-x: hidden; width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* 1. Header & Navigation (Standard Site Header) */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      display: flex;
      flex-direction: column;
      z-index: 500;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transform: translateY(0);
      transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .announcement-bar {
      background-color: #f2f2ef;
      color: #7A7973;
      padding: 10px 0;
      text-align: center;
      font-size: 0.65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 10px 12px 0;
      border-radius: 6px;
    }
    .header-main {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 15px 40px;
    }
    .desktop-only { display: flex !important; gap: 20px; list-style: none; }
    .mobile-only { display: none !important; }
    @media (max-width: 850px) {
      .desktop-only { display: none !important; }
      .mobile-only { display: flex !important; }
      .header-main { padding: 10px 15px; }
    }
    .header-nav ul { display: flex; list-style: none; gap: 20px; font-size: 0.8rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
    .header-nav ul li a { color: #5B5A53 !important; }
    .header-logo { display: flex; justify-content: center; padding: 0 40px; }
    .logo-text { font-weight: 800; font-size: 2.2rem; letter-spacing: -0.04em; text-transform: lowercase; color: #333; line-height: 1; }

    /* Main Content Styling from rhode-kit.html */
    .pdp-wrapper { padding-top: 130px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
    .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; height: auto; }
    .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; height: auto; }

    .details-panel::-webkit-scrollbar { width: 6px; }
    .details-panel::-webkit-scrollbar-thumb { background: #dcdcdc; border-radius: 10px; }
    .product-title { font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; }

    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.3s ease; }
    .btn-atc:hover { background: #000; color: #fff; }
    .afterpay-line { text-align: center; font-size: 11px; margin: 15px 0 50px; display: flex; align-items: center; justify-content: center; gap: 5px; color: #555; }
    .afterpay-badge { background: #000; color: #fff; padding: 2px 6px; border-radius: 4px; font-weight: 800; font-size: 10px; }

    /* Accordions */
    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .accordion-plus { width: 22px; height: 22px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
    .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { max-height: 1200px; padding-top: 15px; }
    .accordion-item.active .accordion-plus { transform: rotate(45deg); background: #000; color: #fff; }

    /* Discovery Blocks */
    .discovery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }
    .img-placeholder { width: 100%; height: auto; display: block; }

Line 106: 




    /* Results Grid */
    .results-block { background: #f4f4f2; border-radius: 12px; padding: 70px 60px; margin-top: 20px; }
    .results-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 50px; }
    .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }
    .results-pic { border-radius: 12px; overflow: hidden; aspect-ratio: 4/5; background: var(--placeholder-bg); }

    /* FAQ */
    .faq-text-side { padding: 80px 60px; background: #f2f2f1; display: flex; flex-direction: column; justify-content: center; }
    .faq-q-row { border-top: 1px solid #ddd; padding: 25px 0; display: flex; justify-content: space-between; font-size: 12px; font-weight: 800; text-transform: uppercase; cursor: pointer; }

    /* Review */
    .review-block { background: #fff; border-radius: 12px; padding: 70px 60px; margin-top: 20px; display: grid; grid-template-columns: 280px 1fr; gap: 60px; position: relative; }
    .v-badge::after { content: '✔'; background: #000; color: #fff; width: 14px; height: 14px; border-radius: 50%; font-size: 8px; display: inline-flex; align-items: center; justify-content: center; margin-left: 5px; vertical-align: middle; }

    @media (max-width: 1024px) {
      .header-main { padding: 10px 15px; grid-template-columns: auto 1fr auto; }
      .pdp-wrapper { padding-top: 110px; padding-left: 0; padding-right: 0; }
      .pdp-main-box { grid-template-columns: 1fr; height: auto; border: none; border-radius: 0; }
      .gallery-wrap { height: 450px; padding: 0; margin-bottom: 20px; }
      .details-panel { border-left: none; padding: 30px 15px; height: auto; overflow-y: visible; background: transparent; }
      .discovery-grid { grid-template-columns: 1fr; gap: 10px; }
      .island-card { height: 400px; }
      .results-header { flex-direction: column; gap: 20px; }
      .results-grid { display: flex; overflow-x: auto; gap: 15px; padding-bottom: 20px; }
      .results-pic { min-width: 85%; flex-shrink: 0; }
      .review-block { grid-template-columns: 1fr; padding: 40px 20px; gap: 40px; }
    }

    /* Footer */
    .site-footer-rhode { background: #fff; padding: 80px 40px; border-top: 1px solid #eee; text-align: center; }
    .logo-text-giant { font-weight: 800; font-size: 7rem; letter-spacing: -0.05em; color: #333; opacity: 1; margin-bottom: 40px; }
  .bogo-inline-section, .bogo-btn, #bogoDrawer, #bogoOverlay { display: none !important; }
</style>
{{ 'styles.css' | asset_url | stylesheet_tag }}
</head>
<body>

  {% section 'header' %}

  <main class="pdp-wrapper">
    <!-- 1. Top Section -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'main.jpg' | file_img_url: 'master' }}" class="img-placeholder" alt="Brightening Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE BRIGHTENING SYSTEM</p>
        <h1 class="product-title">Elaris 7 Korean Brightening Bundle</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (2,199)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Unlock your skin’s natural radiance with the Elaris 7 Korean Brightening Bundle. This system targets dullness and dark spots while maintaining barrier hydration.</p>
        
        <button class="btn-atc add-to-cart-btn" data-variant-id="45678901234567">BUY THE KIT - RS. 4,500</button>
        <div class="afterpay-line">or 4 payments of RS. 1,125 with <span class="afterpay-badge">Afterpay</span> Ⓘ</div>

        <!-- WHAT'S INSIDE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
          <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
          <div class="acc-content">
            <p>The bundle includes four full-size products: E7 Brightening Gel Cleanser, E7 Glow Renewal Toner, E7 Tranexamic Brightening Serum, and E7 Korean Gel Sunscreen.</p>
          </div>
        </div>

        <!-- THE ROUTINE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
          <div class="acc-head">THE ROUTINE <div class="accordion-plus">+</div></div>
          <div class="acc-content">
            <p style="white-space: pre-line;">
              <strong>E7 BRIGHTENING GEL CLEANSER — Pure Refresh</strong>
              Use morning and night. Apply to wet skin, massage gently and rinse.

              <strong>E7 GLOW RENEWAL TONER — Clarity Boost</strong>
              Evening use 2-3 times per week. Sweep over face with cotton pad.

              <strong>E7 TRANEXAMIC BRIGHTENING SERUM — Tone Correct</strong>
              Apply 2-3 drops morning and night and press into skin.

              <strong>E7 KOREAN GEL SUNSCREEN — Daily Shield</strong>
              Final morning step. Generously apply to protect against UV damage.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Discovery Section -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'twoimagessection1.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'twoimagessection2.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 3. Ingredients Science -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side" style="text-align: center;">
        <p style="font-size:11px; font-weight:700; color:#999; margin-bottom:40px;">THE ROUTINE</p>
        <div style="font-family:Lexend; font-size:42px; font-weight:800; color:#333; line-height:1.1;">Four steps to a luminous, even-toned glow</div>
      </div>
      <div class="island-card"><img src="{{ 'textimage.jpg'| file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 4. Results -->
    <section class="results-block">
      <div class="results-header">
        <h2 style="font-family:Lexend; font-size:40px; font-weight:800;">results are in</h2>
        <p style="font-size:13px; max-width:320px; color:#555;">Clinically tested power for visible brightness.</p>
      </div>
      <div class="results-grid">
        <div class="results-pic" style="background: transparent;"></div>
        <div class="results-pic" style="background: transparent;"></div>
        <div class="results-pic" style="background: transparent;"></div>
        <div class="results-pic" style="background: transparent;"></div>
      </div>
    </section>

    <!-- 5. FAQ -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side">
        <h2 style="font-family:Lexend; font-size:42px; font-weight:800; margin-bottom:30px;">Ask away.</h2>
        
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Can I use the toner every night? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Start 2–3 times per week and increase as tolerated to avoid irritation from exfoliating acids.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Is the Tranexamic Brightening Serum safe for sensitive skin? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Yes. It combines gentle brightening actives with soothing ingredients like centella to calm the skin.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Can I layer serum under sunscreen? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Absolutely. Applying serum first enhances hydration and allows sunscreen to absorb evenly.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Will the Korean Gel Sunscreen leave a white cast? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">No. It blends effortlessly, leaving a lightweight, non-greasy finish suitable for all skin tones.</div>

        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">Can this bundle be used in humid climates? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Yes. The lightweight, non-greasy formula is ideal for warm and humid environments.</div>
      </div>
      <div class="island-card"><img src="{{ 'faq.jpg' | file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 6. Review -->
    <section class="review-block">
      <div>
