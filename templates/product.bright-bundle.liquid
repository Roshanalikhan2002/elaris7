  </main>

  <footer class="site-footer-rhode">
    <a href="/" class="footer-logo-massive" style="text-decoration:none; display:block; text-align:center;"><h1 class="logo-text-giant">elaris7</h1></a>
    <div style="font-size:11px; color:#999; letter-spacing:0.3em;">&copy; 2026 ELARIS7.COM</div>
