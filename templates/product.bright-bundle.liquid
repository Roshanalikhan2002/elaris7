<style>
  /* Bundle Page Content Styles */
  .pdp-wrapper { padding-top: 20px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }

    :root {
      --bg-color: #ffffff; 
      --surface-color: #f1efea; 
      --text-color: #333333; 
      --text-light: #777777;
      --border-radius: 24px;
      --nav-radius: 30px;
      --font-family-body: 'Inter', Helvetica, Arial, sans-serif;
      --rhode-grey: #5B5A53;
      --bg-page: #f2f2f1;
      --white: #ffffff;
      --placeholder-bg: #e5e5e5;
      --border-color: #d1d1d1;
      --header-height: 115px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }
    body { background-color: var(--bg-page); color: var(--text-color); font-family: var(--font-family-body); font-size: 14px; line-height: 1.5; overflow-x: hidden; width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* Main Content Styling */
    .pdp-wrapper { padding-top: 20px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
    .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; height: auto; }
    .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; height: auto; }

    .details-panel::-webkit-scrollbar { width: 6px; }
    .details-panel::-webkit-scrollbar-thumb { background: #dcdcdc; border-radius: 10px; }
    .product-title { line-height: 1.05; font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; }

    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.3s ease; }
    .btn-atc:hover { background: #000; color: #fff; }

    /* Accordions */
    .accordion-item { border-top: 1px solid rgba(0,0,0,0.05); border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .accordion-plus { width: 22px; height: 22px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
    .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { max-height: 1200px; padding-top: 20px; }
    .accordion-item.active .accordion-plus { transform: rotate(45deg); background: #000; color: #fff; }

    /* Discovery Blocks */
    .discovery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }
    .img-placeholder { width: 100%; height: auto; display: block; }

    @media (max-width: 1024px) {
      .pdp-wrapper { padding-top: 20px; padding-left: 0; padding-right: 0; }
      .pdp-main-box { grid-template-columns: 1fr; height: auto; border: none; border-radius: 0; }
      .gallery-wrap { height: auto; padding: 0; margin-bottom: 20px; }
      .details-panel { border-left: none; padding: 30px 15px; height: auto; overflow-y: visible; background: transparent; }
      .discovery-grid { grid-template-columns: 1fr; gap: 10px; }
      .island-card { height: 400px; }
    }

    /* Editorial Sections CSS */
    .meet-product-section { padding: 80px 40px; background: #fff; margin-bottom: 20px; border-radius: 12px; }
    .meet-title { text-align: center; font-size: 2.5rem; font-weight: 800; color: #5b5a53; margin-bottom: 50px; }
    .meet-carousel { display: flex; gap: 20px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
    .meet-carousel::-webkit-scrollbar { display: none; }
    .meet-carousel img { flex: 0 0 23%; min-width: 250px; border-radius: 12px; scroll-snap-align: start; }
    
    .breakdown-section { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; min-height: 600px; }
    .breakdown-content { background: #f2f0ed; border-radius: 12px; padding: 60px; display: flex; flex-direction: column; justify-content: center; }
    .bd-title { font-size: 2rem; font-weight: 800; color: #5b5a53; margin-bottom: 30px; }
    .bd-row { display: flex; padding: 15px 0; border-bottom: 1px solid rgba(0,0,0,0.05); gap: 20px; }
    .bd-label { font-weight: 800; font-size: 0.75rem; color: #5b5a53; width: 120px; text-transform: uppercase; }
    .bd-val { font-size: 0.9rem; color: #333; flex: 1; }
    .breakdown-image img { width: 100%; height: 100%; object-fit: cover; border-radius: 12px; }

    .faq-section { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 12px; background: #fff; border-radius: 12px; overflow: hidden; margin-bottom: 60px; }
    .faq-content { padding: 60px; background: #f2f0ed; }
    .faq-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 40px; }
    .faq-item { border-bottom: 1px solid rgba(0,0,0,0.1); padding: 25px 0; display: flex; justify-content: space-between; align-items: flex-start; cursor: pointer; }
    .faq-qa { flex: 1; }
    .faq-question { font-size: 1rem; font-weight: 800; color: #333; display: block; margin-bottom: 10px; }
    .faq-answer { font-size: 0.9rem; color: #5b5a53; line-height: 1.6; display: none; }
    .faq-item.active .faq-answer { display: block; }
    .faq-image-col img { width: 100%; height: 100%; object-fit: cover; }

    @media (max-width: 768px) {
      .meet-product-section { padding: 40px 20px; }
      .breakdown-section, .faq-section { grid-template-columns: 1fr; }
      .breakdown-content, .faq-content { padding: 30px 20px; }
      .meet-carousel img { flex: 0 0 85%; }
    }
</style>

  {% section 'header' %}

  <main class="page-wrapper" style="padding-top: 155px;">
    <!-- 1. Top Section -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ product.featured_image | img_url: 'master' }}" class="img-placeholder" alt="{{ product.title }}">
      </div>
      <div class="details-panel">
        <h1 class="product-title">{{ product.title }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★★★★★ (1,620)</div>
        <div style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">{{ product.description }}</div>
        
        <button class="btn-atc add-to-cart-btn" data-variant-id="{{ product.selected_or_first_available_variant.id }}">BUY THE KIT - {{ product.price | money }}</button>

        <!-- WHAT'S INSIDE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
          <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
          <div class="acc-content">
            <p>Our Brightening Bundle features the perfect combination of products to even out skin tone and reveal a natural glow.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Discovery Section (2 Image) -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'v2-bright-spread.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'v2-bright-spoon.jpg' | asset_url }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 3. Product Breakdown Section (Text with Image) -->
    <section class="breakdown-section">
      <div class="breakdown-content">
        <h2 class="bd-title">Targeted Brightening Care</h2>
        <div class="bd-table">
          <div class="bd-row">
            <span class="bd-label">GOOD FOR:</span><span class="bd-val">Dull skin, dark spots, and achieving an even skin tone</span>
          </div>
          <div class="bd-row">
            <span class="bd-label">FEELS LIKE:</span><span class="bd-val">A skin-reviving routine that feels energetic and lightweight</span>
          </div>
          <div class="bd-row">
            <span class="bd-label">LOOKS LIKE:</span><span class="bd-val">Radiant, glowing, and more youthful-looking complexion</span>
          </div>
          <div class="bd-row">
            <span class="bd-label">FYI:</span><span class="bd-val">Vitamin C Enriched • Advanced Formula • Daily Use • High Performance</span>
          </div>
        </div>
      </div>
      <div class="breakdown-image">
        <img src="{{ 'v2-bright-plate.jpg' | asset_url }}" alt="Bundle Breakdown">
      </div>
    </section>

    <!-- 4. Meet the Product Section (4 Image Carousel) -->
    <section class="meet-product-section">
      <h2 class="meet-title">Meet the Brightening Essentials</h2>
      <div class="meet-carousel">
        <img src="{{ 'v2-bright-1.jpeg' | asset_url }}" alt="Step 1">
        <img src="{{ 'v2-bright-2.jpg' | asset_url }}" alt="Step 2">
        <img src="{{ 'v2-bright-3.jpg' | asset_url }}" alt="Step 3">
        <img src="{{ 'v2-bright-4.jpg' | asset_url }}" alt="Step 4">
      </div>
    </section>

    <!-- 5. FAQ Section -->
    <section class="faq-section">
      <div class="faq-content">
        <h2 class="faq-title">FAQ</h2>
        <div class="faq-accordion">
          <div class="faq-item" onclick="this.classList.toggle('active')">
            <div class="faq-qa">
              <span class="faq-question">How do I use this bundle?</span>
              <p class="faq-answer">Follow the included step-by-step guide for optimal brightening results.</p>
            </div>
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-item" onclick="this.classList.toggle('active')">
            <div class="faq-qa">
              <span class="faq-question">Can I use this with other products?</span>
              <p class="faq-answer">Yes, it integrates perfectly with your existing skincare routine.</p>
            </div>
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-item" onclick="this.classList.toggle('active')">
            <div class="faq-qa">
              <span class="faq-question">When will I see results?</span>
              <p class="faq-answer">Most users report a visible glow within the first 10 days of use.</p>
            </div>
            <span class="faq-icon">+</span>
          </div>
        </div>
      </div>
      <div class="faq-image-col">
        <img src="{{ 'v2-bright-faq.jpg' | asset_url }}" alt="FAQ View">
      </div>
    </section>
  </main>

  {% section 'footer' %}

<script>
    // Main Add to Cart Logic
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            const b = this;
            const originalText = b.innerHTML;
            if (b.disabled) return;
            b.innerHTML = 'ADDING TO BAG...';
            b.disabled = true;

            try {
                const mainVariantId = b.getAttribute('data-variant-id');
                const response = await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ items: [{ id: mainVariantId, quantity: 1 }] })
                });

                const data = await response.json();
                if (!response.ok) throw new Error(data.description || data.message || 'Could not add to bag');
                window.location.href = '/cart';
            } catch (error) {
                console.error('Cart Addition Error:', error);
                alert('Bag Error: ' + error.message);
                b.innerHTML = originalText;
                b.disabled = false;
            }
        });
    });
  </script>

