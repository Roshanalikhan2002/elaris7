{%- comment -%} Removed layout none to inherit theme.liquid header/footer {%- comment -%}

<style>
    /* Content specific styles only */
    .pdp-wrapper { padding-top: 40px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; font-family: 'Inter', sans-serif; }
    .pdp-main-box { background: #fff; border: 1px solid #d1d1d1; border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; overflow: hidden; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; }
    .details-panel { padding: 60px; border-left: 1px solid #d1d1d1; background: #fdfdfd; }
    .product-title { font-family: 'Lexend', sans-serif !important; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; text-transform: uppercase; color: #000 !important; }

    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; color: #000; text-align: center; text-decoration: none; display: block; }
    .btn-atc:hover { background: #000; color: #fff; }

    .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .acc-content { display: none; padding-top: 15px; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { display: block; }

    .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }

    @media (max-width: 1024px) {
        .pdp-main-box { grid-template-columns: 1fr; }
        .details-panel { border-left: none; padding: 30px 15px; }
        .product-title { font-size: 32px; }
        .discovery-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="pdp-wrapper">
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'glassmain.jpg' | file_img_url: 'master' }}" style="width:100%; height:auto;" alt="Glass Skin Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE HYDRATION SYSTEM</p>
        <h1 class="product-title">{{ product.title | default: 'Elaris 7 Korean Glass Skin Bundle' }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Discover the ultimate glow ritual with the E7 Glass Skin Set. Powered by five multitasking essentials.</p>
        
        <a href="/cart/add?id={{ product.variants.first.id }}&quantity=1" class="btn-atc">BUY THE KIT - {{ product.price | money }}</a>

        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div style="font-size:18px;">+</div></div>
            <div class="acc-content"><p>Includes Face Wash, Serum, Moisturizer, Sunscreen, and Night Cream.</p></div>
        </div>
      </div>
    </div>

    <!-- Additional sections like FAQ and Reviews go here -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'glasstwoimagesection1.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'glasstwoimagesection2.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>
</div>
