<style>
  /* Bundle Page Content Styles */
  .pdp-wrapper { padding-top: 20px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }

    :root {
      --bg-color: #ffffff; 
      --surface-color: #f1efea; 
      --text-color: #333333; 
      --text-light: #777777;
      --border-radius: 24px;
      --nav-radius: 30px;
      --font-family-body: 'Inter', Helvetica, Arial, sans-serif;
      --rhode-grey: #5B5A53;
      --bg-page: #f2f2f1;
      --white: #ffffff;
      --placeholder-bg: #e5e5e5;
      --border-color: #d1d1d1;
      --header-height: 115px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }
    body { background-color: var(--bg-page); color: var(--text-color); font-family: var(--font-family-body); font-size: 14px; line-height: 1.5; overflow-x: hidden; width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* Main Content Styling */
    .pdp-wrapper { padding-top: 20px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
    .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; }
    .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; height: auto; }
    .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; height: auto; }

    .details-panel::-webkit-scrollbar { width: 6px; }
    .details-panel::-webkit-scrollbar-thumb { background: #dcdcdc; border-radius: 10px; }
    .product-title { line-height: 1.05; font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; }

    .btn-atc { width: 100%; padding: 22px; border-radius: 50px; border: 1.5px solid #000; background: #fff; font-weight: 700; text-transform: uppercase; cursor: pointer; font-size: 13px; transition: all 0.3s ease; }
    .btn-atc:hover { background: #000; color: #fff; }

    /* Accordions */
    .accordion-item { border-top: 1px solid rgba(0,0,0,0.05); border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
    .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .accordion-plus { width: 22px; height: 22px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
    .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; font-size: 14px; line-height: 1.6; color: #444; }
    .accordion-item.active .acc-content { max-height: 1200px; padding-top: 20px; }
    .accordion-item.active .accordion-plus { transform: rotate(45deg); background: #000; color: #fff; }

    /* Discovery Blocks */
    .discovery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px; }
    .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }
    .img-placeholder { width: 100%; height: auto; display: block; }

    @media (max-width: 1024px) {
      .pdp-wrapper { padding-top: 20px; padding-left: 0; padding-right: 0; }
      .pdp-main-box { grid-template-columns: 1fr; height: auto; border: none; border-radius: 0; }
      .gallery-wrap { height: auto; padding: 0; margin-bottom: 20px; }
      .details-panel { border-left: none; padding: 30px 15px; height: auto; overflow-y: visible; background: transparent; }
      .discovery-grid { grid-template-columns: 1fr; gap: 10px; }
      .island-card { height: 400px; }
    }
</style>

<div class="pdp-wrapper">
    <!-- 1. Top Section -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ product.featured_image | img_url: 'master' }}" class="img-placeholder" alt="{{ product.title }}">
      </div>
      <div class="details-panel">
        <h1 class="product-title">{{ product.title }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <div style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">{{ product.description }}</div>
        
        <button class="btn-atc add-to-cart-btn" data-variant-id="{{ product.selected_or_first_available_variant.id }}">BUY THE KIT - {{ product.price | money }}</button>

        <!-- WHAT'S INSIDE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
          <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
          <div class="acc-content">
            <p>Includes all essential items for this specialized bundle.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Discovery Section -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'twoimagessection1.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'twoimagessection2.jpg' | file_img_url: 'master' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>
  </div>

  <script>
    // Main Add to Cart Logic
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            const b = this;
            const originalText = b.innerHTML;
            if (b.disabled) return;
            b.innerHTML = 'ADDING TO BAG...';
            b.disabled = true;

            try {
                const mainVariantId = b.getAttribute('data-variant-id');
                const response = await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ items: [{ id: mainVariantId, quantity: 1 }] })
                });

                const data = await response.json();
                if (!response.ok) throw new Error(data.description || data.message || 'Could not add to bag');
                window.location.href = '/cart';
            } catch (error) {
                console.error('Cart Addition Error:', error);
                alert('Bag Error: ' + error.message);
                b.innerHTML = originalText;
                b.disabled = false;
            }
        });
    });
  </script>
