{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elaris 7 | Korean Glass Skin Bundle</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Lexend:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-page: #f2f2f1;
            --white: #ffffff;
            --text-color: #000000;
            --placeholder-bg: #e5e5e5;
            --border-color: #d1d1d1;
            --header-height: 80px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-page); color: var(--text-color); overflow-x: hidden; width: 100%; }
        .site-container { max-width: 1440px; margin: 0 auto; padding: 0 20px; width: 100%; }

        header { 
          display: grid; 
          grid-template-columns: 1fr auto 1fr; 
          align-items: center; 
          height: var(--header-height); 
          background: var(--bg-page); 
          position: sticky; 
          top: 0; 
          z-index: 1000; 
          padding: 0 20px;
        }
        .header-logo { font-family: 'Lexend'; font-size: 34px; font-weight: 800; letter-spacing: -0.05em; text-decoration: none; color: #000; text-transform: lowercase; }
        .nav-links { display: flex; gap: 30px; }
        .nav-links.right { justify-content: flex-end; }
        .nav-links a { text-decoration: none; color: #000; font-size: 13px; font-weight: 700; text-transform: uppercase; }

        /* Main Content Styling */
        .pdp-wrapper { padding-top: 130px; max-width: 1440px; margin: 0 auto; padding-left: 12px; padding-right: 12px; width: 100%; }
        .pdp-main-box { background: var(--white); border: 1px solid var(--border-color); border-radius: 12px; display: grid; grid-template-columns: 1.15fr 0.85fr; margin-bottom: 20px; height: auto; }
        .gallery-wrap { display: flex; align-items: flex-start; justify-content: center; background: #fff; height: auto; }
        .details-panel { padding: 60px; border-left: 1px solid var(--border-color); background: #fdfdfd; height: auto; }

        .details-panel::-webkit-scrollbar { width: 6px; }
        .details-panel::-webkit-scrollbar-thumb { background: #dcdcdc; border-radius: 10px; }
        .product-title { font-family: 'Lexend'; font-size: 48px; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 30px; line-height: 0.9; }

        .btn-atc { 
          width: 100%; 
          padding: 22px; 
          border-radius: 50px; 
          border: 1.5px solid #000; 
          background: #fff; 
          font-weight: 700; 
          text-transform: uppercase; 
          cursor: pointer; 
          font-size: 13px;
          transition: all 0.2s;
        }
        .btn-atc:hover { background: #000; color: #fff; }

        .afterpay-line { text-align: center; font-size: 11px; margin: 15px 0 50px; display: flex; align-items: center; justify-content: center; gap: 5px; color: #555; }
        .afterpay-badge { background: #000; color: #fff; padding: 2px 6px; border-radius: 4px; font-weight: 800; font-size: 10px; }

        /* Accordions */
        .accordion-item { border-top: 1px solid #eee; padding: 25px 0; cursor: pointer; }
        .acc-head { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 800; text-transform: uppercase; }
        .accordion-plus { width: 22px; height: 22px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
        .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; font-size: 14px; line-height: 1.6; color: #444; }
        .accordion-item.active .acc-content { max-height: 1200px; padding-top: 15px; }
        .accordion-item.active .accordion-plus { transform: rotate(45deg); background: #000; color: #fff; }

        /* Discovery Blocks */
        .discovery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
        .island-card { border-radius: 12px; overflow: hidden; background: #fff; height: 600px; position: relative; }
        .img-placeholder { width: 100%; height: auto; display: block; }

        /* Results Grid */
        .results-block { background: #f4f4f2; border-radius: 12px; padding: 70px 60px; margin-top: 20px; }
        .results-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 50px; }
        .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }
        .results-pic { border-radius: 12px; overflow: hidden; aspect-ratio: 4/5; background: #ddd; }

        /* FAQ */
        .faq-text-side { padding: 80px 60px; background: #f2f2f1; display: flex; flex-direction: column; justify-content: center; }
        .faq-q-row { border-top: 1px solid #ddd; padding: 25px 0; display: flex; justify-content: space-between; font-size: 12px; font-weight: 800; text-transform: uppercase; cursor: pointer; }
        .acc-content.active { max-height: 200px; }

        /* Review */
        .review-block { background: #fff; border-radius: 12px; padding: 70px 60px; margin-top: 20px; display: grid; grid-template-columns: 280px 1fr; gap: 60px; position: relative; }
        .v-badge::after { content: '✔'; background: #000; color: #fff; width: 14px; height: 14px; border-radius: 50%; font-size: 8px; display: inline-flex; align-items: center; justify-content: center; margin-left: 5px; vertical-align: middle; }

        @media (max-width: 1024px) {
            .pdp-wrapper { padding-top: 90px; }
            header { grid-template-columns: auto 1fr auto; padding: 0 15px; }
            .nav-links { display: none; }
            .header-logo { font-size: 26px; }
            .pdp-main-box { grid-template-columns: 1fr; height: auto; border: none; border-radius: 0; }
            .gallery-wrap { height: auto; padding: 0; margin-bottom: 20px; }
            .details-panel { border-left: none; padding: 30px 15px; height: auto; overflow-y: visible; background: transparent; }
            .discovery-grid { grid-template-columns: 1fr; gap: 10px; }
            .island-card { height: 400px; }
            .results-grid { display: flex; overflow-x: auto; gap: 15px; }
            .results-pic { min-width: 85%; }
            .review-block { grid-template-columns: 1fr; padding: 40px 20px; gap: 40px; }
        }

    </style>
</head>
<body>

  <header>
    <div style="font-weight:700; font-size:12px; cursor:pointer;" onclick="window.location.href='/'">HOME</div>
    <div class="nav-links">
        <a href="/">HOME</a>
        <a href="/pages/about">ABOUT</a>
    </div>
    <a href="/" class="header-logo">elaris7</a>
    <div class="nav-links right">
        <a href="/search">SEARCH</a>
        <a href="/account">ACCOUNT</a>
        <a href="/cart">CART (0)</a>
    </div>
    <div style="font-weight:700; font-size:12px;">CART (0)</div>
  </header>

  <main class="pdp-wrapper">
    <!-- 1. Top Section -->
    <div class="pdp-main-box">
      <div class="gallery-wrap">
        <img src="{{ 'glassmain.jpg' | file_img_url: 'master' }}" class="img-placeholder" alt="Glass Skin Bundle">
      </div>
      <div class="details-panel">
        <p style="font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">COMPLETE HYDRATION SYSTEM</p>
        <h1 class="product-title">{{ product.title | default: 'Elaris 7 Korean Glass Skin Bundle' }}</h1>
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 30px; letter-spacing: 2px;">★ ★ ★ ★ ★ (1,850)</div>
        <p style="font-size: 15px; line-height: 1.7; margin-bottom: 40px; color: #333;">Achieve the ultimate luminous finish with our Korean Glass Skin Bundle. This set focuses on deep hydration, barrier repair, and that signature dewy glow.</p>
        
        <button class="btn-atc add-to-cart-btn" data-variant-id="{{ product.selected_or_first_available_variant.id }}">BUY THE KIT - {{ product.price | money }}</button>
        <div class="afterpay-line">or 4 payments with <span class="afterpay-badge">Afterpay</span> Ⓘ</div>

        <!-- WHAT'S INSIDE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">WHAT'S INSIDE <div class="accordion-plus">+</div></div>
            <div class="acc-content">
                <p>Curated for maximum glow, this bundle includes: Centella Night Cream, Renewal Cleanser, Centella Serum, and Hydra Burst Moisturizer.</p>
            </div>
        </div>

        <!-- THE ROUTINE -->
        <div class="accordion-item" onclick="this.classList.toggle('active')">
            <div class="acc-head">THE ROUTINE <div class="accordion-plus">+</div></div>
            <div class="acc-content">
                <p>
                    <strong>STEP 1: RENEWAL CLEANSER</strong> Purify and prep.
                    <strong>STEP 2: CENTELLA SERUM</strong> Deep hydration boost.
                    <strong>STEP 3: HYDRA BURST MOISTURIZER</strong> Lock in moisture.
                    <strong>STEP 4: CENTELLA NIGHT CREAM</strong> Overnight recovery.
                </p>
            </div>
        </div>
      </div>
    </div>

    <!-- 2. Discovery Section -->
    <section class="discovery-grid">
      <div class="island-card"><img src="{{ 'glasstwoimagesection1.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
      <div class="island-card"><img src="{{ 'glasstwoimagesection2.jpg' | file_img_url: '1000x' }}" class="wi-image" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 3. Ingredients Science -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side" style="text-align: center;">
        <p style="font-size:11px; font-weight:700; color:#999; margin-bottom:40px;">THE SCIENCE</p>
        <div style="font-family:Lexend; font-size:42px; font-weight:800; color:#333; line-height:1.1;">Korean Centella & Hyaluronic Acid</div>
      </div>
      <div class="island-card"><img src="{{ 'glasstextimage.jpg'| file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 4. Results -->
    <section class="results-block">
      <div class="results-header">
        <h2 style="font-family:Lexend; font-size:40px; font-weight:800;">the glow is real</h2>
        <p style="font-size:13px; max-width:320px; color:#555;">Real results from our glass skin community.</p>
      </div>
      <div class="results-grid">
        <div class="results-pic"></div>
        <div class="results-pic"></div>
        <div class="results-pic"></div>
        <div class="results-pic"></div>
      </div>
    </section>

    <!-- 5. FAQ -->
    <section class="discovery-grid">
      <div class="island-card faq-text-side">
        <h2 style="font-family:Lexend; font-size:42px; font-weight:800; margin-bottom:30px;">Ask away.</h2>
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">IS THIS FOR ALL SKIN TYPES? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Yes, our centella-based formula is gentle enough for sensitive skin but effective for oily and combination types.</div>
        
        <div class="faq-q-row" onclick="this.nextElementSibling.classList.toggle('active')">HOW LONG TO SEE RESULTS? <div class="accordion-plus">+</div></div>
        <div class="acc-content" style="padding: 0 10px 20px; color: #555;">Most users notice a difference in hydration immediately, with visible 'glass skin' glow developing within 2 weeks.</div>
      </div>
      <div class="island-card"><img src="{{ 'glassfaq.jpg' | file_img_url: '1000x' }}" style="width:100%; height:100%; object-fit:cover;"></div>
    </section>

    <!-- 6. Review -->
    <section class="review-block">
      <div>
        <h4 style="font-size:16px;">Amna Khan</h4>
        <span class="v-badge" style="display:flex; font-size:11px; color:#777; align-items:center;">Verified Buyer</span>
      </div>
      <div>
        <div style="font-size:18px; margin-bottom:15px;">★ ★ ★ ★ ★</div>
        <p style="line-height:1.7; color:#333; font-size:15px;">“The best bundle for achieving that dewy look. My skin has never felt this hydrated.”</p>
      </div>
      <div style="position:absolute; right:70px; top:70px; font-size:11px; color:#999;">Just now</div>
    </section>
  </main>

  <footer style="padding:100px; text-align:center; font-size:11px; color:#ccc; letter-spacing:0.3em;">ELARIS7.COM</footer>

  <script>
    // Simple AJAX Add to Cart for custom PDP
    document.querySelector('.add-to-cart-btn').addEventListener('click', async function() {
      const variantId = this.getAttribute('data-variant-id');
      const btn = this;
      btn.textContent = 'ADDING...';
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        });
        if(res.ok) window.location.href = '/cart';
        else btn.textContent = 'ERROR';
      } catch(e) { btn.textContent = 'ERROR'; }
    });
  </script>

</body>
</html>
