}

/* Hover CTA Ã¢â‚¬â€ slides up from bottom */
.card-rhode-hover {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 18px 22px;
  display: flex;
  justify-content: center;
