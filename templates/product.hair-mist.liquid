/*   VALUES / MISSION SECTION (Above Footer)                 */
/* ========================================================= */
.values-section {
  background-color: #f3f0ec; /* Rhode signature light beige */
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 12px;
  display: grid;
  grid-template-columns: 1fr;
}

.values-content-col {
  display: flex;
  flex-direction: column;
  justify-content: center; /* keep centered vertically */
  height: 100%;
}

.values-image-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: stretch;
  justify-content: center;
}

.values-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.values-content {
  padding: 40px 40px 0 40px; /* balanced padding */
  text-align: left;
}

.values-statement {
  font-size: 1.55rem;
  line-height: 1.15;
  color: #5b5a53;
  margin-bottom: 24px;
  letter-spacing: -0.02em;
  font-weight: 500;
}

.values-statement strong {
  font-weight: 800;
  color: #333;
}

.btn-pill-values {
  display: inline-block;
  padding: 10px 20px;
  font-size: 0.65rem;
  font-weight: 700;
  color: #5b5a53;
  border: 1px solid #5b5a53;
  border-radius: 50px;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: transparent;
  transition: all 0.2s ease;
}

.btn-pill-values:hover {
  background: #5b5a53;
  color: #fff;
}

.values-accordion {
  padding: 0 40px 40px;
  margin-top: 32px; /* Pull it right under the button */
}

.values-accordion-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid rgba(91, 90, 83, 0.15);
  cursor: pointer;
  color: #5b5a53;
  font-weight: 700;
  font-size: 0.95rem;
  letter-spacing: -0.01em;
}

.values-accordion-item:last-child {
  border-bottom: none;
}

.values-accordion-item .accordion-icon {
  font-size: 1.2rem;
  font-weight: 400;
  transition: transform 0.3s ease;
}

.values-accordion-item.active .accordion-icon {
  transform: rotate(45deg); /* Turns '+' into 'x' */
}

/* Mobile Adjustments for Values Section */
@media (max-width: 768px) {
  .values-section {
    grid-template-columns: 1fr;
  }
  
  /* On mobile, place the image on top */
  .values-image-wrap {
    order: 1;
    aspect-ratio: 1 / 1;
  }

  .values-content {
    padding: 30px 20px 20px;
  }

  .values-accordion {
    padding: 0 20px 20px;
  }

  .values-statement {
    font-size: 1.3rem; 
  }
}
