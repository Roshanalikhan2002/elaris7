{% layout none %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Floral Blossom Hair Mist | elaris7</title>
  <style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

:root {
  --bg-color: #ffffff; 
  --surface-color: #f1efea; 
  --text-color: #333333; 
  --text-light: #777777;
  --border-radius: 24px; /* Rhode exact match */
  --nav-radius: 30px;
  --font-family-body: 'Inter', Helvetica, Arial, sans-serif;
  --rhode-grey: #5B5A53;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-family: var(--font-family-body);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

html {
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }

.page-wrapper {
  padding-top: 115px; /* Tighter balance for header & announcement bar */
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 1. Header & Navigation */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  z-index: 500;
  background: rgba(255, 255, 255, 0.97);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transform: translateY(0);
  transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
}

.announcement-bar {
  background-color: #f2f2ef;
  color: #7A7973;
  padding: 10px 0;
  text-align: center;
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  width: auto;
  margin: 10px 12px 0;
  border-radius: 6px;
}

.header-main {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 15px 40px;
}

.desktop-only {
  display: flex !important;
  gap: 20px;
  list-style: none;
}

.mobile-only {
  display: none !important;
}

@media (max-width: 850px) {
  .desktop-only {
    display: none !important;
  }
  .mobile-only {
    display: flex !important;
  }
  .header-main {
    padding: 10px 15px;
  }
}

.mobile-header-icons {
  display: flex;
  align-items: center;
  gap: 20px;
}

.mobile-icon {
  display: flex;
  align-items: center;
  color: #333;
}

.cart-icon-wrapper {
  position: relative;
}

.cart-count {
  position: absolute;
  top: -8px;
  right: -8px;
  background: transparent;
  color: #333;
  font-size: 0.65rem;
  font-weight: 800;
  width: 14px;
  height: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-hidden {
  transform: translateY(-250%);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.6, 1);
  pointer-events: none;
}

/* Rhode Split Category (High Fidelity) */
.split-category-wrapper {
  margin: 0 12px 12px;
}


.header-visible {
  transform: translateY(0);
  transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
}

.site-header.scrolled-bg {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
}

.site-header.scrolled-bg .header-main {
  padding: 10px 60px;
}

.menu-trigger {
  display: none;
  flex-direction: column;
  gap: 4px;
  cursor: pointer;
  width: 20px;
}

.menu-trigger span {
  display: block;
  width: 100%;
  height: 2px;
  background: #333;
  border-radius: 2px;
}

/* Mobile Header Adjustment */
@media (max-width: 850px) {
  /*
   * Rhode-exact layout:
   * - Announcement bar: on white bg, in normal flow
   * - Header-main: absolute, top:100% Ã¢â€ â€™ floats RIGHT ON TOP of the hero image
   * - Hero card: starts immediately after announcement bar
   */
  .site-header {
    position: fixed;
    background: transparent;
    overflow: visible; 
    z-index: 1000;
    top: 0;
  }

  .announcement-bar {
    margin: 15px 16px 8px; /* 15px top matches Rhode body's 15px top padding */
    padding: 9px 0;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    border-radius: 8px;
    position: relative;
    z-index: 5;
  }

  /* header-main sits at the TOP of the hero image */
  .header-main { 
    position: absolute;
    top: 100%; /* starts exactly at bottom of site-header = top of hero */
    left: 0;
    right: 0;
    height: 48px;
    padding: 0 16px; /* Aligned with hero card's 16px margins = icon hugs card edge */
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    z-index: 600;
  }
  
  .menu-trigger {
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    gap: 4.5px;
    width: 24px;
    height: 24px;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;
    flex-shrink: 0;
  }

  .menu-trigger span {
    display: block;
    width: 18px;
    height: 1.2px;
    background: #5b5a53;
    border-radius: 0;
  }

  .header-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .header-logo .logo-text { 
    font-size: 1.6rem;
    color: #5b5a53;
    font-weight: 700;
    letter-spacing: -0.02em;
    opacity: 0.9;
    display: block;
    line-height: 1;
  }

  .mobile-header-icons {
    display: flex !important;
    gap: 12px; /* Tight spacing like Rhode */
    align-items: center;
    flex-shrink: 0;
    z-index: 10;
  }

  .mobile-header-icons svg {
    stroke-width: 1.2px !important;
    color: #5b5a53 !important;
    width: 18px; /* Smaller icons matching Rhode */
    height: 18px;
    opacity: 0.9 !important;
    display: block !important;
  }

  .cart-icon-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .cart-count {
    position: absolute;
    top: -4px;
    right: -5px;
    font-size: 9px;
    font-weight: 600;
    color: #5b5a53;
    font-family: inherit;
    line-height: 1;
  }
}

/* Mobile Menu Drawer Styling */
.mobile-menu-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #f1efea;
  z-index: 2000;
  transform: translateX(-100%);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.mobile-menu-drawer.open {
  transform: translateX(0);
}

.menu-inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow-y: auto;
}

.menu-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 20px;
  border-bottom: 1px solid #d1d1cf;
}

.menu-close {
  font-size: 1.5rem;
  cursor: pointer;
  font-weight: 800;
}

.menu-logo-small {
  font-family: 'Inter', sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  letter-spacing: -0.05em;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.menu-icons {
  display: flex;
  gap: 15px;
  align-items: center;
}

.menu-icons svg {
  color: #333;
  cursor: pointer;
}

.menu-top svg {
  color: #333;
  stroke-width: 1.5;
}

.menu-tabs-container {
  padding: 15px 0;
  border-bottom: 1px solid #d1d1cf;
  overflow-x: auto;
  scrollbar-width: none;
}

.menu-tabs {
  display: flex;
  gap: 30px;
  padding: 0 20px;
}

.tab {
  font-size: 0.75rem;
  font-weight: 600;
  color: #999;
  white-space: nowrap;
  padding-bottom: 5px;
  cursor: pointer;
  border-bottom: 2px solid transparent;
}

.tab.active {
  color: #333;
  border-bottom: 2px solid #333;
}

.menu-products {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.menu-product-row {
  background: #fff;
  border: 1px solid #d1d1cf;
  border-radius: 4px;
  padding: 15px;
  display: flex;
  align-items: center;
  gap: 15px;
}

.mini-thumb {
  width: 50px;
  height: 50px;
  flex-shrink: 0;
}

.mini-thumb img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.mini-title {
  font-size: 0.85rem;
  font-weight: 800;
  color: #333;
  letter-spacing: -0.02em;
}

.mini-tag {
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  color: #999;
  margin-top: 2px;
}

.mega-shop-btn {
  padding: 0 20px 30px;
}

.menu-secondary {
  padding: 30px 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  border-top: 1px solid #d1d1cf;
}

.menu-secondary a {
  font-size: 0.85rem;
  font-weight: 800;
  color: #333;
}

.menu-footer {
  padding: 30px 20px;
  background: rgba(0,0,0,0.03);
  margin-top: auto;
}

.region-selector {
  font-size: 0.75rem;
  font-weight: 600;
  color: #555;
}

.region-selector span {
  font-weight: 800;
  text-decoration: underline;
}

.header-nav ul {
  display: flex;
  list-style: none;
  gap: 20px;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.header-nav ul li a {
  color: #5B5A53 !important; /* Explicit Rhode grey for visibility */
  transition: opacity 0.2s ease;
}

.header-nav ul li a:hover {
  opacity: 0.7;
}

.header-nav.header-right ul {
  justify-content: flex-end;
}

.header-logo {
  display: flex;
  justify-content: center;
  padding: 0 40px;
}

.logo-text { 
  font-weight: 800; 
  font-size: 2.2rem; 
  letter-spacing: -0.04em; 
  text-transform: lowercase;
  color: #333;
  line-height: 1;
}

/* Hero Section */
.hero-block {
  position: relative;
  border-radius: var(--border-radius);
  height: auto; 
  aspect-ratio: 3 / 1; /* Match the banner's wide proportions move moved moves move */
  margin: 0 12px; 
  overflow: hidden;
}

.hero-video-bg {
  width: 100%;
  height: 100%;
  object-fit: contain; /* CRITICAL: ensures full banner image is visible move move */
  background: #fff;
}

.hero-bottom {
  position: absolute;
  bottom: 60px;
  right: 60px;
  max-width: 800px; /* increased to prevent wrapping */
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 10px; /* vertical space between title and button */
  align-items: flex-end;
}

.hero-title {
  display: none !important; /* Hide overlay text since banner has text move move */
}

.hero-bottom .btn-pill-outline {
  display: inline-block;
  padding: 12px 35px;
  font-size: 0.85rem;
  min-width: 180px;
  text-align: center;
  white-space: nowrap; /* keep on one line */
}

/* Mobile Adjustments for Hero */
@media (max-width: 768px) {
  .page-wrapper {
    padding: 100px 16px 16px; /* Space for fixed mobile header move move move */
    gap: 12px;
  }

  .hero-block {
    height: auto;
    aspect-ratio: 1 / 1;
    margin: 0;
    border-radius: 14px;
    }

  .hero-video-bg {
    object-fit: cover;
  }

  /* Rhode layout: text wraps 2 lines on RIGHT, button stacked BELOW Ã¢â‚¬â€ column, right-aligned */
  .hero-bottom {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 132px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end; /* RIGHT-aligned Ã¢â‚¬â€ matches Rhode BOTTOM_RIGHT class */
    gap: 8px;
    background: transparent;
    text-align: right;
  }

  .hero-title {
    font-size: 1.35rem;
    line-height: 1.15;
    font-weight: 700;
    margin: 0;
    color: #fff;
    max-width: 100%;
    letter-spacing: -0.01em;
    text-align: right;
  }

  /* Button sits BELOW the title text, right-aligned */
  .hero-bottom .btn-pill-outline {
    position: static;
    flex-shrink: 0;
    align-self: flex-end; /* Right-aligned */
    padding: 7px 18px;
    font-size: 0.62rem;
    white-space: nowrap;
    border: 1px solid rgba(255,255,255,0.85);
    color: #fff;
    border-radius: 50px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(6px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
}

/* Base card used across all sections */
.card {
  background-color: var(--surface-color);
  border-radius: var(--border-radius);
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Category Navigation Bar */
.category-bar {
  padding: 20px 12px 15px;
}

.category-list {
  display: flex;
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
  overflow-x: auto;
  scrollbar-width: none;
}

.category-list::-webkit-scrollbar { display: none; }

.cat-link {
  font-size: 0.65rem;
  font-weight: 700;
  color: #5b5a53;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 8px 18px;
  border: 1px solid #d1d1cf;
  border-radius: 50px;
  transition: all 0.3s ease;
  white-space: nowrap;
  display: inline-block;
}

.cat-link.active {
  background-color: #5b5a53;
  color: #fff;
  border-color: #5b5a53;
}

@media (max-width: 768px) {
  .category-bar {
    padding: 15px 16px;
  }
}

/* Product scroll wrapper + arrow button */
.product-scroll-wrapper {
  position: relative;
}

.product-scroll-header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 12px 10px;
}

.scroll-arrow-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #2c2b28;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.25s ease, opacity 0.25s ease, transform 0.2s ease;
  flex-shrink: 0;
}

.scroll-arrow-btn:hover {
  background: #555;
  transform: scale(1.08);
}

@media (max-width: 768px) {
  .scroll-arrow-btn {
    display: none !important;
  }
}

/* Product Collection Slider */
.product-scroll-section {
  position: relative;
  margin-top: 20px;
}

.product-scroll-controls {
  position: absolute;
  top: 50%;
  left: 15px;
  right: 15px;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  pointer-events: none;
  z-index: 500; /* Ensure it is above cards move move moved moves move move move move move move move */
}

.scroll-arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  pointer-events: auto;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 4px 15px rgba(0,0,0,0.12); /* Rhode exact match shadow move move moved moves move move move move move move move */
  opacity: 1; /* Always visible for user clarity move move moved moves move move move move move move move */
}

.scroll-arrow svg {
  color: #333;
  stroke-width: 2.5px;
  width: 22px;
  height: 22px;
}

.scroll-arrow:hover {
  background: #fff;
  transform: scale(1.1);
  box-shadow: 0 6px 16px rgba(0,0,0,0.1);
}

.product-collection {
  display: flex;
  gap: 16px; /* Slightly wider gap */
  overflow-x: auto;
  scrollbar-width: none;
  scroll-behavior: smooth;
  padding: 10px 40px 30px; /* More padding for a cleaner look move move move */
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
}

.product-collection::-webkit-scrollbar { display: none; }

/* Standard product card (used in the scroll) */
.card-standard {
  flex: 0 0 270px;
  background-color: #f2f0ed;
  border-radius: 14px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  cursor: pointer;
  text-decoration: none;
  transition: box-shadow 0.3s ease;
  scroll-snap-align: start;
}

.card-standard:hover {
  box-shadow: 0 8px 24px rgba(0,0,0,0.1);
}

.product-placeholder-img {
  width: 100%;
  height: 220px;
  background: #e0deda;
  border-radius: 10px;
}

.product-image-wrap img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  border-radius: 10px;
}

.card-product-title {
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.03em;
  color: #2c2b28;
}

.card-subtitle {
  font-size: 0.72rem;
  color: #7A7973;
  margin-top: 2px;
}

.product-name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
  margin-top: 4px;
}

@media (max-width: 768px) {
  .product-collection {
    scroll-snap-type: x mandatory;
    padding-right: 16px;
  }
  .card-standard {
    flex: 0 0 75vw;
  }
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ Rhode-style product cards (High Fidelity) Ã¢â€â‚¬Ã¢â€â‚¬ */
.card-rhode {
  flex: 0 0 30%; /* Clearly shows peek on most screens move move moved moves move move move move move move */
  min-width: 330px;
  height: 600px;
  background-color: #f6f5f3;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: background-color 0.3s ease;
  scroll-snap-align: start;
  text-decoration: none;
}

@media (max-width: 768px) {
  .card-rhode {
    overflow: visible !important;
  }
}

.card-rhode:hover {
