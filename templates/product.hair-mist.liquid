.product-showcase-card {
  width: 100%;
  text-align: left;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.product-swirl-wrap {
  width: 100%;
}

.product-swirl-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.stars-row {
  font-size: 0.75rem;
  color: #7A7973;
  margin-bottom: 12px;
}

.showcase-title {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #2c2b28;
  margin-bottom: 6px;
}

.showcase-subtitle {
  font-size: 0.85rem;
  color: #7A7973;
  margin-bottom: 30px;
}

.btn-pill-buy {
  display: inline-block;
  padding: 16px 40px;
  border: 1.5px solid #2c2b28;
  border-radius: 50px;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  color: #2c2b28;
  text-decoration: none;
  transition: all 0.3s ease;
}

.btn-pill-buy:hover {
  background-color: #2c2b28;
  color: #fff;
}

.pagination-counter {
  position: absolute;
  bottom: 40px;
  right: 40px;
  font-size: 1.8rem;
  font-weight: 800;
  letter-spacing: -0.05em;
  color: #2c2b28;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ Mobile: seamlessly connected, zero gap Ã¢â€â‚¬Ã¢â€â‚¬ */
@media (max-width: 768px) {
  .split-category-wrapper {
    margin: 0 0 12px; /* flush to screen edges */
  }

  .split-cat-grid {
    flex-direction: column !important; /* Force stack on mobile regardless of flipped class */
    gap: 0; /* NO gap between image and card */
    min-height: auto;
  }

  .split-cat-left,
  .split-cat-right {
    min-height: 420px;
    height: auto;
    border-radius: 12px;
    width: 100%;
    padding: 0;
  }

  .split-cat-img {
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    display: block;
  }

  .pagination-counter {
    bottom: 20px;
    right: 20px;
    font-size: 1.4rem;
  }

  .product-overlay-details {
    position: absolute !important;
    bottom: 16px !important;
    left: 16px !important;
    right: auto !important;
    text-align: left !important;
    z-index: 10;
  }

  .product-overlay-details .stars-row {
    font-size: 0.55rem !important;
    margin-bottom: 4px !important;
  }

  .product-overlay-details .showcase-title {
    font-size: 0.85rem !important;
    margin-bottom: 10px !important;
    line-height: 1.2 !important;
  }

  .product-overlay-details .btn-pill-buy {
    font-size: 0.6rem !important;
    padding: 7px 16px !important;
    border-radius: 50px !important;
  }
}

