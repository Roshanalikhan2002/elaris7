                .then(data => {
                    window.location.href = '/cart';
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error adding to cart. Please try again.');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                });
            });
          </script>
</body>
</html>














