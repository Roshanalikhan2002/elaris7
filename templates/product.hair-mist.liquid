  gap: 4px;
}

.card-stars {
  font-size: 0.65rem;
  color: #333;
  letter-spacing: 0.1em;
}

.review-count {
  color: #7A7973;
  margin-left: 4px;
}

.card-name {
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #333;
}

.btn-rhode-buy-pill {
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1px solid #333;
  color: #333;
  border-radius: 50px;
